@using System.Globalization
@using System.Linq
@using System
@using ecommerce.Core.Identity
@using ecommerce.Web.Utility

<header class="pb-md-4 pb-0">

<div class="sticky-header-container">
<div class="header-top">
    <div class="container-fluid-lg">
        <div class="row">
            <div class="col-6 d-lg-none d-flex align-items-center">
                <a href="/" class="d-block">
                    <img src="/assets/images/logo/yedeksen.png" class="img-fluid" style="max-height: 32px; filter: contrast(2) brightness(2) invert(1); mix-blend-mode: screen;" alt="Yedeksen">
                </a>
            </div>
            <div class="col-xxl-3 d-xxl-block d-none">
                <div class="top-left-header">
                    <i class="iconly-Call icli text-white"></i>
                    <span class="text-white">
                        <a href="tel:08508407300" class="text-white text-decoration-none fw-semibold">0850 840 7300</a>
                    </span>
                </div>
            </div>

            <div class="col-xxl-6 col-lg-9 d-lg-block d-none">
                <div class="header-offer">
                    <div class="notification-slider">
                        <div>
                            <div class="timer-notification">
                                <h6 class="mb-0">
                                    <strong class="me-1">@lang["HeaderTicker1Strong"]</strong>@lang["HeaderTicker1Text"]
                                </h6>
                            </div>
                        </div>

                        <div>
                            <div class="timer-notification">
                                <h6 class="mb-0">
                                    @lang["HeaderTicker2Text"]
                                    <a href="/discounts" class="text-white text-decoration-underline ms-1">
                                        @lang["HeaderBuyNow"]
                                    </a>
                                </h6>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-6 d-flex justify-content-end align-items-center">
                <ul class="about-list right-nav-about">
                    <li class="right-nav-list">
                        <div class="dropdown theme-form-select">
                            <button class="btn dropdown-toggle" type="button" id="select-language"
                                    data-bs-toggle="dropdown">
                                <span class="d-none d-md-inline">@lang.Language.DisplayName</span>
                                <span class="d-md-none fw-bold">@lang.Language.Locale.Substring(0, 2).ToUpper()</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @foreach (var l in lang.Languages)
                                {
                                    <li>
                                        <a class="dropdown-item" href="javascript:void(0)"
                                           @onclick="() => SetLanguage(l.Locale)">
                                            <span>@l.DisplayName</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="top-nav top-header">
<div class="container-fluid-lg">
<div class="row">
<div class="col-12">
    <div class="navbar-top d-flex align-items-center justify-content-between">
        <button class="navbar-toggler d-none d-md-inline d-xl-none navbar-menu-button" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#primaryMenu">
            <span class="navbar-toggler-icon">
                <i class="fa-solid fa-bars"></i>
            </span>
        </button>
        <!-- Mobile: Home icon goes to Anasayfa -->
      
        <!-- Desktop/Tablet: show logo -->
        <a href="/" class="web-logo nav-logo d-none d-md-inline" @onclick:preventDefault @onclick="@(() => _navigation.NavigateTo("/"))">
            <img src="../assets/images/logo/yedeksen.png" class="img-fluid blur-up lazyload" alt="">
        </a>


        <!-- Mobile: replace logo area with search -->
        <div class="mobile-logo-replace d-md-none flex-grow-1">
            <form class="w-100 position-relative" @onsubmit="OnSearchSubmitAsync" @onsubmit:preventDefault>
                <input type="search" 
                       class="form-control mobile-search-input" 
                       placeholder="@lang["HeaderSearch"]"
                       value="@searchText"
                       @oninput="@(async (e) => await OnSearchInput(e))">
                <button type="button" 
                        class="mobile-search-advanced-btn" 
                        @onclick="() => OpenAdvancedSearch(true)" 
                        title="@lang["Search.AdvancedButton"]">
                    <i class="fa-solid fa-sliders"></i>
                </button>
            </form>
        </div>

        @* Mobile Search *@
        @if (isMobile)
        {
            <div class="header-search-overlay @(isSearchOpen ? "open" : "")" @onclick="CloseSearch"></div>
            <div class="header-search-dropdown mobile @(isSearchOpen ? "open" : "")" @onclick:stopPropagation="true" @onkeydown="OnSearchKeyDown">
                    <div class="search-card">
                        <div class="search-card-head">
                            <div>
                                <h6>@lang["HeaderSearchResult"]</h6>
                                <span class="hint">@searchResults.Count @lang["HeaderSearchProduct"] · @brands.Count @lang["HeaderSearchBrand"] · @compatibleVehicles.Count Araç</span>
                                <div class="mt-2 d-flex align-items-center gap-2">
                                    <div class="form-check form-switch m-0 p-0 d-flex align-items-center gap-2">
                                        <input class="form-check-input ms-0" type="checkbox" id="mobileOnlyInStock" checked="@showOnlyInStock" @onchange="OnOnlyInStockToggle">
                                        <label class="form-check-label small fw-bold" for="mobileOnlyInStock" style="font-size: 0.75rem; cursor: pointer;">@lang["Search.OnlyInStock"]</label>
                                    </div>
                                </div>
                            </div>
                            <div class="head-actions">
                                <button type="button" class="ghost-btn" @onclick="() => OpenAdvancedSearch(true)">
                                    <i class="fa-solid fa-car"></i>
                                </button>
                                <button type="button" class="ghost-btn" @onclick="CloseSearch">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>
                        </div>

                        <div class="search-tabs">
                            <button class="tab @(activeTab == "products" ? "active" : "")" @onclick='() => SwitchTab("products")'>
                                <span>@lang["HeaderSearchProduct"]</span>
                                <span class="count">@searchResults.Count</span>
                            </button>
                            <button class="tab @(activeTab == "brands" ? "active" : "")" @onclick='() => SwitchTab("brands")'>
                                <span>@lang["HeaderSearchBrand"]</span>
                                <span class="count">@brands.Count</span>
                            </button>
                            <button class="tab @(activeTab == "vehicles" ? "active" : "")" @onclick='() => SwitchTab("vehicles")'>
                                <span><i class="fa-solid fa-car me-1"></i>Araçlar</span>
                                <span class="count">@compatibleVehicles.Count</span>
                            </button>
                        </div>

                        <div class="search-results-scroll">
                            @if (activeTab == "products")
                            {
                                @if (searchResults.Any())
                                {
                                    @foreach (var product in searchResults)
                                    {
                                        var compatibilitySummaryMobile = GetCompatibilitySummary(product);
                                        <button type="button" class="search-result-item @(product.Stock <= 0 ? "out-of-stock" : "")" @onclick="() => GoToProduct(product.SellerItemId)">
                                            <span class="result-thumb">
                                                <img src="@ResolveSearchImage(product)" alt="@product.ProductName">
                                            </span>
                                            <span class="result-body">

                                                <span class="title">@product.ProductName</span>

                                                <span class="meta mt-1 mb-1">
                                                     @if(!string.IsNullOrEmpty(product.PartNumber)) { <span class="text-secondary small me-2"><i class="fa-solid fa-barcode me-1"></i>@product.PartNumber</span> }
                                                     @if(!string.IsNullOrEmpty(product.GroupCode)) { <span class="text-primary small"><i class="fa-solid fa-tag me-1"></i>@product.GroupCode</span> }
                                                </span>

                                                <div class="d-flex justify-content-between align-items-center mt-1">
                                                    @if (product.SalePrice > 0)
                                                    {
                                                        <div class="result-price" style="font-weight: 700; color: #0e947a;">@product.SalePrice.ToString("C2")</div>
                                                    }
                                                    else
                                                    {
                                                        <div></div>
                                                    }
                                                    <div class="stock-badge @(product.Stock > 0 ? "in-stock" : "out-of-stock")">
                                                        <i class="fa-solid @(product.Stock > 0 ? "fa-circle-check" : "fa-circle-xmark")"></i>
                                                        @(product.Stock > 0 ? lang["Product.InStock"] : lang["Product.OutOfStock"])
                                                    </div>
                                                </div>
                                                @if (product.SalePrice > 0 && !string.IsNullOrEmpty(product.SellerName))
                                                {
                                                    <div class="result-seller text-muted mt-1" style="font-size: 0.7rem;">
                                                        <i class="fa-solid fa-store me-1"></i>@product.SellerName
                                                    </div>
                                                }
                                                @if (HasPerfectCompatibility(product) && !string.IsNullOrWhiteSpace(compatibilitySummaryMobile))
                                                {
                                                    <span class="search-compatibility-chip">
                                                        <i class="fa-solid fa-check-circle"></i>
                                                        <span class="chip-title">@lang["Product.PerfectCompatibilityBadge"]</span>
                                                        <span class="compatibility-hint">@compatibilitySummaryMobile</span>
                                                    </span>
                                                }
                                            </span>
                                        </button>
                                    }
                                }
                                else if (!string.IsNullOrEmpty(searchText) && searchText.Trim().Length >= 3)
                                {
                                    <div class="search-empty">@lang["HeaderSearchNotFound"]</div>
                                }
                                else if (!string.IsNullOrEmpty(searchText))
                                {
                                    <div class="search-empty">@lang["HeaderLength"]</div>
                                }
                            }
                            else if (activeTab == "brands")
                            {
                                @if (brands.Any())
                                {
                                    @foreach (var brand in brands)
                                    {
                                        <a class="search-result-item brand" href="product-search?brandid=@brand.Id&brandname=@FriendlyUrlHelper.GetFriendlyTitle(brand.Name!)">
                                            <span class="result-body">
                                                <span class="title">@brand.Name</span>
                                            </span>
                                            <span class="result-trailing">
                                                <i class="fa-solid fa-chevron-right"></i>
                                            </span>
                                        </a>
                                    }
                                }
                                else
                                {
                                    <div class="search-empty">@lang["HeaderNFBrand"]</div>
                                }
                            }
                            else if (activeTab == "vehicles")
                            {
                                @if (compatibleVehicles.Any())
                                {
                                    @foreach (var vehicle in compatibleVehicles)
                                    {
                                        <button type="button" class="search-result-item vehicle" @onclick="() => GoToVehicle(vehicle)">
                                            <span class="result-thumb">
                                                <i class="fa-solid fa-car"></i>
                                            </span>
                                            <span class="result-body">
                                                <span class="manufacturer">@vehicle.ManufacturerName</span>
                                                <span class="model">@vehicle.BaseModelName @vehicle.SubModelName</span>
                                            </span>
                                        </button>
                                    }
                                }
                                else
                                {
                                    <div class="search-empty">Uyumlu araç bulunamadı</div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }

        <div class="middle-box d-none d-md-block" style="position: relative;">
            <div class="search-box">
                <form class="flex-grow-1" @onsubmit="OnSearchSubmitAsync" @onsubmit:preventDefault>
                    <div class="search-input-group">
                        <input type="search" class="form-control" placeholder="@lang["HeaderSearch"]"
                           value="@searchText"
                           @oninput="@(async (e) => await OnSearchInput(e))" />
                        <button type="button" class="search-advanced-btn" @onclick="() => OpenAdvancedSearch(true)" title="@lang["Search.AdvancedButton"]">
                            <i class="fa-solid fa-car"></i>
                        </button>
                    </div>
                </form>
            </div>
            @if (!string.IsNullOrWhiteSpace(searchText))
            {
                <button type="button" @onclick="ClearSearch"
                        style="position: absolute; right: 54px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; z-index: 11;">
                    <i class="fa-solid fa-xmark" style="font-size: 16px;"></i>
                </button>
            }

            @if (!isMobile)
            {
            <div class="header-search-dropdown desktop @(isSearchOpen ? "open" : "")" @onclick:stopPropagation="true">
                <div class="search-card">
                    <div class="search-card-head">
                        <div>
                            <h6>@lang["HeaderSearchResult"]</h6>
                             <span class="hint">@searchResults.Count @lang["HeaderSearchProduct"] · @brands.Count @lang["HeaderSearchBrand"]</span>
                             <div class="mt-2 d-flex align-items-center gap-2">
                                 <div class="form-check form-switch m-0 p-0 d-flex align-items-center gap-2">
                                     <input class="form-check-input ms-0" type="checkbox" id="desktopOnlyInStock" checked="@showOnlyInStock" @onchange="OnOnlyInStockToggle">
                                     <label class="form-check-label small fw-bold" for="desktopOnlyInStock" style="font-size: 0.75rem; cursor: pointer;">@lang["Search.OnlyInStock"]</label>
                                 </div>
                             </div>
                         </div>
                        <div class="head-actions">
                            <button type="button" class="ghost-btn" @onclick="CloseSearch">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                    </div>
                    <div class="search-tabs">
                        <button class="tab @(activeTab == "products" ? "active" : "")" @onclick='() => SwitchTab("products")'>
                            <span>@lang["HeaderSearchProduct"]</span>
                            <span class="count">@searchResults.Count</span>
                        </button>
                        <button class="tab @(activeTab == "brands" ? "active" : "")" @onclick='() => SwitchTab("brands")'>
                            <span>@lang["HeaderSearchBrand"]</span>
                            <span class="count">@brands.Count</span>
                        </button>
                        <button class="tab @(activeTab == "vehicles" ? "active" : "")" @onclick='() => SwitchTab("vehicles")'>
                            <span><i class="fa-solid fa-car me-1"></i>Araçlar</span>
                            <span class="count">@compatibleVehicles.Count</span>
                        </button>
                    </div>

                    <div class="search-results-scroll desktop">
                        @if (activeTab == "products")
                        {
                            @if (searchResults.Any())
                            {
                                @foreach (var product in searchResults)
                                {
                                    var compatibilitySummaryDesktop = GetCompatibilitySummary(product);
                                    <button type="button" class="search-result-item @(product.Stock <= 0 ? "out-of-stock" : "")" @onclick="() => GoToProduct(product.SellerItemId)">
                                        <span class="result-thumb">
                                            <img src="@ResolveSearchImage(product)" alt="@product.ProductName">
                                        </span>
                                            <span class="result-body">

                                                <span class="title">@product.ProductName</span>
                                                
                                                <span class="meta mt-1 mb-1">
                                                     @if(!string.IsNullOrEmpty(product.PartNumber)) { <span class="text-secondary small me-2"><i class="fa-solid fa-barcode me-1"></i>@product.PartNumber</span> }
                                                     @if(!string.IsNullOrEmpty(product.GroupCode))
                                                     {
                                                         <div class="d-flex flex-wrap align-items-center gap-1 mt-1">
                                                             <span class="text-secondary fw-bold me-1" style="font-size: 10px; opacity: 0.8;">OEM:</span>
                                                             <span class="d-inline-flex align-items-center justify-content-center"
                                                                   style="font-size: 10px; background-color: #f1f5f9; color: #334155; padding: 2px 6px; border-radius: 4px; border: 1px solid #e2e8f0; font-weight: 600;">
                                                                 @product.GroupCode
                                                             </span>
                                                         </div>
                                                     }
                                                </span>

                                                <div class="d-flex justify-content-between align-items-center mt-1">
                                                    @if (product.SalePrice > 0)
                                                    {
                                                        <div class="result-price" style="font-weight: 700; color: #0e947a;">@product.SalePrice.ToString("C2")</div>
                                                    }
                                                    else
                                                    {
                                                        <div></div>
                                                    }
                                                    <div class="stock-badge @(product.Stock > 0 ? "in-stock" : "out-of-stock")">
                                                        <i class="fa-solid @(product.Stock > 0 ? "fa-circle-check" : "fa-circle-xmark")"></i>
                                                        @(product.Stock > 0 ? lang["Product.InStock"] : lang["Product.OutOfStock"])
                                                    </div>
                                                </div>
                                                @if (product.SalePrice > 0 && !string.IsNullOrEmpty(product.SellerName))
                                                {
                                                    <div class="result-seller text-muted mt-1" style="font-size: 0.7rem;">
                                                        <i class="fa-solid fa-store me-1"></i>@product.SellerName
                                                    </div>
                                                }
                                            @if (HasPerfectCompatibility(product) && !string.IsNullOrWhiteSpace(compatibilitySummaryDesktop))
                                            {
                                                <span class="search-compatibility-chip">
                                                    <i class="fa-solid fa-check-circle"></i>
                                                    <span class="chip-title">@lang["Product.PerfectCompatibilityBadge"]</span>
                                                    <span class="compatibility-hint">@compatibilitySummaryDesktop</span>
                                                </span>
                                            }
                                        </span>
                                        <span class="result-trailing">
                                            <i class="fa-solid fa-chevron-right"></i>
                                        </span>
                                    </button>
                                }
                            }
                            else if (!string.IsNullOrEmpty(searchText) && searchText.Trim().Length >= 3)
                            {
                                <div class="search-empty">@lang["HeaderSearchNotFound"]</div>
                            }
                            else if (!string.IsNullOrEmpty(searchText))
                            {
                                <div class="search-empty">@lang["HeaderLength"]</div>
                            }
                        }
                        else if (activeTab == "brands")
                        {
                            @if (brands.Any())
                            {
                                @foreach (var brand in brands)
                                {
                                    <a class="search-result-item brand" href="product-search?brandid=@brand.Id&brandname=@FriendlyUrlHelper.GetFriendlyTitle(brand.Name!)">
                                        <span class="result-body">
                                            <span class="title">@brand.Name</span>
                                        </span>
                                        <span class="result-trailing">
                                            <i class="fa-solid fa-chevron-right"></i>
                                        </span>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="search-empty">@lang["HeaderNFBrand"]</div>
                            }
                        }
                        else if (activeTab == "vehicles")
                        {
                            @if (compatibleVehicles.Any())
                            {
                                @foreach (var vehicle in compatibleVehicles)
                                {
                                    <button type="button" class="search-result-item vehicle" @onclick="() => GoToVehicle(vehicle)">
                                        <span class="result-thumb">
                                            <i class="fa-solid fa-car"></i>
                                        </span>
                                        <span class="result-body">
                                            <span class="manufacturer">@vehicle.ManufacturerName</span>
                                            <span class="model">@vehicle.BaseModelName @vehicle.SubModelName</span>
                                        </span>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="search-empty">Uyumlu araç bulunamadı</div>
                            }
                        }
                    </div>
                </div>
            </div>
            }
        </div>

        <div class="rightside-box">
            <div class="search-full">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fa-solid fa-search font-light"></i>
                    </span>
                    <input type="text" class="form-control search-type" placeholder="Search here..">
                    <span class="input-group-text close-search">
                        <i class="fa-solid fa-xmark font-light"></i>
                    </span>
                </div>
            </div>
            <ul class="right-side-menu">
                @if(IsLogin){
            
          
                    <li class="right-side">
                        <a href="/user-dashboard#pills-wishlist" class="btn p-0 position-relative header-wishlist">
                            <i class="fa-regular fa-heart"></i>
                        </a>
                    </li>
                    <li class="right-side d-none d-md-flex">
                        <a href="/user-dashboard#pills-garage"
                           class="btn p-0 position-relative header-garage"
                           title="@lang["MyGarage"]"
                           aria-label="@lang["MyGarage"]">
                            <span class="garage-icon-pill">
                                <i class="fa-solid fa-car-side"></i>
                            </span>
                        </a>
                    </li>
                    <li class="right-side">
                        <div class="header-badge">
                            <button type="button" class="btn p-0 position-relative header-wishlist" @onclick="ToggleCartDropdown">
                                <i class="fa-solid fa-cart-shopping"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge bg-success">
                                    @CartResult?.CartCount
                                    <span class="visually-hidden">@lang["UnreadMessages"]</span>
                                </span>
                            </button>

            <div class="header-cart-dropdown @(isCartDropdownOpen ? "show" : "")" @onclick="CloseCartDropdown">
                <div class="cart-panel" @onclick:stopPropagation="true">
                    <div class="cart-head">
                        <h5>@lang["Header.CartTitle"] (@CartResult?.TotalItems)</h5>
                        <button type="button" class="btn-close" @onclick="CloseCartDropdown" aria-label="@lang["Common.Close"]">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    </div>
                    
                    <ul class="cart-list">
                        @if (CartResult?.Sellers != null && CartResult.Sellers.Any())
                        {
                            @foreach (var seller in CartResult.Sellers)
                            {
                                <!-- Satıcı Başlığı -->
                                <li class="cart-seller-header">
                                    <div class="seller-info">
                                        <i class="fa-solid fa-store me-2"></i>
                                        <span class="seller-name">@seller.SellerName</span>
                                    </div>
                                    <div class="seller-total">
                                        @seller.OrderTotal.ToString("C")
                                    </div>
                                </li>
                                
                                <!-- Satıcının Ürünleri -->
                                @foreach (var item in seller.Items)
                                {
                                    <li class="drop-cart" @key="@($"{item.Id}-{item.ProductSellerItemId}")">
                                        <div class="img">
                                            <img src="@_appStateManager.ResolveImageUrl(item.PictureUrl)"
                                             alt="@item.ProductName" 
                                                 onerror="this.onerror=null; this.src='/assets/images/no-product-image.png';" />
                                        </div>
                                        <div class="drop-contain">
                                            <h6>@item.ProductName</h6>
                                            <div class="meta">
                                                <span>@item.Quantity adet</span>
                                                <span>@item.UnitPrice.ToString("C")</span>
                                            </div>
                                            @if (item.IsPerfectCompatibility)
                                            {
                                                <div class="cart-compatibility-badge">
                                                    <i class="fa-solid fa-check-circle"></i>
                                                    @lang["Product.PerfectCompatibilityBadge"]
                                                </div>
                                            }
                                        </div>
                                        <div class="drop-price">@item.Total.ToString("C")</div>
                                        <button class="close_button" @onclick="() => RemoveFromCart(item.Id)" aria-label="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </li>
                                }
                            }
                        }
                    </ul>

                        <div class="cart-foot">
                            @if (CartResult?.DiscountSummaries != null && CartResult.DiscountSummaries.Any())
                            {
                                <div class="cart-total-row">
                                    <span class="label">@lang["Cart.Subtotal"]</span>
                                    <span class="value">@CartResult.SubTotal.ToString("C")</span>
                                </div>
         
                                <div class="cart-total-row">
                                    <span class="label">@lang["Cart.DiscountTotal"]</span>
                                    <span class="value" style="color: #dc3545;">@CartResult.OrderTotalDiscount.ToString("C")</span>
                                </div>
                            
                            }
                            <div class="cart-total-row">
                                <span class="label">@lang["Cart.CargoPriceLabel"]</span>
                                <span class="value">@(((CartResult?.CargoPrice ?? 0m) - (CartResult?.CargoDiscount ?? 0m)).ToString("C"))</span>
                            </div>
                            <div class="cart-total-row">
                                <span class="label">@lang["Cart.Total"]</span>
                                <span class="value">@CartResult?.OrderTotal.ToString("C")</span>
                            </div>
                            
                        <div class="cart-actions">
                            <a href="/cart" class="btn btn-outline" @onclick="CloseCartDropdown">@lang["ViewCart"]</a>
                            <a href="/checkout" class="btn btn-primary" @onclick="CloseCartDropdown">@lang["Cart.Checkout"]</a>
                        </div>
                    </div>
                </div>
            </div>
                        </div>
                    </li>

                }
                
                <li class="right-side onhover-dropdown">
                    <div class="delivery-login-box">
                        <div class="delivery-icon">
                            <i class="fa-regular fa-user"></i>
                        </div>
                        <div class="delivery-detail d-none d-md-block">
                            @if (IsLogin)
                            {
                                <h6>@lang["Hello"]</h6>
                                <h5>@(!string.IsNullOrEmpty(userInitials) ? userInitials : lang["MyAccount"])</h5>
                            }
                        </div>
                    </div>
                    <div class="onhover-div onhover-div-login">
                        <ul class="user-box-name dropdown-font-matching">
                            @if (IsLogin)
                            {
                                <li class="product-box-contain">
                                    <a href="/user-dashboard">@lang["MyAccount"]</a>
                                </li>
                                <li class="product-box-contain">
                                    <a href="javascript:void(0);" @onclick="Logout">@lang["Logout"]</a>
                                </li>
                            }
                            else
                            {
                                <li class="product-box-contain">
                                    <a href="/login">@lang["Login"]</a>
                                </li>
                                <li class="product-box-contain">
                                    <a href="/register">@lang["Register"]</a>
                                </li>
                                <li class="product-box-contain">
                                    <a href="/forgot-password">@lang["ForgotPassword"]</a>
                                </li>
                            }
                        </ul>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>
</div>
</div>

<div class="container-fluid-lg" style="overflow: visible;">
    <div class="row">
        <div class="col-12" style="overflow: visible;">
            <div class="header-nav">
           
                <div class="header-nav-left">
                    <button class="dropdown-category" @onclick="ToggleCategoryMenu" id="category-button" onmouseenter="showMegaMenu()" style="position: relative; z-index: 1001; background: #0e947a; color: white; border: none; padding: 10px 16px; border-radius: 10px; cursor: pointer; font-weight: 700;" data-mobile-toggle="true">
                        <i class="fa-solid fa-bars-staggered"></i>
                        <span>@lang["MenuCategories"]</span>
                    </button>
                </div>

                @if (!isMobile && manufacturers != null && manufacturers.Any())
                {
                    <div class="manufacturer-slider-wrapper">
                        <div class="manufacturer-slider" id="manufacturerSlider">
                            @foreach (var manufacturer in manufacturers)
                            {
                                <a href="javascript:void(0)"
                                   @onclick="async () => await OpenBrandFlyout(manufacturer.Id)"
                                   class="manufacturer-item @(hoveredManufacturerId == manufacturer.Id ? "active" : string.Empty)"
                                   data-brand="@manufacturer.Name">
                                    <img src="@manufacturer.LogoUrl" 
                                         alt="@manufacturer.Name" 
                                         loading="lazy" 
                                         decoding="async" />
                                    <span class="brand-tooltip">@manufacturer.Name</span>
                                </a>
                            }
                        </div>

                    </div>
                }


                @if (showBrandFlyout && hoveredManufacturerId.HasValue && allManufacturerModels.Any())
                {
                    var currentManufacturer = activeManufacturer ?? manufacturers?.FirstOrDefault(x => x.Id == hoveredManufacturerId.Value);
                    var selectedName = currentManufacturer?.Name ?? "";
                    
                    <div class="manufacturer-flyout" @onmouseleave="() => { showBrandFlyout = false; modelSearchText = string.Empty; modelSearchNoResult = false; ResetActiveModel(); StateHasChanged(); }">
                                 <!-- Header with Brand Name -->
                                 <div class="flyout-header">
                                     <div class="brand-logo-section">
                                        <img class="brand-logo" src="@currentManufacturer?.LogoUrl" alt="@selectedName" />
                                         <h3>@selectedName</h3>
                                     </div>
                                 </div>
 
                                 <!-- Search Box -->
                                 <div style="padding: 12px 16px; background: white; border-bottom: 1px solid #e5e7eb;">
                                     <div style="position: relative;">
                                         <input type="text" 
                                                class="form-control" 
                                                placeholder="@lang["Catalog.SearchModelPlaceholder"]" 
                                                value="@modelSearchText"
                                                @oninput="@(e => { modelSearchText = e.Value?.ToString() ?? ""; FilterModels(); })"
                                                style="padding-left: 36px; border-radius: 8px; border: 1px solid #e5e7eb; font-size: 13px;" />
                                         <i class="fa-solid fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 14px;"></i>
                                         @if (!string.IsNullOrWhiteSpace(modelSearchText))
                                         {
                                             <button type="button" 
                                                     @onclick="() => { modelSearchText = string.Empty; FilterModels(); }"
                                                     style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer;">
                                                 <i class="fa-solid fa-times"></i>
                                             </button>
                                         }
                                     </div>
                                     @if (modelSearchNoResult)
                                     {
                                         <div class="model-search-feedback mt-2">
                                             <i class="fa-solid fa-circle-info me-2"></i>@lang["Catalog.ModelSearchFallback"]
                                         </div>
                                     }
                                 </div>
 
                                 <!-- Models & SubModels Layout -->
                                 <div class="models-layout @(isSubModelPanelVisible ? "show-submodels" : string.Empty)">
                                     <div class="models-column">
                                         @if (selectedManufacturerModels.Any())
                                         {
                                             @foreach (var model in selectedManufacturerModels)
                                             {
                                             <a href="javascript:void(0)"
                                                class="model-card @(activeBaseModel?.Id == model.Id ? "active" : string.Empty)"
                                                @onclick="(args) => ShowModelDetails(model)"
                                                @onclick:preventDefault>
                                                 <div class="model-image">
                                                     @if (!string.IsNullOrEmpty(model.ImageUrl))
                                                     {
                                                         <img src="@model.ImageUrl" alt="@model.Name" >
                                                     }
                                                     else
                                                     {
                                                         <div class="placeholder-image">
                                                             <i class="fa-solid fa-car"></i>
                                                         </div>
                                                     }
                                                 </div>
                                                 <div class="model-info">
                                                     <div class="model-name">@model.Name</div>
                                                     <div class="model-type">
                                                         <i class="fa-solid fa-@GetVehicleTypeIcon(model.VehicleType)"></i>
                                                         @GetVehicleTypeName(model.VehicleType)
                                                     </div>
                                                 </div>
                                                 <i class="fa-solid fa-chevron-right model-arrow"></i>
                                             </a>
                                             }
                                         }
                                         else if (!string.IsNullOrWhiteSpace(modelSearchText))
                                         {
                                             <div class="models-empty">
                                                 <i class="fa-solid fa-search"></i>
                                                 <p>@lang["Catalog.ModelSearchNoResult"]</p>
                                             </div>
                                         }

                                         @if (selectedManufacturerModels.Count < filteredModels.Count)
                                         {
                                             <div class="models-load-more">
                                                 <button class="btn btn-sm" @onclick="LoadMore" style="background: #0e947a; color: white; border: none; padding: 8px 20px; border-radius: 6px; cursor: pointer;">
                                                     <i class="fa-solid fa-plus"></i> @lang["Catalog.LoadMoreModels"] (@(filteredModels.Count - selectedManufacturerModels.Count) @lang["Catalog.MoreModels"])
                                                 </button>
                                             </div>
                                         }
                                     </div>

                                    <div class="submodels-column">
                                        @if (activeBaseModel != null && currentManufacturer != null)
                                        {
                                           <div class="submodel-search-group">
                                             <input type="text"
                                                    class="form-control"
                                                     placeholder="@lang["Catalog.SubModelSearchPlaceholder"]"
                                                     value="@subModelSearchText"
                                                     @oninput="UpdateSubModelSearch"
                                                     style="border-radius: 8px; border: 1px solid #e5e7eb; font-size: 12px;" />
                                                 @if (!string.IsNullOrWhiteSpace(subModelSearchText))
                                                 {
                                                     <button type="button" class="clear-btn" @onclick="() => { subModelSearchText = string.Empty; FilterActiveSubModels(); StateHasChanged(); }">
                                                         <i class="fa-solid fa-xmark"></i>
                                                     </button>
                                                 }
                                             </div>
 
                                             <div class="submodel-list">
                                                 @if (filteredActiveSubModels.Any())
                                                 {
                                                     @foreach (var subModel in filteredActiveSubModels)
                                                     {
                                                         <button type="button" class="submodel-item" @onclick="() => GoToSubModel(currentManufacturer, activeBaseModel, subModel)">
                                                             <span class="submodel-name">@subModel.Name</span>
                                                             <i class="fa-solid fa-arrow-right"></i>
                                                         </button>
                                                     }
                                                 }
                                                 else
                                                 {
                                                     <div class="loading-message">
                                                         <i class="fa-solid fa-circle-notch"></i>
                                                     </div>
                                                 }
                                             </div>
                                            
                                        }
                                        else
                                        {
                                             <div class="submodel-placeholder">
                                                 <i class="fa-solid fa-car-on"></i>
                                                 <p>@lang["Catalog.SubModelSelectPrompt"]</p>
                                             </div>
                                         }
                                     </div>
                                 </div>

                                 <!-- Footer -->
                                <div class="flyout-footer">
                                    <div class="flyout-footer-left">
                                        @if (selectedManufacturerModels.Any())
                                        {
                                            <span>@selectedManufacturerModels.Count / @filteredModels.Count @lang["Catalog.ModelsShowing"]</span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(modelSearchText))
                                        {
                                            <span style="color: #94a3b8;">@lang["Catalog.ZeroResultsTryAgain"]</span>
                                        }
                                    </div>
                                    <div class="flyout-footer-actions">
                                        @if (activeBaseModel != null && currentManufacturer != null)
                                        {
                                            <button type="button" class="btn btn-sm view-model-products" @onclick="() => GoToModel(currentManufacturer.Id, currentManufacturer.Name, activeBaseModel.Id, activeBaseModel.Name, activeBaseModel.ManufacturerKey, activeBaseModel.BaseModelKey)">
                                                <i class="fa-solid fa-arrow-up-right-from-square me-1"></i> @lang["Catalog.ViewModelProducts"]
                                            </button>
                                        }
                                    </div>
                                </div>
                             </div>
                 }

                <!-- Modern E-commerce Mega Menu - Desktop Only -->
                    @if (!isMobile)
                    {
                        <div class="mega-menu-container" onmouseleave="hideMegaMenu()" style="position: absolute; top: 100%; left: 0; z-index: 1000; background: white; border: 1px solid #e5e7eb; border-radius: 12px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); min-width: 900px; max-width: 1200px; max-height: 600px;">
                            <div class="mega-menu-content">
                                @if (categories != null && categories.Any() && categories.Count > 0)
                                {
                                    var mainCategories = categories
                                        .Where(c => c.ParentId == null && c.IsMainPage)
                                        .OrderByDescending(c => categories.Any(child => child.ParentId == c.Id)) // Alt kategorisi olanlar önce (true=1, false=0)
                                        .ThenBy(c => c.Name) 
                                        .ToList();
                                    
                                    
                                    <div class="mega-menu-grid">
                                        <!-- Ana Kategoriler -->
                                        <div class="mega-categories-column">
                                            <div class="mega-menu-header">
                                                <h3>@lang["MegaMenu.MainCategories"]</h3>
                                                <p>@lang["MegaMenu.DiscoverAllCategories"]</p>
                                            </div>
                                            
                                            @foreach (var parent in mainCategories)
                                            {
                                                <div class="mega-category-item" data-category-id="@parent.Id" onmouseenter="showSubcategories(@parent.Id)">
                                                    <div class="mega-category-main">
                                                        <div class="mega-category-icon">
                                                            <i class="@GetCategoryIcon(parent.Name!)"></i>
                                                        </div>
                                                        <div class="mega-category-info">
                                                    <a href="product-search?catid=@parent.Id&catname=@FriendlyUrlHelper.GetFriendlyTitle(parent.Name!)" class="mega-category-title" onclick="hideMegaMenu()">
                                                                @CultureInfo.CurrentCulture.TextInfo.ToTitleCase(parent.Name!)
                                                            </a>
                                                            <span class="mega-category-count">@categories.Count(c => c.ParentId == parent.Id) alt kategori</span>
                                                        </div>
                                                        <div class="mega-category-arrow">
                                                            <i class="fa-solid fa-chevron-right"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        <!-- Alt Kategoriler Paneli -->
                                        <div class="mega-subcategories-panel">
                                            @foreach (var parent in mainCategories)
                                            {
                                                <div class="mega-subcategories-content" id="mega-subcat-@parent.Id">
                                                    <div class="mega-subcategory-header">
                                                        <div class="mega-subcategory-icon">
                                                            <i class="@GetCategoryIcon(parent.Name!)"></i>
                                                        </div>
                                                        <div class="mega-subcategory-info">
                                                            <h4>@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(parent.Name!)</h4>
                                                            <p>@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(parent.Name!) kategorisindeki tüm ürünler</p>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="mega-subcategory-grid">
                                                        @{
                                                            var subCategories = categories.Where(c => c.ParentId == parent.Id).Take(12).ToList();
                                                        }
                                                        <!-- DEBUG: Sub-categories count: @subCategories.Count for parent @parent.Name (ID: @parent.Id) -->
                                @if (subCategories.Any())
                                                        {
                                                            @foreach (var child in subCategories)
                                                            {
                                        <a href="product-search?catid=@child.Id&catname=@FriendlyUrlHelper.GetFriendlyTitle(child.Name!)" class="mega-subcategory-item" onclick="hideMegaMenu()">
                                                                    <div class="mega-subcategory-icon">
                                                                        <i class="fa-solid fa-tag"></i>
                                                                    </div>
                                                                    <span class="mega-subcategory-name">@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(child.Name!)</span>
                                                                </a>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <div class="mega-subcategory-item">
                                                                <span>@lang["MegaMenu.NoSubCategories"]</span>
                                                            </div>
                                                        }
                                                    </div>
                                                    
                                                    <div class="mega-subcategory-footer">
                                                        <a href="product-search?catid=@parent.Id&catname=@FriendlyUrlHelper.GetFriendlyTitle(parent.Name!)" class="mega-view-all-btn">
                                                            <i class="fa-solid fa-arrow-right"></i>
                                                            @lang["MegaMenu.ViewAll"] (@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(parent.Name!))
                                                        </a>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                }
                                else
                                {
                                    <div class="mega-menu-empty">
                                        <div class="mega-empty-icon">
                                            <i class="fa-solid fa-folder-open"></i>
                                        </div>
                                        <h3>@lang["MegaMenu.NoCategoriesTitle"]</h3>
                                        <p>@lang["MegaMenu.NoCategoriesDesc"]</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Ultra Modern Mobile Category Modal -->
                    @if (isCategoryMenuOpen)
                    {
                        <div class="mobile-category-modal show" @onclick="CloseCategoryMenu">
                        <div class="mobile-category-panel" @onclick:stopPropagation="true">
                            <!-- Header with Modern Effects -->
                            <div class="mobile-category-header">
                                <div class="header-content">
                                    <div class="header-icon">
                                        <i class="fa-solid fa-layer-group"></i>
                                    </div>
                                    <h3>Kategoriler</h3>
                                </div>
                                <button class="mobile-category-close" @onclick="CloseCategoryMenu">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>

                            <!-- Category List -->
                            <div class="mobile-category-content">
                                @if (categories != null && categories.Any())
                                {
                                    @foreach (var parent in categories.Where(c => c.ParentId == null && c.IsMainPage))
                                    {
                                        <div class="mobile-category-item @(openCategories.Contains(parent.Id!) ? "expanded" : null)">
                                            <!-- Parent Category -->
                                            <div class="mobile-category-parent">
                                                <a href="product-search?catid=@parent.Id&catname=@FriendlyUrlHelper.GetFriendlyTitle(parent.Name!)" class="mobile-category-main-link" @onclick="CloseCategoryMenu" @onclick:stopPropagation="true">
                                                    <div class="mobile-category-info">
                                                        <i class="mobile-category-icon fa-solid fa-folder"></i>
                                                        <span class="mobile-category-name">@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(parent.Name!)</span>
                                                    </div>
                                                </a>
                                                @if (categories.Any(c => c.ParentId == parent.Id))
                                                {
                                                    <button class="mobile-category-expand-btn" @onclick="() => ToggleCategory(parent.Id!)" @onclick:stopPropagation="true">
                                                        <i class="mobile-category-arrow fa-solid fa-chevron-right"></i>
                                                    </button>
                                                }
                                            </div>

                                            <!-- Child Categories -->
                                            @if (categories.Any(c => c.ParentId == parent.Id))
                                            {
                                                <div class="mobile-category-children">
                                                    @foreach (var child in categories.Where(c => c.ParentId == parent.Id))
                                                    {
                                                        <a href="product-search?catid=@child.Id&catname=@FriendlyUrlHelper.GetFriendlyTitle(child.Name!)" class="mobile-category-child" @onclick="CloseCategoryMenu">
                                                            <i class="mobile-category-child-icon fa-solid fa-tag"></i>
                                                            <span>@CultureInfo.CurrentCulture.TextInfo.ToTitleCase(child.Name!)</span>
                                                        </a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="mobile-category-empty">
                                        <i class="fa-solid fa-folder-open"></i>
                                        <p>Henüz kategori bulunmuyor</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    }

                <div class="header-nav-middle">
                    <div class="main-nav navbar navbar-expand-xl navbar-light navbar-sticky">
                        <div class="offcanvas offcanvas-collapse order-xl-2" id="primaryMenu">
                            <div class="offcanvas-header navbar-shadow">
                                <button class="btn-close lead" type="button"
                                        data-bs-dismiss="offcanvas">
                                </button>
                            </div>
                            <div class="offcanvas-body">
                                <ul class="navbar-nav">
                                    <li class="nav-item d-md-none">
                                        <div class="mobile-login-section">
                                            @if (userInitials!=null)
                                            {
                                                <div class="user-card mb-3">
                                                    <div class="d-flex align-items-center">
                                                        <div class="user-avatar flex-shrink-0">
                                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; font-weight: 700;">
                                                         
                                                            </div>
                                                        </div>
                                                        <div class="ms-3 overflow-hidden">
                                                            <div class="fw-semibold text-truncate">@userInitials</div>
                                                            <small class="text-muted text-truncate d-block" style="max-width: 210px;">@_authenticationState.User.GetUserId()</small>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row g-2 mb-3">
                                                    <div class="col-6">
                                                        <a class="btn btn-soft w-100" href="/user-dashboard" data-bs-dismiss="offcanvas">
                                                            <i class="fa-solid fa-user me-2"></i>@lang["MyAccount"]
                                                        </a>
                                                    </div>
                                                    <div class="col-6">
                                                        <a class="btn btn-danger-subtle w-100" href="javascript:void(0);" @onclick="Logout" data-bs-dismiss="offcanvas">
                                                            <i class="fa-solid fa-sign-out-alt me-2"></i>@lang["Logout"]
                                                        </a>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="user-card mb-3">
                                                    <div class="d-flex align-items-center">
                                                        <div class="user-avatar flex-shrink-0">
                                                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                                                <i class="fa-solid fa-user text-muted"></i>
                                                            </div>
                                                        </div>
                                                        <div class="ms-3">
                                                            <div class="fw-semibold">@lang["Hello"]</div>
                                                            <small class="text-muted">@lang["Login"] / @lang["Register"]</small>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row g-2 mb-3">
                                                    <div class="col-6">
                                                        <a class="btn btn-soft w-100" href="/login" data-bs-dismiss="offcanvas">
                                                            <i class="fa-solid fa-sign-in-alt me-2"></i>@lang["Login"]
                                                        </a>
                                                    </div>
                                                    <div class="col-6">
                                                        <a class="btn btn-primary w-100" href="/register" data-bs-dismiss="offcanvas">
                                                            <i class="fa-solid fa-user-plus me-2"></i>@lang["Register"]
                                                        </a>
                                                    </div>
                                                    <div class="col-12 mt-1">
                                                        <a class="btn btn-link w-100 p-2" href="/forgot-password" data-bs-dismiss="offcanvas">
                                                            <i class="fa-solid fa-key me-2"></i>@lang["ForgotPassword"]
                                                        </a>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <hr class="my-3">
                                        <style>
                      
                                        </style>
                                    </li>
                                </ul>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="header-nav-right">
                    <a href="/discounts" class="btn deal-button">
                        <i data-feather="zap"></i>
                        <span>@lang["Nav.Discounts"]</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
</div>

</header>
