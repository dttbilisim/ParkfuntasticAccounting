@page "/education-category"
@using ecommerce.Admin.Domain.Dtos.EducationDto;
@using ecommerce.Core.Utils;

@layout MainLayout
@inject IStringLocalizer<Culture_TR> Loc
<PageTitle>Kategori Tanımları</PageTitle>
<RadzenCard class="mb-3" style="display: flex; align-items: center;">

    <div style="width: 100%; overflow: hidden;">
        <div style="width: 600px; float: left;">
            <RadzenText Text="Kategori Tanımları" TextStyle="TextStyle.H5" style="color:#598087" class="mt-2" />
        </div>
        <div style="float:right">
            <RadzenButton Icon="add_circle_outline" Text="Yeni Kategori Ekle" Click="@AddButtonClick" Variant="Variant.Flat" class="mt-2" />
        </div>
    </div>
</RadzenCard>

<div class="row">
    <div class="col-md-12">
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" AllowSorting="true" PagerAlwaysVisible=true PageSize=25 AllowFilterDateInput=true TItem="EducationCategoryListDto" RowSelect="@EditRow" LoadData="@LoadData" Count="@count" Data="@categories" CellRender="@RowRender" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        EqualsText="@Loc.GetString("EqualsText")"
                        NotEqualsText="@Loc.GetString("NotEqualsText")"
                        LessThanText="@Loc.GetString("LessThanText")"
                        LessThanOrEqualsText="@Loc.GetString("LessThanOrEqualsText")"
                        GreaterThanText="@Loc.GetString("GreaterThanText")"
                        GreaterThanOrEqualsText="@Loc.GetString("GreaterThanOrEqualsText")"
                        IsNullText="@Loc.GetString("IsNullText")"
                        IsNotNullText="@Loc.GetString("IsNotNullText")"
                        ApplyFilterText="@Loc.GetString("ApplyFilterText")"
                        ClearFilterText="@Loc.GetString("ClearFilterText")">


            <Columns>
                <RadzenDataGridColumn TItem="EducationCategoryListDto" Property="Id" Title="Id" Width="50px">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationCategoryListDto" Property="Name" Title="Kategori Adı">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationCategoryListDto" Property="ParentName" Title="Üst Kategori">
                    <Template Context="category">
                        <p style="white-space:pre-wrap">@category.Parent?.Name</p>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationCategoryListDto" Property="CreatedDate" FormatString="{0:dd/MM/yyyy HH:mm}" Width="100px" Title="Oluşturulma Tarihi">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationCategoryListDto" Property="StatusStr" Title="Durum" Width="70px" Sortable="false" Filterable="false">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationCategoryListDto" Title="Aksiyon" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="educationcategory">
                        @if (educationcategory.Status != EntityStatus.Deleted.GetHashCode())
                        {
                            <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall" Shade="Shade.Dark" Variant="Variant.Flat" Click=@(args => GridDeleteButtonClick(args, educationcategory)) @onclick:stopPropagation="true" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

