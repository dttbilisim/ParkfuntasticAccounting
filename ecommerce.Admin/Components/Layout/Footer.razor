<div class="b2b-dashboard-footer b2b-animate" style="z-index: 100 !important;">
    <div class="footer-content-wrapper d-flex align-items-center h-100">
        <!-- Left: User Info -->
        <div class="footer-left-section d-flex align-items-center gap-3 px-4">
            @if (_hasDefaultPlasiyer)
            {
                <div class="bg-white text-secondary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-user-tie" style="font-size: 1.2rem;"></i>
                </div>
                <div class="d-flex flex-column justify-content-center">
                    <div class="fw-bold text-white" style="font-size: 13px; line-height: 1.2;">@_plasiyerName</div>
                    <div class="text-white" style="font-size: 11px; line-height: 1.2;">@_plasiyerPhone</div>
                    <div class="text-white" style="font-size: 11px; line-height: 1.2;">@_plasiyerEmail</div>
                </div>
            }
            else
            {
                <div class="bg-white text-success rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <div>
                    <div class="fw-bold text-white" style="font-size: 13px;">@(Security?.User?.FullName ?? "Aktif Bayi")</div>
                    <div class="text-white" style="font-size: 11px;">
                        @(Security.SelectedCustomerId.HasValue 
                            ? $"Cari: {Security.SelectedCustomerName}" 
                            : $"Cari Kodu: {Security?.User?.UserName ?? "B2B-001"}")
                    </div>
                </div>
            }
        </div>
        
        <!-- Center: Campaign Banner -->
        <div class="footer-center-section flex-grow-1" style="overflow: hidden; height: 100%;">
            <CampaignBanner />
        </div>
        
        <!-- Right: Cart and Order Info -->
        <div class="footer-right-section d-flex align-items-center gap-4 px-4">
            <!-- Sepetteki Ürünler -->
            <div class="d-flex flex-column justify-content-center footer-clickable" @onclick="NavigateToCart" style="cursor: pointer;">
                <span class="text-white" style="font-size: 11px;">Sepetteki Ürünler</span>
                <span class="fw-bold text-white" style="font-size: 13px;">@GetCartItemCount() Adet</span>
            </div>
            <div class="vr bg-white opacity-25 my-2"></div>
            <!-- Bekleyen Sipariş -->
            <div class="d-flex flex-column justify-content-center footer-clickable" @onclick="NavigateToPendingOrders" style="cursor: pointer;">
                <span class="text-white" style="font-size: 11px;">Bekleyen Sipariş</span>
                <span class="fw-bold text-white" style="font-size: 13px;">@GetPendingOrderCount() Adet</span>
            </div>
            <div class="vr bg-white opacity-25 my-2"></div>
            <!-- Toplam Tutar -->
            <div class="d-flex flex-column justify-content-center">
                <span class="text-white" style="font-size: 11px;">Sepet Toplam Tutar</span>
                <span class="fw-bold text-white" style="font-size: 13px;">@GetCartTotal()</span>
            </div>
        </div>
    </div>
</div>
