            @*                     </RadzenColumn> *@
            @*                     <RadzenColumn Size="12"> *@
            @*                         <RadzenImage Path="@FileHelper.GetFileUrl(Discount.ImagePath)" Visible="@(Discount.ImagePath != null)" class="img-fluid"/> *@
