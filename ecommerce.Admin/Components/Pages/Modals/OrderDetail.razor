<RadzenTabsItem Text="Fatura Bilgileri">
    <RadzenFieldset Text="Fatura Bilgileri">
        @{
            // e-Fatura kesilmişse formu pasif yap
            var hasEInvoice = order?.LinkedInvoices != null && order.LinkedInvoices.Any(li => !string.IsNullOrEmpty(li.Ettn));
        }

        @* Bağlı Faturalar — Sadece ETTN ve PDF İndirme *@
        @if (order?.LinkedInvoices != null && order.LinkedInvoices.Any())
        {
            <div class="mb-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa-solid fa-file-invoice" style="color: #16a34a; font-size: 1rem;"></i>
                    <span style="font-weight: 600; color: #15803d; font-size: 0.85rem;">Kesilen Faturalar</span>
                </div>
                <table class="table table-sm table-bordered mb-0" style="font-size: 0.8rem;">
                    <thead style="background: #f1f5f9;">
                        <tr>
                            <th style="width: 50px;" class="text-center">PDF</th>
                            <th style="width: 120px;">Fatura No</th>
                            <th>ETTN</th>
                            <th style="width: 80px;" class="text-center">Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in order.LinkedInvoices)
                        {
                            var isEInvoiced = !string.IsNullOrEmpty(inv.Ettn);
                            var isCancelled = inv.EInvoiceStatus?.ToUpperInvariant() == "IPTAL";
                            var rowBg = isCancelled ? "#fff5f5" : (isEInvoiced ? "#f0fdf4" : "transparent");
                            <tr style="background: @rowBg;">
                                <td class="text-center align-middle">
                                    @if (isEInvoiced && !isCancelled)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-success border-0 p-0"
                                                @onclick="@(() => DownloadLinkedEInvoicePdf(inv))"
                                                disabled="@(_isDownloadingEInvoice)"
                                                title="e-Fatura PDF İndir">
                                            @if (_isDownloadingEInvoice)
                                            {
                                                <i class="fas fa-spinner fa-spin" style="font-size: 1rem;"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-file-pdf" style="font-size: 1.1rem; color: #16a34a;"></i>
                                            }
                                        </button>
                                    }
                                </td>
                                <td class="align-middle" style="font-weight: 500;">@inv.InvoiceNo</td>
                                <td class="align-middle">
                                    @if (isEInvoiced)
                                    {
                                        <code style="background: #e5e7eb; padding: 1px 6px; border-radius: 3px; font-size: 0.7rem; letter-spacing: 0.2px; user-select: all; word-break: break-all;">@inv.Ettn</code>
                                    }
                                    else
                                    {
                                        <span style="color: #94a3b8; font-size: 0.75rem;">—</span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    @if (!string.IsNullOrEmpty(inv.EInvoiceStatus))
                                    {
                                        <span class="badge" style="background: @(isCancelled ? "#dc3545" : "#059669"); color: #fff; font-size: 0.65rem;">@inv.EInvoiceStatus</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (hasEInvoice)
            {
                <div class="alert d-flex align-items-center gap-2 py-2 px-3 mb-3" role="alert"
                     style="background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%); border: 1px solid #86efac; border-radius: 8px;">
                    <i class="fa-solid fa-circle-info" style="color: #16a34a;"></i>
                    <span style="font-weight: 500; color: #15803d; font-size: 0.8rem;">
                        e-Fatura kesildiği için manuel fatura yükleme devre dışıdır.
                    </span>
                </div>
            }
        }

        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="Fatura Tipi" Component="InvoiceType" class="w-100"/>
            </div>
            <div class="col-md-9">
                <RadzenDropDown TValue="UserType" class="rz-full-width" Data="InvoiceType" Name="UserType" Change="(args => ChangeInvoiceType(args))" Placeholder="Seçiniz" 
                                AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Disabled="@hasEInvoice" />
            </div>
        </div>

        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="Fatura Tarihi" Component="LblInvoiceDate" class="w-100"/>
            </div>
            <div class="col-md-9">
                <RadzenDatePicker class="rz-full-width" @bind-Value="@InvoiceUpsertDto.InvoiceDate" Name="InvoiceDate" DateFormat="dd/MM/yyyy" Disabled="@hasEInvoice" />
            </div>
          
        </div>
        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="Fatura Yükleyiniz" Component="InvoiceType" class="w-100"/>
            </div>
            <div class="col-md-9">
                <InputFile OnChange="@(e => LoadFiles(e, "OrderInvoice"))" class="mb-2" accept="application/pdf" disabled="@hasEInvoice" />
            </div>
            <div class="col d-flex justify-content-end mt-btn-custom">
                <RadzenButton  Click="SaveInvoice" ButtonStyle="ButtonStyle.Primary" Icon="save" Text="Fatura Ekle" class="mr-btn-custom" Variant="Variant.Flat" Disabled="@hasEInvoice" />
            </div>
        </div>
         <RadzenDataGrid @ref="radzenDataGridInvoice"
                            AllowFiltering="false"
                            AllowColumnResize="true"
                            AllowAlternatingRows="false"
                            FilterMode="FilterMode.Advanced"
                            AllowSorting="false"
                            AllowPaging="true"
                            PagerHorizontalAlign="HorizontalAlign.Left"
                            ShowPagingSummary="false"
                       
                            Data="@_orderInvoiceList"
                            TItem="OrderInvoiceListDto"
                            ColumnWidth="300px"
                            LogicalFilterOperator="LogicalFilterOperator.Or"
                            PageSize="10"
                          >
                <Columns>
                    <RadzenDataGridColumn TItem="OrderInvoiceListDto" Title="Id" Property="Id" Width="50px"/>
                    <RadzenDataGridColumn TItem="OrderInvoiceListDto" Title="Fatura Tarihi" Property="InvoiceDate" Width="50px"/>
                    <RadzenDataGridColumn TItem="OrderInvoiceListDto" Title="Sipariş No" Property="OrderId" Width="70px"/>
                                    <RadzenDataGridColumn TItem="OrderInvoiceListDto" Title="Fatura Tipi" Property="InvoiceType" Width="70px"/>
                    <RadzenDataGridColumn TItem="OrderInvoiceListDto" Title="Fatura Path" Property="InvoicePath"/>
                       <RadzenDataGridColumn TItem="OrderInvoiceListDto" Width="100px" Title="Evrak Linki">
                                             <Template Context="OrderInvoiceListDto">
                                                   <a href="@(BaseUrl + "/" +OrderInvoiceListDto.FileName )" target="_blank">Faturayı Aç</a>
                                               </Template>
                                         </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderInvoiceListDto" Title="Aksiyon" Width="40px" TextAlign="TextAlign.Center">
                        <Template Context="OrderInvoiceListDto">
                           
                                <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall"
                                              Shade="Shade.Dark" Variant="Variant.Flat"
                                              Click=@(args => DeleteInvoice(OrderInvoiceListDto.Id)) @onclick:stopPropagation="true"/>
                            
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

    </RadzenFieldset>
</RadzenTabsItem>

</Tabs>

</RadzenTabs>

</div>

@code {
    protected async Task ShowAddressDetail(SellerAddressListDto address)
    {
        await DialogService.OpenAsync($"Şube Detayı: {address.Title}", ds => 
            @<div class="p-3">
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Şube Adı:</div>
                    <div class="col-8">@address.Title</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Şehir/İlçe:</div>
                    <div class="col-8">@address.CityName / @address.TownName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Adres:</div>
                    <div class="col-8">@address.Address</div>
                </div>
                @if (!string.IsNullOrEmpty(address.PhoneNumber))
                {
                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Telefon:</div>
                        <div class="col-8">@address.PhoneNumber</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(address.Email))
                {
                    <div class="row mb-2">
                        <div class="col-4 fw-bold">E-posta:</div>
                        <div class="col-8">@address.Email</div>
                    </div>
                }
                <div class="d-flex justify-content-end mt-4">
                    <RadzenButton Text="Kapat" Click="() => ds.Close()" ButtonStyle="ButtonStyle.Light" class="rounded-pill" />
                </div>
            </div>, new DialogOptions { Width = "500px", Height = "auto" });
    }
}