@page "/product-search"
@using ecommerce.Domain.Shared.Dtos.Product
@using ecommerce.Admin.Components.Layout
@using ecommerce.Core.Helpers
@using Radzen
@using Radzen.Blazor
@layout MainLayout
@implements IDisposable

<style>
    /* Custom Scrollbar Styles */
    .b2b-scrollbar::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    
    .b2b-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1; 
        border-radius: 4px;
    }
    
    .b2b-scrollbar::-webkit-scrollbar-thumb {
        background: #ced4da; 
        border-radius: 4px;
    }
    
    .b2b-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #adb5bd; 
    }

</style>

<div class="product-search-root b2b-animate @(isLoading ? "is-loading" : "")" @onclick="CloseRecentSearchesOnOutsideClick">
    <!-- CORPORATE HEADER -->
    <!-- COMPACT B2B TOOLBAR -->
    <div class="b2b-header-toolbar">
        <!-- Search Group -->
        <form @onsubmit:preventDefault="true" @onsubmit="OnSearchSubmit" class="b2b-search-group position-relative d-flex align-items-center w-100">
            <i class="fa-solid fa-magnifying-glass b2b-search-icon"></i>
            <input value="@searchText" 
                   @oninput="@(e => { searchText = e.Value?.ToString() ?? ""; StateHasChanged(); })" 
                   @onfocus="OnSearchInputFocus"
                   @onblur="OnSearchInputBlur"
                   class="@GetSearchInputClass()" 
                   placeholder="Ürün adı ile arayın..." />
            @if (!string.IsNullOrEmpty(searchText))
            {
            <button type="button" class="btn btn-link text-muted p-0 position-absolute" style="right: 50px; z-index: 10;" @onclick="ClearSearch" title="Arama metnini temizle">
                <i class="fa-solid fa-circle-xmark"></i>
            </button>
            }
            <button type="button" class="btn btn-link text-muted p-0 position-absolute end-0 me-2" style="right: 10px; z-index: 10;" @onclick="ToggleRecentSearchesDropdown" @onclick:stopPropagation="true" title="Geçmiş Aramalar">
                <i class="fa-solid fa-clock-rotate-left @(isRecentSearchesDropdownOpen ? "text-success" : "")"></i>
            </button>
            
            <!-- Recent Searches Dropdown -->
            @if (isRecentSearchesDropdownOpen)
            {
                <div class="recent-searches-dropdown" @onclick:stopPropagation="true" @onmouseleave="CloseRecentSearchesDropdown">
                    <div class="recent-searches-header">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-clock-rotate-left text-success"></i>
                            <span class="fw-bold">Geçmiş Aramalar</span>
                            <span class="badge bg-light text-dark ms-2">@(recentSearches?.Count ?? 0)</span>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearRecentSearches" title="Tümünü Temizle">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </div>
                    <div class="recent-searches-table-container">
                        @if (recentSearches != null && recentSearches.Any())
                        {
                            <table class="recent-searches-table">
                                <thead>
                                    <tr>
                                        <th class="col-search">Arama</th>
                                        <th class="col-date">Tarih</th>
                                        <th class="col-count">Kayıt</th>
                                        <th class="col-action"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var searchItem in recentSearches)
                                    {
                                        <tr class="recent-search-row" 
                                            @onclick="@(() => SelectRecentSearch(searchItem.Term))"
                                            @onmouseover="@(() => hoveredSearch = searchItem.Term)"
                                            @onmouseout="@(() => hoveredSearch = null)">
                                            <td class="col-search">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fa-solid fa-search text-muted"></i>
                                                    <span class="@(hoveredSearch == searchItem.Term ? "text-success fw-semibold" : "fw-medium")">@searchItem.Term</span>
                                                </div>
                                            </td>
                                            <td class="col-date">
                                                <span class="text-muted small">
                                                    <i class="fa-solid fa-calendar-alt me-1"></i>
                                                    @searchItem.SearchDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                                </span>
                                            </td>
                                            <td class="col-count">
                                                @if (searchItem.RecordCount > 0)
                                                {
                                                    <span class="text-muted small fw-semibold">
                                                        <i class="fa-solid fa-list me-1"></i>@searchItem.RecordCount
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">-</span>
                                                }
                                            </td>
                                            <td class="col-action">
                                                <button type="button" class="btn btn-sm btn-link text-muted p-0" 
                                                        @onclick="@(() => RemoveRecentSearch(searchItem.Term))"
                                                        @onclick:stopPropagation="true"
                                                        title="Sil">
                                                    <i class="fa-solid fa-times"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center text-muted py-4">
                                <i class="fa-solid fa-clock-rotate-left fa-2x mb-2 opacity-50"></i>
                                <p class="mb-0 small">Henüz geçmiş arama yok</p>
                            </div>
                        }
                    </div>
                </div>

            }
            @* Hidden submit button to capture Enter key within the form - using robust hidden style *@
            <button type="submit" style="position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden;" tabindex="-1"></button>
        </form>

        <!-- Toolbar Actions -->
        <div class="b2b-toolbar-actions">
            <!-- Toggles as Icons/Buttons -->
            <!-- Toggles as Switches -->
             <div class="d-flex align-items-center gap-3">
                 <div class="form-check form-switch custom-switch mb-0" title="Sadece stokta olan ürünleri göster">
                    <input class="form-check-input" type="checkbox" id="stockSwitch" checked="@showOnlyInStock" @onchange="@(args => OnOnlyInStockToggle((bool)(args.Value ?? false)))" title="Sadece stokta olan ürünleri göster">
                    <label class="form-check-label fw-bold text-dark small user-select-none" for="stockSwitch" style="cursor:pointer" title="Sadece stokta olan ürünleri göster">Stokta</label>
                </div>

                <div class="form-check form-switch custom-switch mb-0" title="Sadece resimli ürünleri göster">
                    <input class="form-check-input" type="checkbox" id="imageSwitch" checked="@showOnlyWithImage" @onchange="@(args => OnOnlyWithImageToggle((bool)(args.Value ?? false)))" title="Sadece resimli ürünleri göster">
                    <label class="form-check-label fw-bold text-dark small user-select-none" for="imageSwitch" style="cursor:pointer" title="Sadece resimli ürünleri göster">Resimli</label>
                </div>
            </div>

            <div class="vr mx-1 text-muted opacity-25"></div>

            <button class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm" style="border-radius: 8px; background-color: var(--b2b-primary); border: none;" @onclick="OnSearchSubmit" disabled="@isLoading" title="Ürün ara">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                }
                else
                {
                    <i class="fa-solid fa-magnifying-glass"></i>
                }
                <span class="fw-semibold">@(isLoading ? "Aranıyor..." : "ARA")</span>
            </button>

            @* Araçtan Bul butonu şimdilik kaldırıldı
            <button class="btn-b2b-icon" @onclick="OpenVehicleMatchModal" title="Araç bilgilerine göre ürün ara (Marka, Model, Yıl)">
                <i class="fa-solid fa-car text-success"></i> <span class="d-none d-lg-inline">Araçtan Bul</span>
            </button>
            *@
        </div>
    </div>

    <!-- MAIN CONTENT -->
    @if (hasSearched || isLoading)
    {
        <div class="container-fluid px-3 pb-4 product-results-area">
            <div class="row g-3 transition-all">
            <!-- SIDEBAR: FILTERS -->
            @if(isFilterVisible)
            {
                <div class="col-lg-2 col-md-3 animate-slide-up">
                    <div class="filter-sidebar card shadow-sm border-0 h-100 rounded-3">
                         <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                             <h6 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-filter me-2 text-success"></i>Filtreler</h6>
                              <button class="btn btn-light btn-sm rounded-circle shadow-sm" @onclick="ToggleFilters" title="Filtreleri Gizle">
                                 <i class="fa-solid fa-chevron-left text-success"></i>
                             </button>
                         </div>
                         <div class="card-body p-2 scrollable-filters">
                            
                            <!-- 1. Price Range (Accordion) -->
                            <div class="filter-section mb-3 card border-0 shadow-none bg-light rounded-3 p-3">
                                <div class="d-flex align-items-center justify-content-between mb-0 pointer" @onclick="() => isPriceExpanded = !isPriceExpanded" style="cursor: pointer;">
                                    <label class="form-label small fw-bold text-dark text-uppercase mb-0 pointer"><i class="fa-solid fa-tag me-2 text-success"></i>Fiyat Aralığı</label>
                                    <i class="fa-solid @(isPriceExpanded ? "fa-chevron-up" : "fa-chevron-down") small text-muted"></i>
                                </div>
                                @if(isPriceExpanded) {
                                    <div class="mt-3 fade-in px-2">
                                        <RadzenSlider TValue="IEnumerable<double>" 
                                                      Value=@priceRange 
                                                      Range="true" 
                                                      Min="@(0m)" 
                                                      Max="@((decimal)priceMaxLimit)" 
                                                      Step="100"
                                                      Change="@(args => OnPriceChange(args))" 
                                                      Class="w-100 mb-3" />
                                        
                                        <div class="d-flex align-items-center justify-content-between text-muted small">
                                            <span>@CurrencyHelper.FormatPrice((decimal)(minPrice ?? 0))</span>
                                            <span>@CurrencyHelper.FormatPrice((decimal)(maxPrice ?? priceMaxLimit))</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            @* Parça Grubu filtresi şimdilik kaldırıldı *@

                            <!-- 2. Categories (Accordion) -->
                            <div class="filter-section mb-3 card border-0 shadow-none bg-light rounded-3 p-3">
                                <div class="d-flex align-items-center justify-content-between mb-0 pointer" @onclick="() => isCategoriesExpanded = !isCategoriesExpanded" style="cursor: pointer;">
                                    <label class="form-label small fw-bold text-dark text-uppercase mb-0 pointer"><i class="fa-solid fa-layer-group me-2 text-success"></i>Kategoriler</label>
                                    <i class="fa-solid @(isCategoriesExpanded ? "fa-chevron-up" : "fa-chevron-down") small text-muted"></i>
                                </div>
                                @if(isCategoriesExpanded) {
                                    <div class="mt-3 fade-in">
                                         <RadzenDropDown Data="@categories" TextProperty="Name" ValueProperty="Id"
                                                           @bind-Value="selectedCategoryIds"
                                                           Multiple="true"
                                                           AllowFiltering="true"
                                                           FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                           Placeholder="Seçiniz"
                                                           SelectedItemsText="seçildi"
                                                           Change="@(args => OnSearchFiltersChanged())"
                                                           Class="w-100 search-dropdown shadow-sm border-0" />
                                    </div>
                                }
                            </div>

                            <!-- 4. Brands (Accordion) -->
                            <div class="filter-section mb-3 card border-0 shadow-none bg-light rounded-3 p-3">
                                <div class="d-flex align-items-center justify-content-between mb-0 pointer" @onclick="() => isBrandsExpanded = !isBrandsExpanded" style="cursor: pointer;">
                                    <label class="form-label small fw-bold text-dark text-uppercase mb-0 pointer"><i class="fa-solid fa-copyright me-2 text-success"></i>Markalar</label>
                                    <i class="fa-solid @(isBrandsExpanded ? "fa-chevron-up" : "fa-chevron-down") small text-muted"></i>
                                </div>
                                @if(isBrandsExpanded) {
                                    <div class="mt-3 fade-in">
                                         <RadzenDropDown Data="@brands" TextProperty="Name" ValueProperty="Id"
                                                           @bind-Value="selectedBrandIds"
                                                           Multiple="true"
                                                           AllowFiltering="true"
                                                           FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                           Placeholder="Seçiniz"
                                                           SelectedItemsText="seçildi"
                                                           Change="@(args => OnSearchFiltersChanged())"
                                                           Class="w-100 search-dropdown shadow-sm border-0" />
                                    </div>
                                }
                            </div>

                            @* 5. Vehicle Filters (Accordion) - şimdilik devre dışı
                            <div class="filter-section mb-3 card border-0 shadow-none bg-light rounded-3 p-3">
                                <div class="d-flex align-items-center justify-content-between mb-0 pointer" @onclick="() => isVehiclesExpanded = !isVehiclesExpanded" style="cursor: pointer;">
                                    <label class="form-label small fw-bold text-dark text-uppercase mb-0 pointer"><i class="fa-solid fa-car me-2 text-success"></i>Araç Filtreleri</label>
                                    <i class="fa-solid @(isVehiclesExpanded ? "fa-chevron-up" : "fa-chevron-down") small text-muted"></i>
                                </div>
                                @if(isVehiclesExpanded) {
                                    <div class="mt-3 fade-in">
                                        <div class="mb-3">
                                            <label class="form-label small text-muted">Araç Markası</label>
                                            <RadzenDropDown Data="@manufacturerNames" 
                                                               @bind-Value="@selectedManufacturerName"
                                                               Placeholder="Marka Seç"
                                                               Change="@(args => OnManufacturerChanged((string)args))"
                                                               Class="w-100 search-dropdown" 
                                                               AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label small text-muted">Araç Modeli</label>
                                            <RadzenDropDown Data="@baseModelNames" 
                                                               @bind-Value="@selectedBaseModelName"
                                                               Placeholder="Model Seç"
                                                               Change="@(args => OnModelChanged((string)args))"
                                                               Disabled="@(string.IsNullOrEmpty(selectedManufacturerName))"
                                                               Class="w-100 search-dropdown" 
                                                               AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
                                        </div>
                                    </div>
                                }
                            </div>
                            *@

                         </div>
                         <div class="card-footer bg-white border-top p-3">
                             <button class="btn btn-outline-danger w-100 btn-sm rounded-pill" @onclick="ClearAllFilters">
                                 <i class="fa-solid fa-trash-can me-2"></i>Tümünü Temizle
                             </button>
                         </div>
                    </div>
                </div>
            }

            <!-- MAIN AREA -->
            <div class="@(isFilterVisible ? "col-lg-10 col-md-9" : "col-12") transition-all">
                <div class="results-container">
                    <!-- Tools Bar -->
                    <div class="d-flex justify-content-between align-items-center mb-2 p-3 bg-white rounded-4 shadow-sm">
                         <div class="d-flex align-items-center gap-3">
                            @if(!isFilterVisible)
                            {
                                <button class="btn btn-dark btn-sm rounded-pill shadow-sm" type="button" @onclick="ToggleFilters" style="white-space:nowrap">
                                     <i class="fas fa-filter me-2"></i>Filtreleri Göster
                                </button>
                            }
                            <div class="filter-summary animate__animated animate__fadeIn d-flex align-items-center gap-3">
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <span class="badge bg-success rounded-pill px-3 py-2">
                                        <i class="fas fa-list me-2"></i>@searchResult.DataCount Bulunan Ürün
                                    </span>
                                    
                                    @if (searchResult.TotalRawCount > searchResult.DataCount)
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-2" title="Muadiller Dahil Toplam Sayı">
                                            <i class="fas fa-layer-group me-2"></i>@searchResult.TotalRawCount Bulunan Muadil
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="form-check form-switch custom-switch mb-0" title="Ürünleri satıcı/depo bazında grupla">
                                <input class="form-check-input" type="checkbox" id="groupBySellerSwitch" checked="@isGroupedBySeller" @onchange="@(args => ToggleGroupBySeller())" title="Ürünleri satıcı/depo bazında grupla">
                                <label class="form-check-label fw-bold text-dark small user-select-none" for="groupBySellerSwitch" style="cursor:pointer" title="Ürünleri satıcı/depo bazında grupla">Depo Bazlı Grupla</label>
                            </div>

                            <div class="form-check form-switch custom-switch mb-0" title="Muadilleri Listeye Dahil Et">
                                <input class="form-check-input" type="checkbox" id="includeEquivalentsSwitch" checked="@isIncludeEquivalents" @onchange="@(args => ToggleIncludeEquivalents())" title="Muadilleri Listeye Dahil Et">
                                <label class="form-check-label fw-bold small text-dark" for="includeEquivalentsSwitch">Muadilleri Listeye Dahil Et</label>
                            </div>
                            @if (hasSearched && searchResult.DataCount > 0)
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary ms-2" style="font-size: 11px; padding: 4px 8px;" @onclick="ClearAllFilters" title="Filtreleri Temizle">
                                    <i class="fa-solid fa-filter-circle-xmark me-1"></i> Filtreyi Temizle
                                </button>
                            }
                         </div>
                         <div class="view-toggles d-flex bg-light p-1 rounded-pill border">
                             <button class="btn btn-sm rounded-pill px-3 @(isTableView ? "btn-white shadow-sm fw-bold" : "btn-transparent text-muted")" @onclick='() => isTableView = true' title="Liste görünümüne geç">
                                <i class="fa-solid fa-list me-1"></i> Liste
                            </button>
                            <button class="btn btn-sm rounded-pill px-3 @(!isTableView ? "btn-white shadow-sm fw-bold" : "btn-transparent text-muted")" @onclick='() => isTableView = false' title="Kart görünümüne geç">
                                <i class="fa-solid fa-grip-vertical me-1"></i> Kart
                            </button>
                         </div>
                    </div>
                    @if (isLoading && (searchResult == null || searchResult.DataCount == 0))
                    {
                        <div class="py-5 text-center">
                            <div class="spinner-border text-success" role="status">
                                <span class="visually-hidden">Yükleniyor...</span>
                            </div>
                            @* @if (isLoadingVin) { <p class="mt-3 text-muted fw-bold">Araçlar Yükleniyor...</p> } else *@
                            <p class="mt-3 text-muted fw-bold">Ürünler Hazırlanıyor...</p>
                        </div>
                    }
                    else if (!isLoading && (searchResult == null || searchResult.DataCount == 0 || searchResult.Data == null || !searchResult.Data.Any()))
                    {
                         @* Sonuç bulunamadı *@
                             <div class="py-5 text-center bg-white rounded-5 shadow-sm">
                                 <img src="/images/empty-search.svg" class="mb-4" style="height: 150px; opacity: 0.5;" />
                                 <h4 class="fw-bold text-dark">Sonuç Bulunamadı</h4>
                                 <p class="text-muted">Farklı bir arama yapmayı veya filtreleri temizlemeyi deneyin.</p>
                                 <button class="btn btn-success rounded-pill px-4" @onclick="ClearAllFilters">Filtreleri Sıfırla</button>
                             </div>
                    }
                    else
                    {
                        <div class="product-results-area position-relative" style="min-height: 400px;">
                            @if (isLoading)
                            {
                                <div class="loading-overlay d-flex flex-column align-items-center position-absolute w-100 h-100 rounded-5" 
                                     style="background: rgba(255,255,255,0.45); z-index: 1000; top: 0; left: 0; backdrop-filter: blur(3px); pointer-events: all;">
                                    <div class="sticky-top d-flex flex-column align-items-center justify-content-center" style="top: 300px; height: 100px;">
                                        <div class="spinner-border text-success mb-3 shadow-sm" role="status" style="width: 3.5rem; height: 3.5rem; border-width: 0.35em;">
                                            <span class="visually-hidden">Yükleniyor...</span>
                                        </div>
                                    </div>
                                </div>
                            }

                        @if (isTableView)
                        {
                            <div class="b2b-grid-container fade-in">
                                <AdminDataGrid @ref="searchGrid" Data="@searchResult.Data" 
                                                TItem="SellerProductViewModel" 
                                                IsLoading="@isLoading"
                                                Count="@searchResult.TotalRawCount"
                                                LoadData="@OnLoadData"
                                                AllowPaging="true" 
                                                PageSize="50"
                                                PagerHorizontalAlign="HorizontalAlign.Center"
                                                AllowSorting="true" 
                                                AllowFiltering="false"
                                                AllowGrouping="true"
                                                ShowGroupPanel="false"
                                                GridLines="DataGridGridLines.Horizontal"
                                                RowRender="@RowRender"
                                                Class="rz-datagrid product-search-grid">
                                    <GroupHeaderTemplate>
                                        <div class="d-flex align-items-center gap-3 py-2 px-3" style="background: linear-gradient(to right, #f0fdf4, #ffffff); border-left: 4px solid #198754;">
                                            <div class="d-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm" style="width: 32px; height: 32px;">
                                                <i class="fa-solid fa-store text-success"></i>
                                            </div>
                                            <span class="fw-bold text-dark text-uppercase fs-6">
                                                @context.Data.Key
                                            </span>
                                            <span class="badge bg-success text-white rounded-pill px-3">
                                                @context.Data.Count Ürün
                                            </span>
                                        </div>
                                    </GroupHeaderTemplate>
                                    <Columns>
                                        <RadzenDataGridColumn TItem="SellerProductViewModel" Title="GÖRSEL" Width="80px" Sortable="false" TextAlign="TextAlign.Center">
                                            <Template Context="p">
                                                <div class="d-flex justify-content-center position-relative" @onclick="() => OpenImageZoom(ResolveSearchImage(p))" style="cursor: zoom-in;">
                                                    <img src="@ResolveSearchImage(p)" class="rounded-2 border" style="width: 48px; height: 48px; object-fit: contain; background: #fff;" />
                                                </div>
                                            </Template>
                                        </RadzenDataGridColumn>

                                        <RadzenDataGridColumn TItem="SellerProductViewModel" Property="PartNumber" Title="ÜRÜN KODU" Width="140px">
                                             <Template Context="p">
                                                <div class="code-mono fw-bold">@p.PartNumber</div>
                                                @if (p.OemCode != null && p.OemCode.Any())
                                                {
                                                    <div class="small text-muted mt-1" style="font-size: 11px;">GC: @(string.Join(", ", p.OemCode.Take(2)))</div>
                                                }
                                            </Template>
                                        </RadzenDataGridColumn>

                                        <RadzenDataGridColumn TItem="SellerProductViewModel" Property="ProductName" Title="ÜRÜN ADI" MinWidth="200px">
                                            <Template Context="p">
                                                @{
                                                    var productNameId = $"product-name-{p.SellerItemId}";
                                                }
                                                <div class="d-flex flex-column align-items-start py-1">
                                                    @if (p.IsEquivalent)
                                                    {
                                                        <span class="badge shadow-sm" 
                                                              style="background-color: #198754; color: white; border-radius: 50px; font-size: 9px; padding: 2px 10px; margin-bottom: 3px; font-weight: 500; letter-spacing: 0.5px;">MUADİL</span>
                                                    }
                                                    <a href="javascript:void(0)" 
                                                       @ref="@(_elementReferences[productNameId])"
                                                       class="text-decoration-none fw-semibold text-dark hover-success text-truncate d-block mw-100" 
                                                       @onclick="() => OpenProductDetailModal(p)"
                                                       @onmouseenter="@(() => ShowTooltip(productNameId, p.ProductName ?? ""))"
                                                       @onmouseleave="@(() => HideTooltip())">
                                                        @p.ProductName
                                                    </a>
                                                </div>
                                            </Template>
                                        </RadzenDataGridColumn>

                                        <RadzenDataGridColumn TItem="SellerProductViewModel" Property="Brand.Name" Title="MARKA" Width="80px">
                                            <Template Context="p">
                                                <div class="fw-bold text-secondary text-truncate">@(p.Brand?.Name ?? "-")</div>
                                            </Template>
                                        </RadzenDataGridColumn>

                                        <RadzenDataGridColumn TItem="SellerProductViewModel" Title="MUADİL" Width="120px" Sortable="false" TextAlign="TextAlign.Center">
                                             <Template Context="p">
                                                  @if (!isIncludeEquivalents && p.SimilarProductCount > 0)
                                                  {
                                                      <button class="btn btn-xs btn-success d-flex align-items-center gap-1 mx-auto" 
                                                              @onclick="() => OpenSimilarProductsModal(p)" 
                                                              style="font-size: 10px; padding: 2px 8px; border-radius: 4px; white-space: nowrap;">
                                                          <i class="fa-solid fa-layer-group"></i> Muadil Ürünler
                                                      </button>
                                                  }
                                                  else { <span class="text-muted opacity-25">-</span> }
                                             </Template>
                                         </RadzenDataGridColumn>

                                         <RadzenDataGridColumn TItem="SellerProductViewModel" Property="Stock" Title="STOK" Width="80px" TextAlign="TextAlign.Center">
                                            <Template Context="p">
                                                @if (IsPlasiyer())
                                                {
                                                    @* Plasiyer: Stok miktarını göster *@
                                                    @if (p.Stock > 0)
                                                    {
                                                        <span class="badge-stock in-stock">
                                                            <i class="fa-solid fa-check"></i> @p.Stock
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge-stock out-stock">0</span>
                                                    }
                                                }
                                                else
                                                {
                                                    @* CustomerB2B: Stokta/Tükendi göster *@
                                                    @if (p.Stock > 0)
                                                    {
                                                        <span class="badge-stock in-stock">Stokta</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge-stock out-stock">Tükendi</span>
                                                    }
                                                }
                                            </Template>
                                        </RadzenDataGridColumn>

                                        @if (ShowPurchaseHistoryColumn)
                                        {
                                         <RadzenDataGridColumn TItem="SellerProductViewModel" Title="GEÇMİŞ" Width="70px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                                            <Template Context="p">
                                                @if (purchasedProductIds.Contains(p.ProductId))
                                                {
                                                    <button type="button" class="btn btn-link text-success p-0" title="Geçmiş alışverişler"
                                                            @onclick="() => OpenPurchaseHistoryModal(p)"
                                                            @onclick:stopPropagation="true">
                                                        <i class="fa-solid fa-clock-rotate-left"></i>
                                                    </button>
                                                }
                                                else { <span class="text-muted opacity-25">-</span> }
                                            </Template>
                                         </RadzenDataGridColumn>
                                        }

                                        @if (isCartVisible)
                                        {
                                         <RadzenDataGridColumn TItem="SellerProductViewModel" Property="SellerItemId" Title="SEPET" Width="140px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                                            <Template Context="p">
                                                @{
                                                    var isInCart = existingCartItems.ContainsKey(p.SellerItemId);
                                                    bool isItemLoading = isCartLoading || IsProductLoading(p.SellerItemId);
                                                }
                                                @if (isCartLoading)
                                                {
                                                    <span class="spinner-border spinner-border-sm text-muted" role="status" title="Sepet yükleniyor..."></span>
                                                }
                                                else if (p.Stock > 0 && p.SalePrice > 0)
                                                {
                                                    @if (isInCart)
                                                    {
                                                        <!-- Quantity Controls - Only show when item is in cart -->
                                                        @if (isItemLoading)
                                                        {
                                                            <div class="d-flex justify-content-center align-items-center" style="min-height: 36px;">
                                                                <span class="spinner-border spinner-border-sm text-success" role="status" title="Güncelleniyor...">
                                                                    <span class="visually-hidden">Güncelleniyor...</span>
                                                                </span>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="quantity-controls d-flex justify-content-center">
                                                                <button class="qty-btn minus" 
                                                                        disabled="@isItemLoading"
                                                                        @onclick="@(() => UpdateQtyDifference(p.SellerItemId, -1))"
                                                                        @onclick:stopPropagation="true"
                                                                        title="Miktarı azalt">
                                                                    <i class="fa-solid fa-minus"></i>
                                                                </button>
                                                                
                                                                <input type="number" 
                                                                       value="@GetQuantity(p.SellerItemId)" 
                                                                       @onchange="@(e => OnQuantityChanged(p.SellerItemId, int.Parse(e.Value?.ToString() ?? "1")))"
                                                                       title="Sepetteki adet (Maksimum: @p.Stock)" 
                                                                       min="1"
                                                                       max="@p.Stock"
                                                                       oninput="this.value = !!this.value && Math.abs(this.value) >= 1 ? Math.abs(this.value) : 1"
                                                                       disabled="@isItemLoading"
                                                                       @onclick:stopPropagation="true" />
                                                                       
                                                                <button class="qty-btn plus" 
                                                                        disabled="@isItemLoading"
                                                                        @onclick="@(() => UpdateQtyDifference(p.SellerItemId, 1))"
                                                                        @onclick:stopPropagation="true"
                                                                        title="Miktarı artır">
                                                                    <i class="fa-solid fa-plus"></i>
                                                                </button>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <!-- Add to Cart Button - Only show when item is NOT in cart -->
                                                        <button class="btn btn-sm btn-success d-flex align-items-center justify-content-center" 
                                                                style="width: 36px; height: 36px; padding: 0;"
                                                                title="Sepete Ekle"
                                                                disabled="@isItemLoading"
                                                                @onclick="@(() => AddToCart(p.SellerItemId))"
                                                                @onclick:stopPropagation="true">
                                                            @if(isItemLoading) {
                                                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                                            } else {
                                                                <i class="fa-solid fa-cart-plus"></i>
                                                            }
                                                        </button>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">-</span>
                                                }
                                            </Template>
                                        </RadzenDataGridColumn>
                                        }

                                         <RadzenDataGridColumn TItem="SellerProductViewModel" Property="SalePrice" Title="FİYAT" Width="100px" TextAlign="TextAlign.Right">
                                            <Template Context="p">
                                                <div class="fw-bold text-dark">@p.SalePrice.ToString("N2") <span class="small text-muted">@p.Currency</span></div>
                                            </Template>
                                        </RadzenDataGridColumn>


                                        @* ARAÇ kolonu - şimdilik devre dışı
                                        <RadzenDataGridColumn TItem="SellerProductViewModel" Title="ARAÇ" Width="60px" Sortable="false" TextAlign="TextAlign.Center">
                                            <Template Context="p">
                                                @if (p.SubModelsJson != null && p.SubModelsJson.Any())
                                                {
                                                    <button class="btn btn-link text-success p-0" @onclick="() => OpenVehicleModal(p)" title="Bu ürünün uyumlu olduğu araçları görüntüle">
                                                        <i class="fa-solid fa-car"></i>
                                                    </button>
                                                }
                                                else { <span class="text-muted opacity-25">-</span> }
                                            </Template>
                                        </RadzenDataGridColumn>
                                        *@
                                    </Columns>
                                </AdminDataGrid>
                            </div>
                        }
                        else
                        {
                            <!-- CATALOG CARD VIEW -->
                            <div class="b2b-catalog-grid fade-in">
                                @foreach (var p in searchResult.Data)
                                {
                                    <div class="catalog-card @(p.IsEquivalent ? "equivalent-highlight" : "")" style="@(p.IsEquivalent ? "border: 2px solid #198754 !important;" : "")">
                                        <div class="catalog-img-wrapper" @onclick="() => OpenProductDetailModal(p)">
                                            <img src="@ResolveSearchImage(p)" />
                                        </div>
                                        <div class="catalog-info">
                                            <div class="d-flex align-items-center mb-1 gap-1">
                                                <div class="code-mono">@p.PartNumber</div>
                                                    @if (!isIncludeEquivalents && p.SimilarProductCount > 0)
                                                    {
                                                        <button class="btn btn-sm btn-success text-white shadow-sm d-flex align-items-center gap-2" 
                                                                style="font-size: 0.75rem; padding: 0.4rem 0.8rem; border-radius: 6px; transition: all 0.2s ease;"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="@(() => OpenSimilarProductsModal(p))">
                                                            <i class="fas fa-layer-group"></i>
                                                            <span>Muadil Ürünler</span>
                                                        </button>
                                                    }
                                                    @if (ShowPurchaseHistoryColumn && purchasedProductIds.Contains(p.ProductId))
                                                    {
                                                        <button type="button" class="btn btn-link text-success p-0 ms-1" title="Geçmiş alışverişler"
                                                                @onclick="() => OpenPurchaseHistoryModal(p)"
                                                                @onclick:stopPropagation="true">
                                                            <i class="fa-solid fa-clock-rotate-left"></i>
                                                        </button>
                                                    }
                                                </div>
                                                @{
                                                var cardProductNameId = $"card-product-name-{p.SellerItemId}";
                                            }
                                            <div class="d-flex flex-column align-items-start">
                                                @if (p.IsEquivalent)
                                                {
                                                    <span class="badge shadow-sm" 
                                                          style="background-color: #198754; color: white; border-radius: 50px; font-size: 9px; padding: 2px 10px; margin-bottom: 4px; font-weight: 500; letter-spacing: 0.5px;">MUADİL</span>
                                                }
                                                <h5 @ref="@(_elementReferences[cardProductNameId])"
                                                    @onclick="() => OpenProductDetailModal(p)" 
                                                    style="cursor: pointer;"
                                                    @onmouseenter="@(() => ShowTooltip(cardProductNameId, p.ProductName ?? ""))"
                                                    @onmouseleave="@(() => HideTooltip())">@p.ProductName</h5>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between mt-2">
                                                 <div class="small fw-bold text-secondary">@(p.Brand?.Name)</div>
                                                 @if (IsPlasiyer())
                                                 {
                                                     @* Plasiyer: Stok miktarını göster *@
                                                     @if(p.Stock > 0) { 
                                                         <span class="badge-stock in-stock"><i class="fa-solid fa-check"></i> @p.Stock</span> 
                                                     } else { 
                                                         <span class="badge-stock out-stock">0</span> 
                                                     }
                                                 }
                                                 else
                                                 {
                                                     @* CustomerB2B: Stokta/Tükendi göster *@
                                                     @if(p.Stock > 0) { 
                                                         <span class="badge-stock in-stock">Stokta</span> 
                                                     } else { 
                                                         <span class="badge-stock out-stock">Tükendi</span> 
                                                     }
                                                 }
                                            </div>
                                        </div>
                                        <div class="catalog-price-row">
                                            <div class="catalog-price">
                                                @p.SalePrice.ToString("N2") <span class="small text-muted">@p.Currency</span>
                                            </div>
                                            @{
                                                var isCardItemLoading = isCartLoading || IsProductLoading(p.SellerItemId);
                                                var cardCartQty = GetCartQuantity(p.SellerItemId);
                                            }
                                            
                                            @if (cardCartQty > 0)
                                            {
                                                <!-- Product is in cart - show quantity controls -->
                                                <div class="quantity-controls" style="min-width: 100px;">
                                                    <button class="qty-btn minus" 
                                                            disabled="@isCardItemLoading"
                                                            @onclick="() => UpdateCartQuantityDelta(p.SellerItemId, -1)"
                                                            @onclick:stopPropagation="true"
                                                            title="Miktarı azalt">
                                                        <i class="fa-solid fa-minus"></i>
                                                    </button>
                                                    
                                                    <input type="number" 
                                                            value="@cardCartQty" 
                                                            disabled="@isCardItemLoading"
                                                            @onchange="@((ChangeEventArgs e) => OnCardQuantityChange(p.SellerItemId, e))"
                                                            min="1"
                                                            title="Sepetteki adet"
                                                            @onclick:stopPropagation="true" />
                                                            
                                                    <button class="qty-btn plus" 
                                                            disabled="@isCardItemLoading"
                                                            @onclick="() => UpdateCartQuantityDelta(p.SellerItemId, 1)"
                                                            @onclick:stopPropagation="true"
                                                            title="Miktarı artır">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                </div>
                                            }
                                            else
                                            {
                                                <!-- Product not in cart - show add button -->
                                                <button class="btn-card-action" 
                                                        @onclick="() => AddToCart(p.SellerItemId)"
                                                        disabled="@isCardItemLoading"
                                                        title="Sepete ekle">
                                                    @if(isCardItemLoading) {
                                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                                    } else {
                                                        <i class="fa-solid fa-cart-plus"></i>
                                                    }
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        </div>
                    }
                    </div> @* end results-container *@
                </div> @* end col-12 *@
            </div> @* end row *@
        </div> @* end results-area *@
    }
    else
    {
        <!-- B2B DASHBOARD START SCREEN -->
        <div class="b2b-dashboard-container b2b-animate">
            
            <!-- Widget 1: Recent Searches (Hidden - now in modal) -->
            @* Recent Searches moved to modal - this section is hidden *@

            <!-- User Dashboard - For CustomerB2B AND Plasiyer -->
            @if (IsCustomerB2B() || IsPlasiyer())
            {
            <div class="modern-dashboard-container dashboard-full-width">
                <div class="dashboard-header-modern">
                    <div class="dashboard-header-content">
                        <div class="dashboard-header-icon-wrapper">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>
                        <div>
                            <h3 class="dashboard-header-title">
                                @(IsPlasiyer() && !Security.SelectedCustomerId.HasValue ? "Plasiyer Paneli" : "Özet Bilgiler")
                            </h3>
                            <p class="dashboard-header-subtitle">
                                @(IsPlasiyer() && !Security.SelectedCustomerId.HasValue ? "Müşteri ve sipariş takibi" : "Hesap durumunuz ve istatistikleriniz")
                            </p>
                        </div>
                    </div>
                    @if (IsPlasiyer() && Security.SelectedCustomerId.HasValue)
                    {
                        <div class="dashboard-header-right animate__animated animate__fadeIn">
                            <span class="badge bg-white text-primary border border-primary-subtle shadow-sm px-3 py-2 rounded-pill d-inline-flex align-items-center gap-2">
                                <i class="fas fa-user-check text-primary"></i>
                                <span class="fw-medium text-dark">Seçili Cari:</span>
                                <strong class="text-primary">@Security.SelectedCustomerName</strong>
                                <button type="button" class="btn-close-customer ms-2" @onclick="ClearSelectedCustomer" title="Cari Seçimini Kaldır">
                                    <i class="fas fa-times"></i>
                                </button>
                            </span>
                        </div>
                    }
                </div>
                
                @if (isLoadingDashboard)
                {
                    <div class="dashboard-loading-state">
                        <div class="dashboard-skeleton-loader">
                            @for (int i = 0; i < 5; i++)
                            {
                                <div class="dashboard-skeleton-card">
                                    <div class="skeleton-icon"></div>
                                    <div class="skeleton-content">
                                        <div class="skeleton-line short"></div>
                                        <div class="skeleton-line long"></div>
                                        <div class="skeleton-line medium"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="modern-dashboard-grid">
                        <!-- Sepet Toplam -->
                        <div class="modern-dashboard-card card-cart" style="cursor: pointer;" @onclick="NavigateToCart">
                            <div class="card-decoration"></div>
                            <div class="card-icon-wrapper">
                                <div class="card-icon-bg"></div>
                                <i class="fa-solid fa-cart-shopping card-icon"></i>
                            </div>
                            <div class="card-content-wrapper">
                                <div class="card-label">Sepet Toplam</div>
                                <div class="card-main-value">@GetCartTotal()</div>
                                <div class="card-secondary-info">
                                    <i class="fa-solid fa-box"></i>
                                    <span>@GetCartItemCount() ürün</span>
                                </div>
                            </div>
                            <div class="card-hover-effect"></div>
                        </div>

                        <!-- Bekleyen Sipariş -->
                        <div class="modern-dashboard-card card-pending" style="cursor: pointer;" @onclick="NavigateToPendingOrders">
                            <div class="card-decoration"></div>
                            <div class="card-icon-wrapper">
                                <div class="card-icon-bg"></div>
                                <i class="fa-solid fa-clock card-icon"></i>
                            </div>
                            <div class="card-content-wrapper">
                                <div class="card-label">Bekleyen Sipariş</div>
                                <div class="card-main-value">@GetPendingOrderCount() <span class="value-unit">Adet</span></div>
                                <div class="card-secondary-info">
                                    <span>@GetPendingOrderTotal()</span>
                                </div>
                            </div>
                            <div class="card-hover-effect"></div>
                        </div>

                        <!-- Toplam Sipariş -->
                        <div class="modern-dashboard-card card-total">
                            <div class="card-decoration"></div>
                            <div class="card-icon-wrapper">
                                <div class="card-icon-bg"></div>
                                <i class="fa-solid fa-boxes-stacked card-icon"></i>
                            </div>
                            <div class="card-content-wrapper">
                                <div class="card-label">Toplam Sipariş</div>
                                <div class="card-main-value">@GetTotalOrderCount() <span class="value-unit">Adet</span></div>
                                <div class="card-secondary-info">
                                    <span>@GetTotalOrderAmount()</span>
                                </div>
                            </div>
                            <div class="card-hover-effect"></div>
                        </div>

                        <!-- Bakiye -->
                        <!-- Bakiye / Bağlı Cari Sayısı -->
                        <div class="modern-dashboard-card card-balance @(IsPlasiyer() && !Security.SelectedCustomerId.HasValue ? "balance-info" : (GetBalance() >= 0 ? "balance-positive" : "balance-negative"))" style="cursor: pointer;" @onclick='() => { if(IsPlasiyer() && !Security.SelectedCustomerId.HasValue) Navigation.NavigateTo("/plasiyer/customers"); else Navigation.NavigateTo("/b2b/customer-account-report"); }'>
                            <div class="card-decoration"></div>
                            <div class="card-icon-wrapper">
                                <div class="card-icon-bg"></div>
                                <i class="fa-solid @(IsPlasiyer() && !Security.SelectedCustomerId.HasValue ? "fa-users" : "fa-wallet") card-icon"></i>
                            </div>
                            <div class="card-content-wrapper">
                                <div class="card-label">@(IsPlasiyer() && !Security.SelectedCustomerId.HasValue ? "Bağlı Cari" : "Bakiye")</div>
                                <div class="card-main-value balance-value">
                                    @(IsPlasiyer() && !Security.SelectedCustomerId.HasValue ? $"{linkedCustomerCount} Adet" : CurrencyHelper.FormatPrice(GetBalance()))
                                </div>
                                <div class="card-secondary-info d-flex flex-column align-items-start gap-1">
                                    @if(IsPlasiyer() && !Security.SelectedCustomerId.HasValue)
                                    {
                                        <div class="small fw-semibold text-primary">
                                            <i class="fa-solid fa-list me-1"></i> Tümünü Gör
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="small fw-semibold text-danger">
                                            <i class="fa-solid fa-arrow-up me-1"></i> Borç: @CurrencyHelper.FormatPrice(GetTotalDebit())
                                        </div>
                                        <div class="small fw-semibold text-success">
                                            <i class="fa-solid fa-arrow-down me-1"></i> Alacak: @CurrencyHelper.FormatPrice(GetTotalCredit())
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="card-hover-effect"></div>
                        </div>
                        <!-- Fatura Toplamı -->
                        <div class="modern-dashboard-card card-invoice" style="cursor: pointer;" @onclick='() => Navigation.NavigateTo("/b2b/my-invoices")'>
                            <div class="card-decoration"></div>
                            <div class="card-icon-wrapper">
                                <div class="card-icon-bg"></div>
                                <i class="fa-solid fa-file-invoice-dollar card-icon"></i>
                            </div>
                            <div class="card-content-wrapper">
                                <div class="card-label">Fatura Toplamı</div>
                                <div class="card-main-value">@GetTotalInvoiceAmount()</div>
                                <div class="card-secondary-info">
                                    <i class="fa-solid fa-file-invoice"></i>
                                    <span>@GetTotalInvoiceCount() fatura</span>
                                </div>
                            </div>
                            <div class="card-hover-effect"></div>
                        </div>
                    </div>
                }
            </div>
            }

        </div>

        <!-- STATIC DASHBOARD FOOTER -->

    }
</div>

@* VEHICLE MATCH MODAL - şimdilik devre dışı *@
@if (false && isVehicleMatchModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1055; overflow-x: hidden; overflow-y: hidden;">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content rounded-4 shadow-lg border-0 overflow-hidden">
                <div class="modal-header bg-success text-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-4">
                        <h5 class="modal-title fw-bold mb-0"><i class="fa-solid fa-car-side me-2"></i>Araçtan Eşleşme</h5>
                        <div class="form-check form-switch custom-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="modalStockSwitch" 
                                   checked="@isModalOnlyInStock" 
                                   @onchange="@(async (args) => await OnVehicleMatchStockSwitchChanged((bool)(args.Value ?? false)))">
                            <label class="form-check-label text-white small user-select-none" for="modalStockSwitch" style="cursor:pointer">Stoktakiler</label>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseVehicleMatchModal"></button>
                </div>
                <div class="modal-body p-0 overflow-hidden">
                    <div class="vehicle-modal-columnar">
                        <!-- Column 1: Manufacturers -->
                        <div class="col-column">
                            <div class="column-header">MARKA SEÇİNİZ</div>
                            <div class="column-search-box">
                                <div class="position-relative">
                                    <i class="fa-solid fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                                    <input type="text" class="form-control rounded-pill" 
                                           placeholder="Marka ara..." @bind="modalManufacturerSearch" @bind:event="oninput" />
                                    @if (!string.IsNullOrWhiteSpace(modalManufacturerSearch))
                                    {
                                        <button type="button" @onclick="() => modalManufacturerSearch = string.Empty"
                                                style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer;">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="scrollable-modal-list">
                                @foreach(var manufacturerName in filteredModalManufacturers) {
                                    <button class="modal-list-item @(modalSelectedManufacturer == manufacturerName ? "active" : "")" @onclick="() => OnModalManufacturerChanged(manufacturerName)">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <div class="d-flex align-items-center gap-2 flex-grow-1">
                                                <span>@manufacturerName</span>
                                            </div>
                                            @if(modalSelectedManufacturer == manufacturerName) {
                                                <i class="fa-solid fa-chevron-right small opacity-50"></i>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Column 2: Models -->
                        <div class="col-column">
                            <div class="column-header">MODEL SEÇİNİZ</div>
                            <div class="column-search-box">
                                <div class="position-relative">
                                    <i class="fa-solid fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                                    <input type="text" class="form-control rounded-pill" 
                                           placeholder="Model ara..." @bind="modalModelSearch" @bind:event="oninput" 
                                           disabled="@(string.IsNullOrEmpty(modalSelectedManufacturer))" />
                                    @if (!string.IsNullOrWhiteSpace(modalModelSearch))
                                    {
                                        <button type="button" @onclick="() => modalModelSearch = string.Empty"
                                                style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer;">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="scrollable-modal-list @(string.IsNullOrEmpty(modalSelectedManufacturer) ? "opacity-50" : "")">
                                @if (isModelLoading)
                                {
                                    <div class="d-flex justify-content-center align-items-center h-100 p-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Yükleniyor...</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @foreach(var modelName in filteredModalModels) {
                                        <button class="modal-list-item @(modalSelectedModel == modelName ? "active" : "")" @onclick="() => OnModalModelChanged(modelName)">
                                            <div class="d-flex justify-content-between align-items-center gap-2">
                                                <span>@modelName</span>
                                                @if(modalSelectedModel == modelName) {
                                                    <i class="fa-solid fa-chevron-right small opacity-50"></i>
                                                }
                                            </div>
                                        </button>
                                    }
                                    @if(!string.IsNullOrEmpty(modalSelectedManufacturer) && !filteredModalModels.Any()) {
                                        <div class="p-4 text-center text-muted">
                                            <i class="fa-solid fa-circle-question d-block mb-2 fs-4"></i>
                                            <span class="small">Model bulunamadı</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Column 3: Sub-Models -->
                        <div class="col-column">
                            <div class="column-header">TİP SEÇİNİZ</div>
                            <div class="column-search-box">
                                <div class="position-relative">
                                    <i class="fa-solid fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                                    <input type="text" class="form-control rounded-pill" 
                                           placeholder="Tip ara..." @bind="modalSubModelSearch" @bind:event="oninput" 
                                           disabled="@(string.IsNullOrEmpty(modalSelectedModel))" />
                                    @if (!string.IsNullOrWhiteSpace(modalSubModelSearch))
                                    {
                                        <button type="button" @onclick="() => modalSubModelSearch = string.Empty"
                                                style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer;">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="scrollable-modal-list @(string.IsNullOrEmpty(modalSelectedModel) ? "opacity-50" : "")">
                                @if (isSubModelLoading)
                                {
                                    <div class="d-flex justify-content-center align-items-center h-100 p-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Yükleniyor...</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @foreach(var sm in filteredModalSubModels) {
                                        <button class="modal-list-item @(modalSelectedSubModel == sm.Key ? "active" : "")" @onclick="() => OnModalSubModelChanged(sm.Key)">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>@sm.Name</span>
                                                @if(modalSelectedSubModel == sm.Key) {
                                                    <i class="fa-solid fa-chevron-right small opacity-50"></i>
                                                }
                                            </div>
                                        </button>
                                    }
                                    @if(!string.IsNullOrEmpty(modalSelectedModel) && !filteredModalSubModels.Any()) {
                                        <div class="p-4 text-center text-muted">
                                            <i class="fa-solid fa-circle-question d-block mb-2 fs-4"></i>
                                            <span class="small">Tip bulunamadı</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>


                        <!-- Column 4: DotParts (Part Groups) -->
                        <div class="col-column">
                            <div class="column-header">PARÇA GRUBU SEÇİNİZ</div>
                            <div class="column-search-box">
                                <div class="position-relative">
                                    <i class="fa-solid fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                                    <input type="text" class="form-control rounded-pill" 
                                           placeholder="Parça ara..." @bind="modalDotPartSearch" @bind:event="oninput" 
                                           disabled="@(string.IsNullOrEmpty(modalSelectedSubModel))" />
                                    @if (!string.IsNullOrWhiteSpace(modalDotPartSearch))
                                    {
                                        <button type="button" @onclick="() => modalDotPartSearch = string.Empty"
                                                style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer;">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="scrollable-modal-list @(string.IsNullOrEmpty(modalSelectedSubModel) ? "opacity-50" : "")">
                                @if (isDotPartLoading)
                                {
                                    <div class="d-flex justify-content-center align-items-center h-100 p-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Yükleniyor...</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @foreach(var dotPart in filteredModalDotParts) {
                                        <button class="modal-list-item @(modalSelectedDotPart == dotPart.Name ? "active" : "")" @onclick="() => OnModalDotPartChanged(dotPart)">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>@dotPart.DisplayName.ToUpper()</span>
                                                @if(modalSelectedDotPart == dotPart.Name) {
                                                    <i class="fa-solid fa-check small opacity-50"></i>
                                                }
                                            </div>
                                        </button>
                                    }
                                    @if(!string.IsNullOrEmpty(modalSelectedSubModel) && !filteredModalDotParts.Any()) {
                                        <div class="p-4 text-center text-muted">
                                            <i class="fa-solid fa-circle-question d-block mb-2 fs-4"></i>
                                            <span class="small">Parça grubu bulunamadı</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Column 5: Summary -->
                        <div class="col-column">
                            <div class="column-header">SEÇİM ÖZETİ</div>
                            <div class="p-4 flex-grow-1 overflow-auto">
                               @if(!string.IsNullOrEmpty(modalSelectedManufacturer)) {
                                   <div class="summary-card mb-2">
                                       <div class="d-flex align-items-center gap-2">
                                           <i class="fa-solid fa-industry text-success opacity-50"></i>
                                           <div>
                                               <div class="summary-label">MARKA</div>
                                               <div class="summary-value">@modalSelectedManufacturer</div>
                                           </div>
                                       </div>
                                   </div>
                               }
                               @if(!string.IsNullOrEmpty(modalSelectedModel)) {
                                   <div class="summary-card mb-2">
                                       <div class="d-flex align-items-center gap-2">
                                           <i class="fa-solid fa-car-side text-success opacity-50"></i>
                                           <div>
                                               <div class="summary-label">MODEL</div>
                                               <div class="summary-value">@modalSelectedModel</div>
                                           </div>
                                       </div>
                                   </div>
                               }
                               @if(!string.IsNullOrEmpty(modalSelectedSubModel)) {
                                   <div class="summary-card mb-2">
                                       <div class="d-flex align-items-center gap-2">
                                           <i class="fa-solid fa-microchip text-success opacity-50"></i>
                                           <div>
                                               <div class="summary-label">TİP</div>
                                               <div class="summary-value">@modalSubModels.FirstOrDefault(x => x.Key == modalSelectedSubModel)?.Name</div>
                                           </div>
                                       </div>
                                   </div>
                               }
                               @if(!string.IsNullOrEmpty(modalSelectedDotPart)) {
                                   <div class="summary-card mb-2">
                                       <div class="d-flex align-items-center gap-2">
                                           <i class="fa-solid fa-gears text-success opacity-50"></i>
                                           <div>
                                               <div class="summary-label">PARÇA GRUBU</div>
                                               <div class="summary-value">@modalSelectedDotPartDisplay</div>
                                           </div>
                                       </div>
                                   </div>
                               }
                            </div>
                            <div class="p-4 border-top bg-light">
                                <div class="d-grid gap-2">
                                    <button class="btn btn-success btn-lg fw-bold shadow-sm py-3 rounded-3" 
                                            @onclick="ApplyVehicleMatchFilters" 
                                            disabled="@(string.IsNullOrEmpty(modalSelectedManufacturer))">
                                        <i class="fa-solid fa-search me-2"></i> ARA
                                    </button>
                                    <button class="btn btn-link text-muted text-decoration-none" @onclick="CloseVehicleMatchModal">İptal</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
