        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="Telefon Numarası" Component="PhoneNumber" class="w-100"/>
            </div>
            <div class="col-md-9">
                @if (SellerCompany != null)
                {
                    <RadzenTextBox class="rz-full-width" @bind-Value="@SellerCompany.PhoneNumber" Disabled Name="PhoneNumber"/>
                }
            </div>
        </div>

        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="Adres" Component="PhoneNumber" class="w-100"/>
            </div>
            <div class="col-md-9">
                @if (SellerCompany != null)
                {
                    <RadzenTextArea Rows="5" class="rz-full-width" @bind-Value="@SellerCompany.Address" Disabled Name="Address"/>
                }
            </div>
        </div>
    </RadzenFieldset>
</RadzenTabsItem>

