@using Radzen
@using Radzen.Blazor

<link href="css/b2b-change-password.css" rel="stylesheet" />

<div class="password-modal-container">
    <div class="text-center mb-4">
        <div class="modal-icon-wrapper mb-3">
            <i class="fa-solid fa-key fa-3x text-success opacity-75"></i>
        </div>
        <h4 class="fw-bold mb-1">Şifre Değiştir</h4>
        <p class="text-muted small">Hesabınızı güvende tutmak için şifrenizi güncelleyin.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger d-flex align-items-center mb-4 border-0 rounded-3 shadow-sm animate-fade-in" role="alert">
            <i class="fa-solid fa-circle-exclamation me-3 fs-5"></i>
            <div class="small">@errorMessage</div>
        </div>
    }

    @if (isSuccess)
    {
        <div class="text-center py-4 animate-bounce-in">
            <div class="mb-3">
                <i class="fa-solid fa-circle-check text-success fa-5x"></i>
            </div>
            <h5 class="fw-bold text-success mb-2">Başarılı!</h5>
            <p class="text-muted small mb-4">Şifreniz başarıyla değiştirildi.</p>
            <RadzenButton Click='() => DialogService.Close(true)' Text="Kapat" ButtonStyle="ButtonStyle.Success" Class="w-100 rounded-pill py-2 fw-bold shadow-sm" />
        </div>
    }
    else
    {
        <form @onsubmit:preventDefault @onsubmit="HandleChangePassword">
            <div class="mb-3">
                <label class="form-label fw-bold text-dark small text-uppercase mb-1">Mevcut Şifre</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" class="form-control border-start-0 ps-0" @bind="currentPassword" placeholder="Eski şifrenizi girin" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-dark small text-uppercase mb-1">Yeni Şifre</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-shield-halved"></i></span>
                    <input type="password" class="form-control border-start-0 ps-0" @bind="newPassword" placeholder="En az 6 karakter" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-dark small text-uppercase mb-1">Yeni Şifre (Tekrar)</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-circle-check"></i></span>
                    <input type="password" class="form-control border-start-0 ps-0" @bind="confirmPassword" placeholder="Yeni şifreyi onaylayın" required />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <RadzenButton Click='() => DialogService.Close(false)' Text="Vazgeç" ButtonStyle="ButtonStyle.Light" Class="flex-grow-1 rounded-pill py-2 fw-bold text-uppercase" />
                <RadzenButton ButtonType="ButtonType.Submit" 
                              ButtonStyle="ButtonStyle.Success" 
                              Class="flex-grow-2 rounded-pill py-2 fw-bold shadow-sm text-uppercase d-flex align-items-center justify-content-center gap-2" 
                              Disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span>...</span>
                    }
                    else
                    {
                        <span>Güncelle</span>
                    }
                </RadzenButton>
            </div>
        </form>
    }
</div>

<style>
    .password-modal-container {
        padding: 0.5rem;
    }
    
    .modal-icon-wrapper {
        width: 80px;
        height: 80px;
        background: rgba(14, 148, 122, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .flex-grow-2 {
        flex-grow: 2;
    }

    /* Override some global modal styles if needed */
    .rz-dialog-content {
        padding: 2rem !important;
    }
</style>
