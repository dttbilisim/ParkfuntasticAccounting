@page "/orders"
@layout MainLayout
@using ecommerce.Admin.Domain.Dtos.OrderDto;
@using ecommerce.Core.Utils;
@using Microsoft.AspNetCore.Components
@inject IStringLocalizer<Culture_TR> Loc
<PageTitle>Siparişler</PageTitle>
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-6">
            <h1 class="h3 mb-0 text-gray-800">Siparişler</h1>
        </div>
        <div class="col-6 text-end">
            <RadzenButton Icon="cloud_download" Text="Excel olarak indir" Click="@(args => ExcelExportClick())" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Success" />
        </div>
    </div>

    <RadzenCard class="mb-4 d-flex align-items-center gap-3 flex-wrap shadow-sm">
        <RadzenTextBox style="flex: 1; min-width: 200px;" Change="@TopFilterChange" Placeholder="Sipariş No Veya Müşteri Adı Yazınız" @bind-Value="@TopFilterTest"></RadzenTextBox>
        <RadzenDropDown style="flex: 0 0 180px;" Data="@platformTypes" TextProperty="Key" ValueProperty="Value" Change="@TopFilterChange" Placeholder="Platform Seçiniz.." AllowClear="true" @bind-Value="@SelectFilterPlatformType"
                        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
        <RadzenDropDown style="flex: 0 0 200px;" Data="@orderStatus" TextProperty="Key" ValueProperty="Value" Change="@TopFilterChange" Placeholder="Durum Seçiniz.." AllowClear="true" @bind-Value="@SelectFilterStatus"
                        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
        <RadzenDatePicker style="flex: 0 0 150px;" Change="@TopFilterChange" @bind-Value="@SelectFilterStartDate" Name="StartDate" Placeholder="Başlangıç Tarihi" DateFormat="dd/MM/yyyy" />
        <RadzenDatePicker style="flex: 0 0 150px;" Change="@TopFilterChange" @bind-Value="@SelectFilterEndDate" Name="EndDate" Placeholder="Bitiş Tarihi" DateFormat="dd/MM/yyyy" />
    </RadzenCard>

    <div class="card shadow mb-4">
        <div class="card-body">
            <AdminDataGrid @ref="radzenDataGrid"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Advanced"
                            AllowPaging="true"
                            AllowSorting="true"
                            PageSize="25"
                            AllowFilterDateInput="true"
                            TItem="OrderListDto"
                            LoadData="@LoadData"
                            Data="orders"
                            Count="@count"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            ExpandMode="DataGridExpandMode.Single"
                            RowSelect="@(item => OpenDetailForOrder(item))"
                            RowRender="@RowRender"
                            LogicalFilterOperator="LogicalFilterOperator.Or"
                            SelectionMode="DataGridSelectionMode.Single">

                <Columns>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="" Width="45px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                        <Template Context="order">
                            @{
                                var hasEttn = order.LinkedInvoices != null && order.LinkedInvoices.Any(li => !string.IsNullOrEmpty(li.Ettn));
                            }
                            @if (hasEttn)
                            {
                                <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(args => DownloadEInvoicePdf(order))" IsBusy="@_isDownloadingEInvoice"
                                              title="e-Fatura PDF İndir" @onclick:stopPropagation="true" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Sipariş No." Property="OrderNumber" Filterable="true" Sortable="true" Width="200px">
                        <Template Context="order">
                            <div class="d-flex align-items-center gap-2">
                                @if (order.PlatformType == OrderPlatformType.B2B)
                                {
                                    <span class="badge" style="background-color: #10b981; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">B2B</span>
                                }
                                else if (order.PlatformType == OrderPlatformType.Marketplace)
                                {
                                    <span class="badge" style="background-color: #9333ea; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">Marketplace</span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color: #6b7280; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">Diğer</span>
                                }
                                <span>@order.OrderNumber</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Müşteri" Property="CustomerName" Filterable="true" Sortable="true" />
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Satıcı" Property="Seller.Name" Filterable="true" Sortable="true" />
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Sipariş Durumu" Property="OrderStatusType" Filterable="true" />
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Ödeme Tipi" Property="PaymentTypeId" Filterable="true" />
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Sipariş Tarihi" Property="CreatedDate" Filterable="true" Sortable="true" />
                    <RadzenDataGridColumn TItem="OrderListDto" Property="GrandTotal" Title="Toplam" Filterable="true" FormatString="₺{0:n2}" />
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Fatura No" Filterable="false" Sortable="false" Width="100px">
                        <Template Context="order">
                            @{
                                var firstInv = order.LinkedInvoices?.FirstOrDefault();
                            }
                            @if (firstInv != null)
                            {
                                <span style="font-size: 0.8rem;">@firstInv.InvoiceNo</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Ara Toplam" Filterable="false" Sortable="false" Width="95px" TextAlign="TextAlign.End">
                        <Template Context="order">
                            @{
                                var firstInv = order.LinkedInvoices?.FirstOrDefault();
                            }
                            @if (firstInv != null)
                            {
                                <span style="font-size: 0.8rem;">₺@firstInv.TotalAmount.ToString("N2")</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="İndirim" Filterable="false" Sortable="false" Width="85px" TextAlign="TextAlign.End">
                        <Template Context="order">
                            @{
                                var firstInv = order.LinkedInvoices?.FirstOrDefault();
                            }
                            @if (firstInv != null)
                            {
                                <span style="font-size: 0.8rem; color: #dc2626;">₺@firstInv.DiscountTotal.ToString("N2")</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="KDV" Filterable="false" Sortable="false" Width="85px" TextAlign="TextAlign.End">
                        <Template Context="order">
                            @{
                                var firstInv = order.LinkedInvoices?.FirstOrDefault();
                            }
                            @if (firstInv != null)
                            {
                                <span style="font-size: 0.8rem;">₺@firstInv.VatTotal.ToString("N2")</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="OrderListDto" Title="Fatura Toplam" Filterable="false" Sortable="false" Width="105px" TextAlign="TextAlign.End">
                        <Template Context="order">
                            @{
                                var firstInv = order.LinkedInvoices?.FirstOrDefault();
                            }
                            @if (firstInv != null)
                            {
                                <span style="font-size: 0.8rem; font-weight: 600;">₺@firstInv.GeneralTotal.ToString("N2")</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </AdminDataGrid>
        </div>
    </div>
</div>
