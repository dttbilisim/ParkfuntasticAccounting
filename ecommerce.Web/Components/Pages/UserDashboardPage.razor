    @* // Şifre değiştirme *@

<div class="tab-pane fade" id="pills-password" role="tabpanel">
        <div class="dashboard-download">
            <div class="dashboard-title mb-4">
                <h2>@lang["ChangePassword"]</h2>
                <span class="title-leaf">
                <svg class="icon-width bg-gray">
                    <use xlink:href="../assets/svg/leaf.svg#leaf"></use>
                </svg>
            </span>
            </div>
        

            <div class="dashboard-bg-box p-4 shadow-sm rounded-3" style="max-width: 800px; margin: auto;">
                <RadzenTemplateForm TItem="object" Data="@this" Submit="@ChangePassword">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="mb-2">
                                <label class="form-label">@lang["CurrentPassword"]</label>
                                <input type="password"
                                       class="form-control"
                                       name="CurrentPassword"
                                       placeholder="@lang["CurrentPassword"]"
                                       @bind="CurrentPassword" required />
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="mb-2">
                                <label class="form-label">@lang["NewPassword"]</label>
                                <input type="password"
                                       class="form-control"
                                       name="NewPassword"
                                       placeholder="@lang["NewPassword"]"
                                       @bind="NewPassword" required />
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="mb-2">
                                <label class="form-label">@lang["ConfirmPassword"]</label>
                                <input type="password"
                                       class="form-control"
                                       name="ConfirmPassword"
                                       placeholder="@lang["ConfirmPassword"]"
                                       @bind="ConfirmPassword" required />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center mt-4">
                        <button class="btn theme-bg-color btn-md fw-bold mt-4 text-white" tabindex="0" type="submit">
                            @lang["ChangePassword"]
                        </button>
                    </div>
                </RadzenTemplateForm>
            </div>
        </div>
    </div>
</div>
