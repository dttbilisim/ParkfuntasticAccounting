@page "/education-items"
@using ecommerce.Admin.Domain.Dtos.EducationDto
@using ecommerce.Core.Utils
@layout MainLayout
@inject IStringLocalizer<Culture_TR> Loc

<PageTitle>Eğitim Detayları</PageTitle>

<RadzenCard class="mb-3" style="display: flex; align-items: center;">

    <div style="width: 100%; overflow: hidden;">
        <div style="width: 600px; float: left;">
            <RadzenText Text="Eğitim Detayları" TextStyle="TextStyle.H5" style="color:#598087" class="mt-2" />
        </div>
        <div style="float:right">
            <RadzenButton Icon="add_circle_outline" Text="Yeni Eğitim Detayı Ekle" Click="@AddButtonClick" Variant="Variant.Flat" class="mt-2" />
        </div>
    </div>


</RadzenCard>

<div class="row">
    <div class="col-md-12">
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" AllowSorting="true" PagerAlwaysVisible=true PageSize=25 AllowFilterDateInput=true TItem="EducationItemsListDto" RowSelect="@EditRow" LoadData="@LoadData" Count="@count" Data="@data" CellRender="@RowRender" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        EqualsText="@Loc.GetString("EqualsText")"
                        NotEqualsText="@Loc.GetString("NotEqualsText")"
                        LessThanText="@Loc.GetString("LessThanText")"
                        LessThanOrEqualsText="@Loc.GetString("LessThanOrEqualsText")"
                        GreaterThanText="@Loc.GetString("GreaterThanText")"
                        IsNullText="@Loc.GetString("IsNullText")"
                        IsNotNullText="@Loc.GetString("IsNotNullText")">


            <Columns>
                <RadzenDataGridColumn TItem="EducationItemsListDto" Property="Id" Title="Id" Width="50px"/>
                <RadzenDataGridColumn TItem="EducationItemsListDto" Property="Order" Title="Sırası" Width="50px"/>
                <RadzenDataGridColumn TItem="EducationItemsListDto" Property="EducationName" Title="Eğitim Adı" />

                <RadzenDataGridColumn TItem="EducationItemsListDto" Property="Name" Title="Bölüm Adı"/>
                         
                <RadzenDataGridColumn TItem="EducationItemsListDto" Property="CreatedDate" FormatString="{0:dd/MM/yyyy HH:mm}" Width="100px" Title="Oluşturulma Tarihi">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationItemsListDto" Property="StatusStr" Filterable="false" Sortable="false" Title="Durum" Width="70px">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="EducationItemsListDto" Title="Aksiyon" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="Banner">
                        @if (Banner.Status != EntityStatus.Deleted.GetHashCode())
                        {
                            <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall" Shade="Shade.Dark" Variant="Variant.Flat" Click=@(args => GridDeleteButtonClick(args, Banner)) @onclick:stopPropagation="true" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>
