@using System.Linq
@using Blazored.Modal
@using Blazored.Modal.Services
@using ecommerce.Web.Domain.Dtos
@using ecommerce.Web.Domain.Services
@using ecommerce.Web.Domain.Services.Abstract
@using Core.Utils
@using ecommerce.Web.Utility
@using I18NPortable
@using Microsoft.JSInterop
@using Radzen
@using ecommerce.Domain.Shared.Dtos.Filters
@using SharedProduct = ecommerce.Domain.Shared.Dtos.Product
@inject NavigationManager NavigationManager
@inject II18N lang
@inject IJSRuntime JsRuntime
@inject IManufacturerCacheService ManufacturerCacheService
@inject NotificationService NotificationService
@inject ISellerProductService ProductService
@implements IAsyncDisposable

<div class="advanced-search-wrapper">
    <div class="advanced-search-modal vehicle-match-modal">
        <div class="modal-header">
            <h5 class="modal-title "><i class="fa-solid fa-car-side me-2"></i>Araçtan Eşleşme</h5>
             <div class="form-check form-switch custom-switch mb-0 ms-auto me-3">
                <input class="form-check-input" type="checkbox" id="modalStockSwitch" 
                       checked="@isModalOnlyInStock" 
                       @onchange="OnStockSwitchChanged">
                <label class="form-check-label small user-select-none" for="modalStockSwitch" style="cursor:pointer">Sadece Stoktakiler</label>
            </div>
            <button type="button" class="btn-close-custom" @onclick="CancelAsync">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="modal-body-columnar">
            <!-- Column 1: Manufacturers -->
            <div class="col-column">
                <div class="column-header">MARKA SEÇİNİZ</div>
                <div class="column-search-box">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-search"></i>
                        <input type="text" placeholder="Marka ara..." @bind="modalManufacturerSearch" @bind:event="oninput" />
                        @if (!string.IsNullOrWhiteSpace(modalManufacturerSearch))
                        {
                            <button type="button" @onclick="() => modalManufacturerSearch = string.Empty"><i class="fa-solid fa-xmark"></i></button>
                        }
                    </div>
                </div>
                <div class="scrollable-modal-list">
                    @foreach(var manufacturerName in FilteredModalManufacturers) {
                        <button class="modal-list-item @(modalSelectedManufacturer == manufacturerName ? "active" : "")" @onclick="() => OnModalManufacturerChanged(manufacturerName)">
                            <span>@manufacturerName</span>
                            @if(modalSelectedManufacturer == manufacturerName) {
                                <i class="fa-solid fa-chevron-right"></i>
                            }
                        </button>
                    }
                </div>
            </div>

            <!-- Column 2: Models -->
            <div class="col-column">
                <div class="column-header">MODEL SEÇİNİZ</div>
                <div class="column-search-box">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-search"></i>
                        <input type="text" placeholder="Model ara..." @bind="modalModelSearch" @bind:event="oninput" disabled="@(string.IsNullOrEmpty(modalSelectedManufacturer))" />
                        @if (!string.IsNullOrWhiteSpace(modalModelSearch))
                        {
                            <button type="button" @onclick="() => modalModelSearch = string.Empty"><i class="fa-solid fa-xmark"></i></button>
                        }
                    </div>
                </div>
                <div class="scrollable-modal-list @(string.IsNullOrEmpty(modalSelectedManufacturer) ? "opacity-50" : "")">
                    @if (isModelLoading)
                    {
                        <div class="loading-state">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else
                    {
                        @foreach(var modelName in FilteredModalModels) {
                            <button class="modal-list-item @(modalSelectedModel == modelName ? "active" : "")" @onclick="() => OnModalModelChanged(modelName)">
                                <span>@modelName</span>
                                @if(modalSelectedModel == modelName) {
                                    <i class="fa-solid fa-chevron-right"></i>
                                }
                            </button>
                        }
                        @if(!string.IsNullOrEmpty(modalSelectedManufacturer) && !FilteredModalModels.Any()) {
                            <div class="empty-state">Model bulunamadı</div>
                        }
                    }
                </div>
            </div>

            <!-- Column 3: Sub-Models -->
            <div class="col-column">
                <div class="column-header">TİP SEÇİNİZ</div>
                <div class="column-search-box">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-search"></i>
                        <input type="text" placeholder="Tip ara..." @bind="modalSubModelSearch" @bind:event="oninput" disabled="@(string.IsNullOrEmpty(modalSelectedModel))" />
                         @if (!string.IsNullOrWhiteSpace(modalSubModelSearch))
                        {
                             <button type="button" @onclick="() => modalSubModelSearch = string.Empty"><i class="fa-solid fa-xmark"></i></button>
                        }
                    </div>
                </div>
                <div class="scrollable-modal-list @(string.IsNullOrEmpty(modalSelectedModel) ? "opacity-50" : "")">
                    @if (isSubModelLoading)
                    {
                        <div class="loading-state">
                           <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else
                    {
                        @foreach(var sm in FilteredModalSubModels) {
                            <button class="modal-list-item @(modalSelectedSubModelKey == sm.Key ? "active" : "")" @onclick="() => OnModalSubModelChanged(sm.Key, sm.Name)">
                                <span>@sm.Name</span>
                                @if(modalSelectedSubModelKey == sm.Key) {
                                    <i class="fa-solid fa-chevron-right"></i>
                                }
                            </button>
                        }
                        @if(!string.IsNullOrEmpty(modalSelectedModel) && !FilteredModalSubModels.Any()) {
                             <div class="empty-state">Tip bulunamadı</div>
                        }
                    }
                </div>
            </div>

             <!-- Column 4: DotParts (Part Groups) -->
            <div class="col-column">
                <div class="column-header">PARÇA GRUBU</div>
                 <div class="column-search-box">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-search"></i>
                        <input type="text" placeholder="Parça ara..." @bind="modalDotPartSearch" @bind:event="oninput" disabled="@(string.IsNullOrEmpty(modalSelectedSubModelKey))" />
                         @if (!string.IsNullOrWhiteSpace(modalDotPartSearch))
                        {
                             <button type="button" @onclick="() => modalDotPartSearch = string.Empty"><i class="fa-solid fa-xmark"></i></button>
                        }
                    </div>
                </div>
                 <div class="scrollable-modal-list @(string.IsNullOrEmpty(modalSelectedSubModelKey) ? "opacity-50" : "")">
                    @if (isDotPartLoading)
                    {
                         <div class="loading-state">
                           <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else
                    {
                        @foreach(var dotPart in FilteredModalDotParts) {
                            <button class="modal-list-item @(modalSelectedDotPart == dotPart.Name ? "active" : "")" @onclick="() => OnModalDotPartChanged(dotPart.Name, dotPart.ProcessNumber)">
                                <span>@dotPart.Name.ToUpper()</span>
                                @if(modalSelectedDotPart == dotPart.Name) {
                                    <i class="fa-solid fa-check"></i>
                                }
                            </button>
                        }
                         @if(!string.IsNullOrEmpty(modalSelectedSubModelKey) && !FilteredModalDotParts.Any()) {
                             <div class="empty-state">Parça bulunamadı</div>
                        }
                    }
                </div>
            </div>

             <!-- Column 5: Summary -->
            <div class="col-column summary-column">
                <div class="column-header">SEÇİM ÖZETİ</div>
                <div class="summary-content">
                    @if(!string.IsNullOrEmpty(modalSelectedManufacturer)) {
                        <div class="summary-card">
                            <div class="summary-label">MARKA</div>
                            <div class="summary-value">@modalSelectedManufacturer</div>
                        </div>
                    }
                    @if(!string.IsNullOrEmpty(modalSelectedModel)) {
                        <div class="summary-card">
                            <div class="summary-label">MODEL</div>
                            <div class="summary-value">@modalSelectedModel</div>
                        </div>
                    }
                    @if(!string.IsNullOrEmpty(modalSelectedSubModelKey)) {
                        <div class="summary-card">
                            <div class="summary-label">TİP</div>
                            <div class="summary-value">@modalSelectedSubModelName</div>
                        </div>
                    }
                     @if(!string.IsNullOrEmpty(modalSelectedDotPart)) {
                        <div class="summary-card">
                            <div class="summary-label">PARÇA GRUBU</div>
                            <div class="summary-value">@modalSelectedDotPart</div>
                        </div>
                    }
                </div>
                <div class="summary-footer">
                     <button class="btn btn-search-action" @onclick="SubmitAsync" disabled="@(string.IsNullOrEmpty(modalSelectedManufacturer))">
                        <i class="fa-solid fa-magnifying-glass me-2"></i> ARA
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

