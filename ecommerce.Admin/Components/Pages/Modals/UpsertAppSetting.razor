@page "/upsert-app-setting"
@using ecommerce.Admin.Domain.Dtos.AppSettingDto
@attribute [Authorize]

<PageTitle>Ayar Ekle/Düzenle</PageTitle>

<div class="col-md-12">
    <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">@errorMessage</RadzenAlert>
    
    <RadzenTemplateForm TItem="AppSettingUpsertDto" Data="@dto" Visible="@(dto != null)" Submit="@FormSubmit">
        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-4">
                <RadzenLabel Text="Anahtar (Key)" Component="Key" style="width: 100%" />
            </div>
            <div class="col-md-8">
                <RadzenTextBox style="display: block; width: 100%" @bind-Value="@dto.Key" Name="Key" Disabled="@(dto.Id > 0)" />
                <RadzenRequiredValidator Component="Key" Text="Anahtar girmelisiniz" />
            </div>
        </div>

        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-4">
                <RadzenLabel Text="Değer (Value)" Component="Value" style="width: 100%" />
            </div>
            <div class="col-md-8">
                <RadzenTextArea style="display: block; width: 100%" @bind-Value="@dto.Value" Name="Value" Rows="5" />
                <RadzenRequiredValidator Component="Value" Text="Değer girmelisiniz" />
            </div>
        </div>

        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-4">
                <RadzenLabel Text="Açıklama" Component="Description" style="width: 100%" />
            </div>
            <div class="col-md-8">
                <RadzenTextBox style="display: block; width: 100%" @bind-Value="@dto.Description" Name="Description" />
            </div>
        </div>

        <div class="row">
            <div class="col d-flex justify-content-end" style="margin-top: 1rem">
                <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Kaydet" Style="margin-right: 0.5rem" Variant="Variant.Flat"  />
                <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Vazgeç" Variant="Variant.Flat" Click="@CancelButtonClick" />
            </div>
        </div>
    </RadzenTemplateForm>
</div>
