@using ecommerce.Admin.Domain.Dtos.CheckDto
@using ecommerce.Core.Utils
@using Radzen
@using Radzen.Blazor

@if (Model == null)
{
    <div class="d-flex justify-content-center p-4">
        <RadzenProgressBarCircular ShowValue="true" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
    </div>
}
else
{
    <RadzenTemplateForm Data="@Model" Submit="@(async (CheckUpsertDto _) => await FormSubmit())">
        <div class="check-modal">
            <div class="check-modal__header">
                <h6 class="check-modal__title">@(Model.Id == 0 || !Model.Id.HasValue ? "Yeni Çek" : "Çek Düzenle")</h6>
                <button type="button" class="check-modal__close" @onclick="@(() => DialogService.Close(false))" aria-label="Kapat">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="check-modal__body">
                <div class="check-modal__section">
                    <span class="check-modal__section-title">Cari & Banka</span>
                    <div class="check-modal__row">
                        <div class="check-modal__field check-modal__field--full">
                            <RadzenLabel Text="Cari" Component="CustomerId" class="small" />
                            <RadzenDropDown Name="CustomerId"
                                            @bind-Value="@Model.CustomerId"
                                            Data="@CustomerList"
                                            TextProperty="DisplayName"
                                            ValueProperty="Id"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            FilterOperator="StringFilterOperator.Contains"
                                            Style="width:100%"
                                            Placeholder="Cari seçiniz" />
                            <RadzenRequiredValidator Component="CustomerId" Text="Cari zorunludur" />
                        </div>
                    </div>
                    <div class="check-modal__row">
                        <div class="check-modal__field">
                            <RadzenLabel Text="Banka" Component="BankId" class="small" />
                            <RadzenDropDown Name="BankId"
                                            @bind-Value="@Model.BankId"
                                            Data="@BankList"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            Change="@OnBankChange"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Style="width:100%"
                                            Placeholder="Banka seçiniz" />
                            <RadzenRequiredValidator Component="BankId" Text="Banka zorunludur" />
                        </div>
                        <div class="check-modal__field">
                            <RadzenLabel Text="Şube (İl/İlçe)" Component="BankBranchId" class="small" />
                            <RadzenDropDown Name="BankBranchId"
                                            @bind-Value="@Model.BankBranchId"
                                            Data="@FilteredBankBranchList"
                                            TextProperty="DisplayText"
                                            ValueProperty="Id"
                                            AllowClear="true"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Style="width:100%"
                                            Placeholder="@(Model.BankId == 0 ? "Önce banka seçiniz" : "Şube seçiniz (opsiyonel)")"
                                            Disabled="@(Model.BankId == 0)" />
                        </div>
                    </div>
                </div>

                <div class="check-modal__section">
                    <span class="check-modal__section-title">Çek Bilgileri</span>
                    <div class="check-modal__row">
                        <div class="check-modal__field">
                            <RadzenLabel Text="Çek Numarası" Component="CheckNumber" class="small" />
                            <RadzenTextBox Name="CheckNumber"
                                           @bind-Value="@Model.CheckNumber"
                                           Style="width:100%"
                                           Placeholder="Boş bırakılırsa otomatik üretilir" />
                        </div>
                        <div class="check-modal__field">
                            <RadzenLabel Text="Tutar" Component="Amount" class="small" />
                            <RadzenNumeric Name="Amount"
                                           @bind-Value="@Model.Amount"
                                           Style="width:100%"
                                           Format="N2"
                                           Min="@((decimal?)0.01)"
                                           ShowUpDown="false" />
                            <RadzenRequiredValidator Component="Amount" Text="Tutar zorunludur" />
                        </div>
                    </div>
                    <div class="check-modal__row">
                        <div class="check-modal__field">
                            <RadzenLabel Text="Vade Tarihi" Component="DueDate" class="small" />
                            <RadzenDatePicker Name="DueDate"
                                              @bind-Value="@Model.DueDate"
                                              DateFormat="dd.MM.yyyy"
                                              Style="width:100%"
                                              Placeholder="Vade" />
                            <RadzenRequiredValidator Component="DueDate" Text="Vade zorunludur" />
                        </div>
                        <div class="check-modal__field">
                            <RadzenLabel Text="Döviz" Component="CurrencyId" class="small" />
                            <RadzenDropDown Name="CurrencyId"
                                            @bind-Value="@Model.CurrencyId"
                                            Data="@CurrencyOptions"
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            Style="width:100%"
                                            Placeholder="Döviz" />
                            <RadzenRequiredValidator Component="CurrencyId" Text="Döviz zorunludur" />
                        </div>
                    </div>
                </div>

                <div class="check-modal__section">
                    <span class="check-modal__section-title">Durum & Tarihler</span>
                    <div class="check-modal__row">
                        <div class="check-modal__field">
                            <RadzenLabel Text="Çek Durumu" Component="CheckStatus" class="small" />
                            <RadzenDropDown Name="CheckStatus"
                                            @bind-Value="@Model.CheckStatus"
                                            Data="@CheckStatusOptions"
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            Style="width:100%"
                                            Placeholder="Durum" />
                        </div>
                        <div class="check-modal__field">
                            <RadzenLabel Text="Alınış Tarihi (opsiyonel)" Component="ReceivedDate" class="small" />
                            <RadzenDatePicker Name="ReceivedDate"
                                              @bind-Value="@Model.ReceivedDate"
                                              DateFormat="dd.MM.yyyy"
                                              Style="width:100%"
                                              Placeholder="Alınış" />
                        </div>
                    </div>
                    <div class="check-modal__row">
                        <div class="check-modal__field">
                            <RadzenLabel Text="Tahsil/Red/İade Tarihi (opsiyonel)" Component="SettlementDate" class="small" />
                            <RadzenDatePicker Name="SettlementDate"
                                              @bind-Value="@Model.SettlementDate"
                                              DateFormat="dd.MM.yyyy"
                                              Style="width:100%"
                                              Placeholder="Tarih" />
                        </div>
                    </div>
                </div>

                <div class="check-modal__section">
                    <RadzenLabel Text="Açıklama (opsiyonel)" Component="Description" class="small" />
                    <RadzenTextArea Name="Description"
                                    @bind-Value="@Model.Description"
                                    Style="width:100%"
                                    Rows="2"
                                    Placeholder="Açıklama..." />
                </div>
            </div>

            <div class="check-modal__footer">
                <RadzenButton Text="Vazgeç" Click="@(() => DialogService.Close(false))" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Kaydet" ButtonStyle="ButtonStyle.Primary" Icon="save" IsBusy="@Saving" Size="ButtonSize.Small" />
            </div>
        </div>
    </RadzenTemplateForm>
}

<style>
    .check-modal {
        display: flex;
        flex-direction: column;
        max-height: 85vh;
        min-width: 480px;
    }
    .check-modal__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-bottom: 1px solid var(--rz-border-color, #e9ecef);
        flex-shrink: 0;
        background: var(--rz-base-50, #f8f9fa);
    }
    .check-modal__title {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
        color: var(--rz-text-color, #212529);
    }
    .check-modal__close {
        background: none;
        border: none;
        padding: 4px 8px;
        color: var(--rz-text-secondary-color, #6c757d);
        cursor: pointer;
        border-radius: 4px;
        line-height: 1;
    }
    .check-modal__close:hover {
        color: var(--rz-text-color);
        background: rgba(0,0,0,0.06);
    }
    .check-modal__body {
        padding: 12px 16px;
        overflow-y: auto;
        flex: 1 1 auto;
        min-height: 0;
    }
    .check-modal__section {
        margin-bottom: 14px;
    }
    .check-modal__section:last-of-type {
        margin-bottom: 0;
    }
    .check-modal__section-title {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--rz-text-secondary-color, #6c757d);
        margin-bottom: 6px;
    }
    .check-modal__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }
    .check-modal__field {
        min-width: 0;
    }
    .check-modal__field--full {
        grid-column: 1 / -1;
    }
    .check-modal__footer {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 12px 16px;
        border-top: 1px solid var(--rz-border-color, #e9ecef);
        flex-shrink: 0;
        background: var(--rz-base-50, #f8f9fa);
    }
</style>
