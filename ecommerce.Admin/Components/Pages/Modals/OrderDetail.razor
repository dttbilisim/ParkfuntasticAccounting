@page "/orderdetail"
@using ecommerce.Admin.Domain.Dtos.OrderDto;
@using ecommerce.Core.Entities;
@using ecommerce.Core.Utils;
@using ecommerce.Core.Helpers;
@using ecommerce.Admin.Domain.Dtos.SellerAddressDto;
@attribute [Authorize]
@inject IStringLocalizer<Culture_TR> Loc
<PageTitle>Sipariş Bilgileri</PageTitle>


<div class="col-md-12 order-detail-scope">

<RadzenTabs TabPosition="TabPosition.Top" class="w-100" RenderMode="TabRenderMode.Client" Change="@OnTabChange">
<Tabs>
<RadzenTabsItem Text="Sipariş Bilgileri">
    <RadzenFieldset Text="Sipariş Bilgileri">
        <RadzenTemplateForm TItem="OrderListDto" Data="@order" Visible="@(order != null)">

            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="Sipariş" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenTextBox class="rz-full-width" @bind-Value="@order!.OrderNumber" Name="OrderNumber" Disabled="true"/>
                </div>
            </div>

            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="Sipariş Durumu" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenDropDown TValue="OrderStatusType" Data="@(Enum.GetValues<OrderStatusType>())" Value="@order.OrderStatusType" ValueChanged="@UpdateOrderStatus" class="w-100" 
                                    AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
                </div>
            </div>

            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="Sipariş Tarihi" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenDatePicker class="rz-full-width" @bind-Value="@order.CreatedDate" Name="CreatedDate" Disabled="true"/>
                </div>
            </div>
            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="İndirim Tutarı" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenNumeric class="rz-full-width" @bind-Value="@order.DiscountTotal" Name="DiscountTotal" Disabled="true" Format="c"/>
                </div>
            </div>
            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="Sipariş Tutarı" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenNumeric class="rz-full-width" @bind-Value="@order.OrderTotal" Name="OrderTotal" Disabled="true" Format="c"/>
                </div>
            </div>

            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="Ödeme Tipi" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenNumeric class="rz-full-width" @bind-Value="@order.PaymentTypeId" Name="PaymentTypeId" Disabled="true"/>
                </div>
            </div>

            <div class="row rz-form-row">
                <div class="col-md-3">
                    <RadzenLabel Text="Ödeme Durumu" class="w-100"/>
                </div>
                <div class="col-md-9">
                    <RadzenTextBox class="rz-full-width" Value="@order.PaymentStatusResult" Disabled="true"/>
                </div>
            </div>
              @if(order.IyzicoCancelDate != null){
                <div class="row rz-form-row">
                    <div class="col-md-3">
                        <RadzenLabel Text="Ödeme İptal Tarihi" class="w-100"/>
                    </div>
                    <div class="col-md-9">
                        <RadzenDatePicker class="rz-full-width" @bind-Value="@order.IyzicoCancelDate" Name="ShipmentDate" Disabled="true"/>
                    </div>
                </div>
                <div class="row rz-form-row">
                    <div class="col-md-3">
                        <RadzenLabel Text="Ödeme İptal Mesajı" class="w-100"/>
                    </div>
                    <div class="col-md-9">
                        <RadzenTextBox class="rz-full-width" Value="@order.IyzicoCanceledMessage" Disabled="true"/>
                    </div>
                </div>
            }
          


            <div class="row">
                <div class="col d-flex justify-content-end mt-3">
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Vazgeç" Variant="Variant.Flat" Click="@CancelButtonClick"/>
                </div>
            </div>
        </RadzenTemplateForm>
    </RadzenFieldset>

</RadzenTabsItem>


<RadzenTabsItem Text="Ürün Bilgileri">
    <div class="tab-flex-container">
        <div class="fieldset-header-container p-3">
            <span class="fieldset-header-title">
                <RadzenIcon Icon="inventory_2" class="fieldset-header-icon text-primary" />
                Ürün Bilgileri
            </span>
        </div>

        <div class="grid-wrapper">
            <RadzenDataGrid @ref="radzenDataGrid"
                AllowFiltering="true"
                FilterMode="FilterMode.Simple"
                AllowPaging="false"
                AllowSorting="false"
                Density="Density.Compact"
                RenderMode="TabRenderMode.Client"
                TItem="OrderItemViewModel"
                Data="orderitemsGrouped"
                Count="@count"
                Style="flex: 1;"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                EqualsText="@Loc.GetString("EqualsText")"
                NotEqualsText="@Loc.GetString("NotEqualsText")"
                LessThanText="@Loc.GetString("LessThanText")"
                LessThanOrEqualsText="@Loc.GetString("LessThanOrEqualsText")"
                GreaterThanText="@Loc.GetString("GreaterThanText")"
                GreaterThanOrEqualsText="@Loc.GetString("GreaterThanOrEqualsText")"
                IsNullText="@Loc.GetString("IsNullText")"
                IsNotNullText="@Loc.GetString("IsNotNullText")"
                ApplyFilterText="@Loc.GetString("ApplyFilterText")"
                ClearFilterText="@Loc.GetString("ClearFilterText")">
                <Columns>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Ürün Id" Property="Item.ProductId" Width="80px" Filterable="false"/>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Ürün Adı" Property="Item.ProductName" Filterable="false"/>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Adet" Property="Item.Quantity" Filterable="false" Width="50px"/>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Birim Fiyatı" Property="Item.Price" Filterable="false" Width="100px">
                    <Template Context="vm">
                        <span class="price-val">@CurrencyHelper.FormatPrice(vm.Item.Price)</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Toplam Fiyatı" Property="Item.TotalPrice" Filterable="false" Width="120px">
                    <Template Context="vm">
                        <span class="price-val">@CurrencyHelper.FormatPrice(vm.Item.TotalPrice)</span>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
            </RadzenDataGrid>
                </div>

                @if (order != null)
                {
                    <div class="order-summary-footer">
                        <div class="summary-content">
                            <div class="summary-line">
                                <span class="sum-label">Alt Toplam</span>
                                <span class="price-val">@CurrencyHelper.FormatPrice(order.ProductTotal)</span>
                            </div>
                            <div class="summary-line discount">
                                <span class="sum-label">İndirim Toplamı</span>
                                <span class="price-val">@CurrencyHelper.FormatPrice(order.DiscountTotal ?? 0)</span>
                            </div>
                            <div class="summary-line grand-total">
                                <span class="sum-label">Toplam</span>
                                <span class="price-val">@CurrencyHelper.FormatPrice(order.GrandTotal)</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </RadzenTabsItem>

<RadzenTabsItem Text="Tedarikci Depo">
    <div class="tab-flex-container">
        <div class="fieldset-header-container p-3 d-flex align-items-center justify-content-between">
            <span class="fieldset-header-title mb-0">
                <RadzenIcon Icon="warehouse" class="fieldset-header-icon text-warning mr-2" />
                Tedarikci Depo
            </span>
            <div class="d-flex gap-2">
                <RadzenButton Click="@CheckStocks" 
                               Text="Depo Stoklarını Kontrol Et" 
                               Icon="refresh" 
                               ButtonStyle="ButtonStyle.Success" 
                               Variant="Variant.Flat" 
                               IsBusy="@_isCheckingStocks"
                               class="btn-stock-update-small rounded-pill" />
                
                <RadzenButton Click="@CreateSupplierOrder" 
                               Text="@(IsSupplierOrderCreated ? "Sipariş Oluşturuldu" : "Tedarikçi Siparişi Oluştur")" 
                               Icon="@(IsSupplierOrderCreated ? "done_all" : "assignment_turned_in")" 
                               ButtonStyle="@(IsSupplierOrderCreated ? ButtonStyle.Success : ButtonStyle.Info)" 
                               Variant="Variant.Flat" 
                               IsBusy="@_isAddingToCart"
                               Disabled="@((order?.Seller?.Id != 1 && order?.Seller?.Id != 3 && order?.Seller?.Id != 4) || IsSupplierOrderCreated)"
                               class="btn-stock-update-small rounded-pill" />
                
                @if (order?.Seller?.Id == 1 && IsSupplierOrderCreated)
                {
                    <RadzenButton Click="@CancelSupplierOrder" 
                               Text="Siparişi İptal Et" 
                               Icon="cancel" 
                               ButtonStyle="ButtonStyle.Danger" 
                               Variant="Variant.Flat" 
                               class="btn-stock-update-small rounded-pill ml-2" />
                }
            </div>
        </div>

        <div class="grid-wrapper">
            <RadzenDataGrid @ref="radzenDataGrid"
                AllowFiltering="true"
                FilterMode="FilterMode.Simple"
                AllowPaging="false"
                AllowSorting="false"
                Density="Density.Compact"
                RenderMode="TabRenderMode.Client"
                TItem="OrderItemViewModel"
                LoadData="@LoadData"
                Data="orderitemsGrouped"
                Count="@count"
                Style="flex: 1;"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                ExpandMode="DataGridExpandMode.Single"
                RowSelect="@(args => radzenDataGrid.ExpandRow(args))"
                EqualsText="@Loc.GetString("EqualsText")"
                NotEqualsText="@Loc.GetString("NotEqualsText")"
                LessThanText="@Loc.GetString("LessThanText")"
                LessThanOrEqualsText="@Loc.GetString("LessThanOrEqualsText")"
                GreaterThanText="@Loc.GetString("GreaterThanText")"
                GreaterThanOrEqualsText="@Loc.GetString("GreaterThanOrEqualsText")"
                IsNullText="@Loc.GetString("IsNullText")"
                IsNotNullText="@Loc.GetString("IsNotNullText")"
                ApplyFilterText="@Loc.GetString("ApplyFilterText")"
                ClearFilterText="@Loc.GetString("ClearFilterText")">
                <GroupHeaderTemplate>
                    <div class="cargo-group-header">
                        <div class="cargo-icon-wrapper">
                            <i class="fa-solid fa-box" style="color: #10b981; font-size: 18px;"></i>
                        </div>
                        <span class="cargo-group-title">@context.Data!.Key</span>
                        <span class="cargo-group-count">(@context.Data.Count ürün)</span>
                    </div>
                </GroupHeaderTemplate>
                <Columns>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Ürün Id" Property="Item.ProductId" Width="80px" Filterable="false"/>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Ürün Adı" Property="Item.ProductName" Filterable="false"/>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Adet" Property="Item.Quantity" Filterable="false" Width="50px"/>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Birim Fiyatı" Property="Item.Price" Filterable="false" Width="100px">
                    <Template Context="vm">
                        <span class="price-val">@CurrencyHelper.FormatPrice(vm.Item.Price)</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Toplam Fiyatı" Property="Item.TotalPrice" Filterable="false" Width="120px">
                    <Template Context="vm">
                        <span class="price-val">@CurrencyHelper.FormatPrice(vm.Item.TotalPrice)</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="Depo Stoğu" Filterable="false" Width="220px">
                    <Template Context="vm">
                        @{ 
                            var stockInfo = "";
                            var hasStockInfo = ItemStocks != null && ItemStocks.TryGetValue(vm.Item.Id, out stockInfo) && !string.IsNullOrEmpty(stockInfo);
                        }

                        @if (hasStockInfo)
                        {
                            @if (stockInfo == "Stok Yok" || vm.AssignedWH == "Stok Yok")
                            {
                                <div class="stock-status-empty">
                                    <span class="status-dot bg-danger-dot"></span>
                                    Stok Yok
                                </div>
                            }
                            else
                            {
                                <div class="stock-container">
                                    @{
                                        // Eşleşen depoyu bul
                                        string? matchedWhInfo = null;
                                        SellerAddressListDto? matchedAddress = null;
                                        string? matchedFriendlyName = null;
                                        bool isMatchFound = false;

                                        if (!string.IsNullOrEmpty(vm.AssignedWH) && vm.AssignedWH != "API'de Mevcut" && vm.AssignedWH != "Atanmadı")
                                        {
                                            var warehouses = stockInfo?.Split(new[] { ',', '|' }, StringSplitOptions.RemoveEmptyEntries);
                                            
                                            // Önceden hesapla ve sadece sonucu render et
                                            if (warehouses != null)
                                            {
                                                foreach (var WH in warehouses)
                                                {
                                                    var parts = WH.Split(':');
                                                    var whName = parts[0].Trim();
                                                    var address = GetSellerAddressByWH(whName);
                                                    var friendlyName = address != null && !string.IsNullOrEmpty(address.Title) ? address.Title : (whName + " (Tanımsız)");

                                                    if (friendlyName.Equals(vm.AssignedWH, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        matchedWhInfo = WH;
                                                        matchedAddress = address;
                                                        matchedFriendlyName = friendlyName;
                                                        isMatchFound = true;
                                                        break; // Render tree dışında break kullanımı güvenlidir
                                                    }
                                                }
                                            }
                                        }

                                        if (isMatchFound && !string.IsNullOrEmpty(matchedWhInfo))
                                        {
                                            var parts = matchedWhInfo.Split(':');
                                            var definitionMissing = matchedAddress == null;
                                            
                                            <div class="stock-item-wrapper">
                                                <div class="stock-row">
                                                    <span class="wh-name-v2 @(definitionMissing ? "text-warning" : "")">@matchedFriendlyName</span>
                                                    @if (definitionMissing)
                                                    {
                                                        <i class="fa fa-triangle-exclamation text-warning ml-1" title="Depo tanımı yapılmamış"></i>
                                                    }
                                                    @if (parts.Length > 1)
                                                    {
                                                        <span class="wh-count-v2">@parts[1].Trim()</span>
                                                    }
                                                </div>
                                                @if (matchedAddress != null)
                                                {
                                                    <RadzenButton Icon="info" 
                                                                    ButtonStyle="ButtonStyle.Info" 
                                                                    Size="ButtonSize.ExtraSmall" 
                                                                    Variant="Variant.Text" 
                                                                    Click="@(() => ShowAddressDetail(matchedAddress))" 
                                                                    class="wh-info-btn"
                                                                    Tooltip="@matchedAddress.Title" />
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            // Eşleşme yoksa ham veriyi göster
                                            <div class="stock-info-text">
                                                <i class="fa fa-info-circle mr-1 text-info"></i>
                                                <span class="text-wrap">@stockInfo</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                        else if (_isCheckingStocks)
                        {
                            <div class="status-placeholder text-center">
                                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.ExtraSmall" />
                            </div>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderItemViewModel" Title="AssignedWH" Property="AssignedWH" Visible="false" />
            </Columns>
            </RadzenDataGrid>
                </div>

                @if (order != null)
                {
                    <div class="order-summary-footer">
                        <div class="summary-content">
                            <div class="summary-line">
                                <span class="sum-label">Alt Toplam</span>
                                <span class="price-val">@CurrencyHelper.FormatPrice(order.ProductTotal)</span>
                            </div>
                            <div class="summary-line discount">
                                <span class="sum-label">İndirim Toplamı</span>
                                <span class="price-val">@CurrencyHelper.FormatPrice(order.DiscountTotal ?? 0)</span>
                            </div>
                            <div class="summary-line grand-total">
                                <span class="sum-label">Toplam</span>
                                <span class="price-val">@CurrencyHelper.FormatPrice(order.GrandTotal)</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </RadzenTabsItem>


<RadzenTabsItem Text="Satıcı Bilgileri">
    <RadzenFieldset Text="Satıcı Bilgileri">
        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="Satıcı Adı" class="w-100"/>
            </div>
            <div class="col-md-9">
                @if (order?.Seller != null)
                {
                    <RadzenTextBox class="rz-full-width" Value="@order.Seller.Name" Disabled="true"/>
                }
            </div>
        </div>
        
        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="İl" Component="CityId" class="w-100"/>
            </div>
            <div class="col-md-9">
                @if (SellerCompany != null)
                {
                    <RadzenDropDownDataGrid Data="@Sellercities" TextProperty="Name" ValueProperty="Id" Placeholder="Seçiniz" class="rz-full-width" @bind-Value="@SellerCompany.CityId" Name="CityId" Disabled FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowFiltering="true"/>
                }
            </div>
        </div>

        <div class="row rz-form-row">
            <div class="col-md-3">
                <RadzenLabel Text="İlçe" Component="TownId" class="w-100"/>
