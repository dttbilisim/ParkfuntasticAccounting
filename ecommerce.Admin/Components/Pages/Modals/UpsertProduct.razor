<RadzenTabsItem Text="Görsel Bilgileri">

    <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Medium" AlertStyle="AlertStyle.Warning" Visible="@IsProductSaved">Önce ürün kaydetmelisiniz!</RadzenAlert>


    <div style="width: 100%; overflow: hidden;" class="mb-2">
        <div style="float:right">
            <RadzenButton Icon="add_circle_outline" Text="Görsel Ekle" Variant="Variant.Flat" Click="AddProductImageButtonClick" class="mt-2" Visible="@isShowSaveThenProductPanels"/>
        </div>
    </div>

    <RadzenDataGrid @ref="radzenDataGridProductImage"
                    AllowFiltering="false"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    AllowSorting="false"
                    AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    ShowPagingSummary="false"
                    RowSelect="EditRowProductImage"
                    Data="@productImages"
                    TItem="ProductImageListDto"
                    ColumnWidth="300px"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    PageSize="10"
                    RowRender="RowRenderForImage">
        <Columns>
            <RadzenDataGridColumn TItem="ProductImageListDto" Title="Id" Property="Id" Width="50px"/>
            <RadzenDataGridColumn TItem="ProductImageListDto" Title="Sıra No." Property="Order" Width="50px"/>
            <RadzenDataGridColumn TItem="ProductImageListDto" Title="Görsel" Width="70px">
                <Template Context="productImage">
                    @if(productImage.FileName != null){
                        if(productImage.FileName.Contains(".png") == true){
                            <RadzenImage Path="@($"data:image/png;base64,{Convert.ToBase64String(productImage.Base64Str)}")" Style="width: 2rem;"/>
                        }
                        if(productImage.FileName.Contains(".webp") == true){
                            <RadzenImage Path="@($"data:image/webp;base64,{Convert.ToBase64String(productImage.Base64Str)}")" Style="width: 2rem;"/>
                        } else
                            if(productImage.FileName.Contains(".jpeg") == true || productImage.FileName.Contains(".jpg") == true){
                                <RadzenImage Path="@($"data:image/jpeg;base64,{Convert.ToBase64String(productImage.Base64Str)}")" Style="width: 2rem;"/>
                            } else
                                if(productImage.FileName.Contains(".gif") == true){
                                    <RadzenImage Path="@($"data:image/gif;base64,{Convert.ToBase64String(productImage.Base64Str)}")" Style="width: 2rem;"/>
                                }
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ProductImageListDto" Title="Dosya Adı" Property="FileName"/>
            <RadzenDataGridColumn TItem="ProductImageListDto" Title="Durum" Property="StatusStr" Width="100px"/>
            <RadzenDataGridColumn TItem="ProductImageListDto" Title="Aksiyon" Width="40px" TextAlign="TextAlign.Center">
                <Template Context="productImage">
                    @if(productImage.Status != EntityStatus.Deleted){
                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall"
                                      Shade="Shade.Dark" Variant="Variant.Flat"
                                      Click=@(args => GridDeleteProductImageButtonClick(args, productImage)) @onclick:stopPropagation="true"/>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenTabsItem>

<RadzenTabsItem Text="Depo/Stok Konumu">
     <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Medium" AlertStyle="AlertStyle.Warning" Visible="@IsProductSaved">Önce ürün kaydetmelisiniz!</RadzenAlert>

    <div style="width: 100%; overflow: hidden;" class="mb-2">
        <div style="float:right">
            <RadzenButton Icon="add_circle_outline" Text="Stok Konumu Ekle" Variant="Variant.Flat" Click="AddProductStockButtonClick" class="mt-2" Visible="@isShowSaveThenProductPanels"/>
        </div>
    </div>

    <RadzenDataGrid @ref="radzenDataGridProductStock"
                    AllowFiltering="false"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    AllowSorting="false"
                    AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    ShowPagingSummary="false"
                    RowSelect="@EditRowProductStock"
                    Data="@productStocks"
                    TItem="ProductStockListDto"
                    ColumnWidth="300px"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    PageSize="10">
        <Columns>
            <RadzenDataGridColumn TItem="ProductStockListDto" Title="Id" Property="Id" Width="50px"/>
            <RadzenDataGridColumn TItem="ProductStockListDto" Title="Depo" Property="ShelfWarehouseName" Width="150px"/>
            <RadzenDataGridColumn TItem="ProductStockListDto" Title="Raf Kodu" Property="ShelfCode" Width="100px"/>
             <RadzenDataGridColumn TItem="ProductStockListDto" Title="Adet" Property="Quantity" Width="80px"/>
            <RadzenDataGridColumn TItem="ProductStockListDto" Title="Durum" Property="Status" Width="100px">
                 <Template Context="item">
                        @if (item.Status == (int)EntityStatus.Deleted)
                        {
                            <RadzenText style="color:red;">Pasif</RadzenText>
                        }
                        else
                        {
                            <RadzenText style="color:#598087;">Aktif</RadzenText>
                        }
                    </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ProductStockListDto" Title="Aksiyon" Width="60px" TextAlign="TextAlign.Center">
                <Template Context="stock">
                    
                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall"
                                      Shade="Shade.Dark" Variant="Variant.Flat"
                                      Click=@(args => GridDeleteProductStockButtonClick(args, stock)) @onclick:stopPropagation="true"/>
                    
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenTabsItem>
<RadzenTabsItem Text="Birim Tanımları">
    <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Medium" AlertStyle="AlertStyle.Warning" Visible="@IsProductSaved">Önce ürün kaydetmelisiniz!</RadzenAlert>

    <div style="width: 100%; overflow: hidden;" class="mb-2">
        <div style="float:right">
            <RadzenButton Icon="add_circle_outline" Text="Birim Ekle" Variant="Variant.Flat" Click="AddProductUnitButtonClick" class="mt-2" Visible="@isShowSaveThenProductPanels"/>
        </div>
    </div>

    <RadzenDataGrid @ref="radzenDataGridProductUnit"
                    AllowFiltering="false"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    AllowSorting="false"
                    AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    ShowPagingSummary="false"
                    RowSelect="@EditRowProductUnit"
                    Data="@productUnits"
                    TItem="ProductUnitListDto"
                    ColumnWidth="300px"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    PageSize="10">
        <Columns>
            <RadzenDataGridColumn TItem="ProductUnitListDto" Title="Id" Property="Id" Width="60px"/>
            <RadzenDataGridColumn TItem="ProductUnitListDto" Title="Birim" Property="UnitName" Width="150px"/>
            <RadzenDataGridColumn TItem="ProductUnitListDto" Title="Barkod" Property="Barcode" Width="150px"/>
            <RadzenDataGridColumn TItem="ProductUnitListDto" Title="Birim Değeri" Property="UnitValue" Width="100px"/>
            <RadzenDataGridColumn TItem="ProductUnitListDto" Title="Aksiyon" Width="60px" TextAlign="TextAlign.Center">
                <Template Context="unit">
                    <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall"
                                  Shade="Shade.Dark" Variant="Variant.Flat"
                                  Click=@(args => GridDeleteProductUnitButtonClick(args, unit)) @onclick:stopPropagation="true"/>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenTabsItem>

