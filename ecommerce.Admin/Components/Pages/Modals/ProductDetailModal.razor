@using ecommerce.Domain.Shared.Dtos.Product
@using ecommerce.Admin.Services.Interfaces
@using ecommerce.Web.Domain.Dtos.Cart
@using ecommerce.Web.Domain.Services.Abstract
@using Radzen
@using Radzen.Blazor
@inject ICartStateService CartStateService
@inject ecommerce.Web.Domain.Services.Abstract.ICartService CartService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject ecommerce.Admin.Services.AuthenticationService Security
@implements IDisposable

<div class="product-detail-modal-wrapper">
    <div class="vehicle-modal-header p-4 border-bottom shadow-sm">
        <div class="d-flex align-items-center justify-content-between w-100">
            <div>
                <h5 class="mb-1 fw-bold fs-4"><i class="fa-solid fa-box-open me-2"></i>Ürün Detayı</h5>
                <small class="text-white-50">@Product.ManufacturerName - @Product.PartNumber</small>
            </div>
            <button class="btn btn-sm btn-light rounded-circle shadow-sm" style="width: 32px; height: 32px;" @onclick="Close">
                <i class="fa-solid fa-xmark text-success"></i>
            </button>
        </div>
    </div>
    <div class="vehicle-modal-body p-0 bg-white" style="max-height: 80vh; overflow-y: auto;">
                <div class="p-3 bg-white">
                    <div class="row g-3">
                        <!-- Left Column: Image Only -->
                        <div class="col-md-3">
                            <div class="text-center">
                                <img src="@ResolveSearchImage(Product)" 
                                     class="img-fluid" 
                                     style="max-height: 120px; max-width: 100%; object-fit: contain;"
                                     onerror="this.onerror=null; this.src='/images/no-photo.png';" />
                            </div>
                        </div>
                        
                        <!-- Right Column: Product Info -->
                        <div class="col-md-9">
                            <h5 class="mb-2 fw-bold text-dark" style="font-size: 1rem;">@Product.ProductName</h5>
                            
                            <div class="product-info-card mb-2" style="padding: 0.75rem;">
                                <div class="d-flex flex-column gap-2 mb-2">
                                    <div class="d-flex justify-content-between border-bottom pb-1">
                                        <span class="text-muted" style="font-size: 0.8rem;">Marka</span>
                                        <span class="fw-bold text-dark" style="font-size: 0.85rem;">@Product.ManufacturerName</span>
                                    </div>
                                    <div class="d-flex justify-content-between border-bottom pb-1">
                                        <span class="text-muted" style="font-size: 0.8rem;">Orjinal Oem No</span>
                                        <span class="fw-bold text-dark" style="font-size: 0.85rem;">@Product.PartNumber</span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center justify-content-between mt-2">
                                    <div class="d-flex flex-column">
                                        <span class="small text-muted mb-1" style="font-size: 0.7rem;">Satış Fiyatı</span>
                                        <div class="product-price-badge" style="padding: 0.4rem 0.8rem; font-size: 1rem;">
                                            @Product.SalePrice.ToString("N2") <span class="small">@Product.Currency</span>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-column align-items-end">
                                         <span class="small text-muted mb-1" style="font-size: 0.7rem;">Stok Durumu</span>
                                         @if (IsPlasiyer())
                                         {
                                             @if(Product.Stock > 0)
                                             {
                                                 <span class="product-stock-badge in-stock" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;">
                                                     <i class="fa-solid fa-check-circle me-1"></i> Stokta (@Product.Stock)
                                                 </span>
                                             }
                                             else
                                             {
                                                 <span class="product-stock-badge out-stock" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;">
                                                     <i class="fa-solid fa-times-circle me-1"></i> Tükendi (0)
                                                 </span>
                                             }
                                         }
                                         else
                                         {
                                             @if(Product.Stock > 0)
                                             {
                                                 <span class="product-stock-badge in-stock" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;">
                                                     <i class="fa-solid fa-check-circle me-1"></i> Stokta
                                                 </span>
                                             }
                                             else
                                             {
                                                 <span class="product-stock-badge out-stock" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;">
                                                     <i class="fa-solid fa-times-circle me-1"></i> Tükendi
                                                 </span>
                                             }
                                         }
                                    </div>
                                </div>
                                
                                <!-- Add to Cart Section for Main Product -->
                                <div class="border-top mt-3 pt-3">
                                    @{
                                        var currentCartMain = CartStateService.CurrentCart;
                                        var mainProductInCart = currentCartMain?.Sellers?
                                            .SelectMany(s => s.Items)
                                            .Any(i => i.ProductSellerItemId == Product.SellerItemId) ?? false;
                                        var mainProductQty = mainProductInCart 
                                            ? (currentCartMain?.Sellers?
                                                .SelectMany(s => s.Items)
                                                .FirstOrDefault(i => i.ProductSellerItemId == Product.SellerItemId)?.Quantity ?? 1)
                                            : 1;
                                        var mainProductLoading = loadingItems.Contains(Product.SellerItemId);
                                    }
                                    @if (mainProductInCart)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <label class="small text-muted mb-0" style="font-size: 0.75rem;">Miktar:</label>
                                            <div class="d-flex align-items-center gap-1">
                                                <button class="btn btn-sm btn-outline-secondary" style="width: 28px; height: 28px; padding: 0;" 
                                                        @onclick="@(async () => await UpdateQuantity(Product.SellerItemId, mainProductQty - 1))"
                                                        disabled="@mainProductLoading">
                                                    @if (mainProductLoading)
                                                    {
                                                        <span class="spinner-border spinner-border-sm" style="width: 0.7rem; height: 0.7rem;"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-minus" style="font-size: 0.7rem;"></i>
                                                    }
                                                </button>
                                                <input type="number" 
                                                       class="form-control form-control-sm text-center" 
                                                       style="width: 60px; height: 28px; font-size: 0.8rem;"
                                                       value="@mainProductQty"
                                                       @onchange="@(async (ChangeEventArgs e) => { if (int.TryParse(e.Value?.ToString(), out int qty) && qty >= 0) await UpdateQuantity(Product.SellerItemId, qty); })"
                                                       min="0"
                                                       disabled="@mainProductLoading" />
                                                <button class="btn btn-sm btn-outline-secondary" style="width: 28px; height: 28px; padding: 0;" 
                                                        @onclick="@(async () => await UpdateQuantity(Product.SellerItemId, mainProductQty + 1))"
                                                        disabled="@mainProductLoading">
                                                    @if (mainProductLoading)
                                                    {
                                                        <span class="spinner-border spinner-border-sm" style="width: 0.7rem; height: 0.7rem;"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-plus" style="font-size: 0.7rem;"></i>
                                                    }
                                                </button>
                                            </div>
                                            <span class="badge bg-success small ms-auto">
                                                <i class="fa-solid fa-check me-1"></i>Sepette
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success btn-sm w-100" 
                                                @onclick="@(async () => await AddToCart(Product.SellerItemId))"
                                                disabled="@(Product.Stock <= 0 || mainProductLoading)">
                                            @if (mainProductLoading)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2"></span>
                                                <span>Ekleniyor...</span>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-cart-plus me-2"></i>
                                                <span>Sepete Ekle</span>
                                            }
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- OEMs List - Full Width Below -->
                    @if (Product.OemCode != null && Product.OemCode.Any())
                    {
                        <div class="border-top pt-3 mt-3">
                            <div class="text-muted mb-2 fw-bold small">OEM Kodları:</div>
                            <div class="border rounded p-3 bg-light" style="max-height: 150px; overflow-y: auto;">
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var oem in Product.OemCode)
                                    {
                                        <span class="badge bg-secondary text-start" style="font-size: 0.75rem; white-space: nowrap; font-weight: normal;">@oem</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Accordion Section - Compact -->
                <div class="px-3 pb-3">
                    <RadzenAccordion Multiple="true">
                        <Items>
                            @if (!string.IsNullOrEmpty(Product.ProductDescription))
                            {
                                <RadzenAccordionItem Text="Ürün Açıklaması" Icon="description" Selected="false">
                                    <div class="text-muted small lh-lg p-2" style="font-size: 0.8rem;">
                                        @((MarkupString)Product.ProductDescription)
                                    </div>
                                </RadzenAccordionItem>
                            }

                            <RadzenAccordionItem Text="Uyumlu Araçlar" Icon="directions_car">
                                 @if (Product.SubModelsJson != null && Product.SubModelsJson.Any())
                                 {
                                     <div class="row g-2 p-2">
                                         @foreach (var v in Product.SubModelsJson)
                                         {
                                             <div class="col-md-6">
                                                 <div class="p-3 border rounded bg-white shadow-sm d-flex align-items-center">
                                                     <i class="fa-solid fa-car text-success me-3 fs-5"></i>
                                                     <div>
                                                         <div class="fw-bold text-dark small">@($"{Product.ManufacturerName} {Product.BaseModelName}")</div>
                                                         <div class="text-muted small">@v.Name</div>
                                                     </div>
                                                 </div>
                                             </div>
                                         }
                                     </div>
                                 }
                                 else
                                 {
                                     <div class="text-center p-3 text-muted">Uyumlu araç bilgisi bulunamadı.</div>
                                 }
                            </RadzenAccordionItem>

                            <RadzenAccordionItem Text="Muadil Ürünler" Icon="compare_arrows">
                                 @if (SimilarProducts.Any())
                                 {
                                     <div class="d-flex flex-column gap-2 p-2">
                                         @foreach (var sim in SimilarProducts)
                                         {
                                             var currentCartForSimilar = CartStateService.CurrentCart;
                                             var similarInCart = currentCartForSimilar?.Sellers?
                                                 .SelectMany(s => s.Items)
                                                 .Any(i => i.ProductSellerItemId == sim.SellerItemId) ?? false;
                                             var similarQty = similarInCart 
                                                 ? (currentCartForSimilar?.Sellers?
                                                     .SelectMany(s => s.Items)
                                                     .FirstOrDefault(i => i.ProductSellerItemId == sim.SellerItemId)?.Quantity ?? 1)
                                                 : 1;
                                             var similarLoading = loadingItems.Contains(sim.SellerItemId);
                                             <div class="d-flex align-items-center p-3 border rounded bg-white similar-product-card" @onclick:stopPropagation="true">
                                                 <div style="width: 50px; height: 50px; flex-shrink: 0;" class="me-3 p-1 border rounded bg-white d-flex align-items-center justify-content-center">
                                                     <img src="@ResolveSearchImage(sim)" 
                                                          alt="@sim.ProductName" 
                                                          style="width: 100%; height: 100%; object-fit: contain;"
                                                          onerror="this.onerror=null; this.src='/images/no-photo.png';" />
                                                 </div>
                                                 <div class="flex-grow-1">
                                                     <div class="fw-bold text-dark small mb-1">@sim.ProductName</div>
                                                     <div class="d-flex text-muted x-small gap-3 flex-wrap">
                                                         <span><i class="fa-solid fa-hashtag me-1"></i>@sim.PartNumber</span>
                                                         @if (IsPlasiyer())
                                                         {
                                                             <span><i class="fa-solid fa-cube me-1"></i>Stok: @sim.Stock</span>
                                                         }
                                                         else
                                                         {
                                                             <span><i class="fa-solid fa-cube me-1"></i>Stok: @(sim.Stock > 0 ? "Stokta" : "Tükendi")</span>
                                                         }
                                                     </div>
                                                 </div>
                                                 <div class="text-end me-3">
                                                     <div class="fw-bold text-success fs-5 mb-2">@sim.SalePrice.ToString("N2") @sim.Currency</div>
                                                     @if (similarInCart)
                                                     {
                                                         <div class="d-flex align-items-center gap-1 justify-content-end mb-2">
                                                             <button class="btn btn-sm btn-outline-secondary" style="width: 24px; height: 24px; padding: 0; font-size: 0.7rem;" 
                                                                     @onclick="@(async () => await UpdateQuantity(sim.SellerItemId, similarQty - 1))"
                                                                     disabled="@similarLoading">
                                                                 @if (similarLoading)
                                                                 {
                                                                     <span class="spinner-border spinner-border-sm" style="width: 0.6rem; height: 0.6rem;"></span>
                                                                 }
                                                                 else
                                                                 {
                                                                     <i class="fa-solid fa-minus"></i>
                                                                 }
                                                             </button>
                                                             <input type="number" 
                                                                    class="form-control form-control-sm text-center" 
                                                                    style="width: 50px; height: 24px; font-size: 0.75rem;"
                                                                    value="@similarQty"
                                                                    @onchange="@(async (ChangeEventArgs e) => { if (int.TryParse(e.Value?.ToString(), out int qty) && qty >= 0) await UpdateQuantity(sim.SellerItemId, qty); })"
                                                                    min="0"
                                                                    disabled="@similarLoading" />
                                                             <button class="btn btn-sm btn-outline-secondary" style="width: 24px; height: 24px; padding: 0; font-size: 0.7rem;" 
                                                                     @onclick="@(async () => await UpdateQuantity(sim.SellerItemId, similarQty + 1))"
                                                                     disabled="@similarLoading">
                                                                 @if (similarLoading)
                                                                 {
                                                                     <span class="spinner-border spinner-border-sm" style="width: 0.6rem; height: 0.6rem;"></span>
                                                                 }
                                                                 else
                                                                 {
                                                                     <i class="fa-solid fa-plus"></i>
                                                                 }
                                                             </button>
                                                         </div>
                                                         <span class="badge bg-success small">
                                                             <i class="fa-solid fa-check me-1"></i>Sepette
                                                         </span>
                                                     }
                                                     else
                                                     {
                                                         <button class="btn btn-success btn-sm" 
                                                                 @onclick="@(async () => await AddToCart(sim.SellerItemId))"
                                                                 disabled="@(sim.Stock <= 0 || similarLoading)">
                                                             @if (similarLoading)
                                                             {
                                                                 <span class="spinner-border spinner-border-sm me-1" style="width: 0.7rem; height: 0.7rem;"></span>
                                                                 <span>Ekleniyor...</span>
                                                             }
                                                             else
                                                             {
                                                                 <i class="fa-solid fa-cart-plus me-1"></i>
                                                                 <span>Sepete Ekle</span>
                                                             }
                                                         </button>
                                                     }
                                                 </div>
                                             </div>
                                         }
                                     </div>
                                 }
                                 else
                                 {
                                     <div class="text-center p-3 text-muted">Muadil ürün bulunamadı.</div>
                                 }
                            </RadzenAccordionItem>
                        </Items>
                    </RadzenAccordion>

                </div>
    </div>
</div>

@code {
    [Parameter] public SellerProductViewModel Product { get; set; } = null!;
    [Parameter] public List<SellerProductViewModel> SimilarProducts { get; set; } = new();
    
    private HashSet<int> loadingItems = new();
    
    private bool IsPlasiyer()
    {
        return Security?.User?.Roles.Any(r => r.Name == "Plasiyer") ?? false;
    }
    
    protected override void OnInitialized()
    {
        CartStateService.OnChange += OnCartChanged;
    }
    
    public void Dispose()
    {
        CartStateService.OnChange -= OnCartChanged;
    }
    
    private async void OnCartChanged()
    {
        await InvokeAsync(StateHasChanged);
    }
    
    private void Close()
    {
        DialogService.Close();
    }
    
    private async Task AddToCart(int productSellerItemId)
    {
        if (loadingItems.Contains(productSellerItemId)) return;
        
        loadingItems.Add(productSellerItemId);
        StateHasChanged();
        
        try
        {
            var currentCart = CartStateService.CurrentCart;
            int currentCartQty = currentCart?.Sellers?
                .SelectMany(s => s.Items)
                .FirstOrDefault(i => i.ProductSellerItemId == productSellerItemId)?.Quantity ?? 0;
            
            int targetQty = 1;
            int delta = targetQty - currentCartQty;

            if (delta == 0)
            {
                loadingItems.Remove(productSellerItemId);
                StateHasChanged();
                return;
            }

            var req = new CartItemUpsertDto 
            { 
                ProductSellerItemId = productSellerItemId, 
                Quantity = delta,
                CustomerId = Security?.SelectedCustomerId
            };
            
            var result = await CartService.CreateCartItem(req);
            
            if (result.Ok && result.Result != null)
            {
                CartStateService.SetCart(result.Result);
                
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Sepete Eklendi",
                    Detail = "Ürün sepete eklendi.",
                    Duration = 2000
                });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Hata",
                    Detail = result.Metadata?.Message ?? "Ürün sepete eklenemedi.",
                    Duration = 4000
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Hata",
                Detail = ex.Message,
                Duration = 4000
            });
        }
        finally
        {
            loadingItems.Remove(productSellerItemId);
            StateHasChanged();
        }
    }
    
    private async Task UpdateQuantity(int productSellerItemId, int newQuantity)
    {
        if (loadingItems.Contains(productSellerItemId)) return;
        
        // If quantity is 0 or less, remove item (like CartDrawer)
        if (newQuantity <= 0)
        {
            await RemoveItem(productSellerItemId);
            return;
        }
        
        loadingItems.Add(productSellerItemId);
        StateHasChanged();
        
        try
        {
            var currentCart = CartStateService.CurrentCart;
            int currentCartQty = currentCart?.Sellers?
                .SelectMany(s => s.Items)
                .FirstOrDefault(i => i.ProductSellerItemId == productSellerItemId)?.Quantity ?? 0;
            
            int delta = newQuantity - currentCartQty;
            
            if (delta == 0)
            {
                loadingItems.Remove(productSellerItemId);
                StateHasChanged();
                return;
            }

            var req = new CartItemUpsertDto 
            { 
                ProductSellerItemId = productSellerItemId, 
                Quantity = delta,
                CustomerId = Security?.SelectedCustomerId
            };
            
            var result = await CartService.CreateCartItem(req);
            
            if (result.Ok && result.Result != null)
            {
                CartStateService.SetCart(result.Result);
                
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Güncellendi",
                    Detail = "Sepet güncellendi.",
                    Duration = 2000
                });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Hata",
                    Detail = result.Metadata?.Message ?? "Miktar güncellenemedi.",
                    Duration = 4000
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Hata",
                Detail = ex.Message,
                Duration = 4000
            });
        }
        finally
        {
            loadingItems.Remove(productSellerItemId);
            StateHasChanged();
        }
    }
    
    private async Task RemoveItem(int productSellerItemId)
    {
        if (loadingItems.Contains(productSellerItemId)) return;
        
        loadingItems.Add(productSellerItemId);
        StateHasChanged();
        
        try
        {
            var currentCart = CartStateService.CurrentCart;
            var cartItem = currentCart?.Sellers?
                .SelectMany(s => s.Items)
                .FirstOrDefault(i => i.ProductSellerItemId == productSellerItemId);
            
            if (cartItem == null)
            {
                loadingItems.Remove(productSellerItemId);
                StateHasChanged();
                return;
            }
            
            var result = await CartService.CartItemRemove(cartItem.Id);
            
            if (result.Ok && result.Result != null)
            {
                CartStateService.SetCart(result.Result);
                
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Info,
                    Summary = "Silindi",
                    Detail = "Ürün sepetten kaldırıldı.",
                    Duration = 2000
                });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Hata",
                    Detail = result.Metadata?.Message ?? "Ürün sepetten kaldırılamadı.",
                    Duration = 4000
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Hata",
                Detail = ex.Message,
                Duration = 4000
            });
        }
        finally
        {
            loadingItems.Remove(productSellerItemId);
            StateHasChanged();
        }
    }
    
    private string ResolveSearchImage(SellerProductViewModel product)
    {
        if (!string.IsNullOrWhiteSpace(product.DocumentUrl)) return product.DocumentUrl;
        if (product.Images != null && product.Images.Any())
        {
            return $"https://cdn.yedeksen.com/images/ProductImages/{product.Images.First().FileName}";
        }
        return "/images/no-photo.png";
    }
}
