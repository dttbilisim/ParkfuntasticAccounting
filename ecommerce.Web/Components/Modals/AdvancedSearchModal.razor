@code {
    [CascadingParameter] public BlazoredModalInstance? ModalInstance { get; set; }
    [Parameter] public IEnumerable<ManufacturerElasticDto> Manufacturers { get; set; } = Enumerable.Empty<ManufacturerElasticDto>();
    [Parameter] public Dictionary<int, List<ecommerce.Web.Domain.Dtos.BaseModelDto>> ManufacturerModelCache { get; set; } = new();

    // State
    private string modalManufacturerSearch = "";
    private string modalModelSearch = "";
    private string modalSubModelSearch = "";
    private string modalDotPartSearch = "";

    private string? modalSelectedManufacturer;
    private string? modalSelectedModel;
    private string? modalSelectedSubModelKey;
    private string? modalSelectedSubModelName;
    private string? modalSelectedDotPart;
    private List<string>? modalSelectedDatProcessNumber;
    
    private bool isModalOnlyInStock = false;

    // Data lists
    // Explicitly using SharedProduct namespace for SubModelDto to avoid conflict with Web.Domain.Dtos.SubModelDto
    private List<string> modalBaseModels = new();
    private List<SharedProduct.SubModelDto> modalSubModels = new();
    private List<(string Name, List<string> ProcessNumber)> modalDotParts = new();

    // Loading states
    private bool isModelLoading = false;
    private bool isSubModelLoading = false;
    private bool isDotPartLoading = false;

    private Dictionary<string, List<SharedProduct.SubModelDto>> modalModelSubModelsCache = new();
    
    // Real manufacturers from Elasticsearch (only those with products)
    private List<string> realManufacturers = new();
    private bool isLoadingManufacturers = false;

    protected override async Task OnParametersSetAsync()
    {
        // Load manufacturers when modal opens
        if (!realManufacturers.Any() && !isLoadingManufacturers)
        {
            await LoadManufacturersFromElasticsearch();
        }
    }
    
    private async Task LoadManufacturersFromElasticsearch()
    {
        isLoadingManufacturers = true;
        try
        {
            // Fetch a sample of products to extract manufacturers (reduced for speed)
            var filter = new SearchFilterReguestDto 
            { 
                OnlyInStock = isModalOnlyInStock,
                Page = 1, 
                PageSize = 500  // Balanced: Fast loading while capturing most manufacturers
            };
            
            var productResult = await ProductService.GetByFilterPagingAsync(filter);
            
            if (productResult.Ok && productResult.Result != null && productResult.Result.Data.Any())
            {
                realManufacturers = productResult.Result.Data
                    .Select(p => p.ManufacturerName)
                    .Where(name => !string.IsNullOrEmpty(name))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(x => x)
                    .ToList()!;
                    
                Console.WriteLine($"✅ Loaded {realManufacturers.Count} manufacturers from {productResult.Result.Data.Count} products");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
        }
        finally
        {
            isLoadingManufacturers = false;
        }
    }

    // Filter properties - Use real manufacturers from Elasticsearch
    private IEnumerable<string> FilteredModalManufacturers => realManufacturers
        .Where(m => string.IsNullOrEmpty(modalManufacturerSearch) || m.Contains(modalManufacturerSearch, StringComparison.OrdinalIgnoreCase))
        .OrderBy(x => x);

    private IEnumerable<string> FilteredModalModels => modalBaseModels
        .Where(m => string.IsNullOrEmpty(modalModelSearch) || 
                    m.Contains(modalModelSearch, StringComparison.OrdinalIgnoreCase) ||
                    (modalModelSubModelsCache.TryGetValue(m, out var subModels) && 
                     subModels.Any(sm => sm.Name != null && sm.Name.Contains(modalModelSearch, StringComparison.OrdinalIgnoreCase))));

    private IEnumerable<SharedProduct.SubModelDto> FilteredModalSubModels => modalSubModels
        .Where(sm => !string.IsNullOrWhiteSpace(sm.Name))  // CRITICAL: Filter out null/empty names
        .Where(sm => string.IsNullOrEmpty(modalSubModelSearch) || sm.Name.Contains(modalSubModelSearch, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<(string Name, List<string> ProcessNumber)> FilteredModalDotParts => modalDotParts
        .Where(dp => string.IsNullOrEmpty(modalDotPartSearch) || dp.Name.Contains(modalDotPartSearch, StringComparison.OrdinalIgnoreCase));

    private async Task OnStockSwitchChanged(ChangeEventArgs e)
    {
        var newValue = (bool)(e.Value ?? false);
        Console.WriteLine($"🔄 Stock toggle changed: {isModalOnlyInStock} -> {newValue}");
        
        isModalOnlyInStock = newValue;
        
        // Clear all selections when stock filter changes
        modalSelectedManufacturer = null;
        modalSelectedModel = null;
        modalSelectedSubModelKey = null;
        modalSelectedSubModelName = null;
        modalSelectedDotPart = null;
        modalSelectedDatProcessNumber = null;
        modalBaseModels.Clear();
        modalSubModels.Clear();
        modalDotParts.Clear();
        
        // Show loading state immediately
        StateHasChanged();
        
        Console.WriteLine($"⏳ Reloading manufacturers with OnlyInStock={isModalOnlyInStock}...");
        
        // Reload manufacturers based on stock filter
        await LoadManufacturersFromElasticsearch();
        
        Console.WriteLine($"✅ Stock toggle complete - {realManufacturers.Count} manufacturers loaded");
        
        // Final refresh after everything is loaded
        StateHasChanged();
    }

    protected async Task OnModalManufacturerChanged(string manufacturer)
    {
        modalSelectedManufacturer = manufacturer;
        modalSelectedModel = null;
        modalSelectedSubModelKey = null;
        modalSelectedSubModelName = null;
        modalSelectedDotPart = null;
        
        modalBaseModels.Clear();
        modalSubModels.Clear();
        modalDotParts.Clear();
        
        modalModelSearch = "";
        modalSubModelSearch = "";
        modalDotPartSearch = "";
        
        isModelLoading = true;
        
        if (!string.IsNullOrEmpty(manufacturer))
        {
            try
            {
                Console.WriteLine($"🔍 Fetching models for {manufacturer}, OnlyInStock={isModalOnlyInStock}");
                
                var filter = new SearchFilterReguestDto 
                { 
                    ManufacturerNames = new List<string> { manufacturer },
                    OnlyInStock = isModalOnlyInStock,
                    Page = 1, 
                    PageSize = 500 
                };
                
                var productResult = await ProductService.GetByFilterPagingAsync(filter);
                
                Console.WriteLine($"✅ Got {productResult.Result?.Data?.Count ?? 0} products for manufacturer {manufacturer}");
                
                if (productResult.Ok && productResult.Result != null && productResult.Result.Data.Any())
                {
                    modalBaseModels = productResult.Result.Data
                        .Select(p => p.BaseModelName)
                        .Where(name => !string.IsNullOrEmpty(name))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(x => x)
                        .ToList()!;
                    
                    Console.WriteLine($"📊 Extracted {modalBaseModels.Count} unique models");
                    
                    // Populate cache
                    modalModelSubModelsCache.Clear();
                    foreach (var product in productResult.Result.Data.Where(p => p.SubModelsJson != null && p.SubModelsJson.Any()))
                    {
                        var modelName = product.BaseModelName;
                        if (string.IsNullOrEmpty(modelName)) continue;

                        if (!modalModelSubModelsCache.ContainsKey(modelName))
                        {
                            modalModelSubModelsCache[modelName] = new List<SharedProduct.SubModelDto>();
                        }

                        foreach (var sm in product.SubModelsJson)
                        {
                            if (sm != null && !string.IsNullOrEmpty(sm.Key) && !modalModelSubModelsCache[modelName].Any(x => x.Key == sm.Key))
                            {
                                modalModelSubModelsCache[modelName].Add(sm);
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                 NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
            }
        }
        
        isModelLoading = false;
        StateHasChanged();
    }

    protected async Task OnModalModelChanged(string model)
    {
        Console.WriteLine($"🔄 OnModalModelChanged: {model}");
        
        modalSelectedModel = model;
        modalSelectedSubModelKey = null;
        modalSelectedSubModelName = null;
        modalSelectedDotPart = null;
        modalDotParts.Clear();
        modalSubModelSearch = "";
        modalDotPartSearch = "";
        
        isSubModelLoading = true;
        StateHasChanged(); // Show loading state immediately
        
        // Cache Check
        if (modalModelSubModelsCache.TryGetValue(model, out var cachedSubModels) && cachedSubModels.Any())
        {
             Console.WriteLine($"✅ Cache HIT for model '{model}': {cachedSubModels.Count} sub-models");
             modalSubModels = cachedSubModels.OrderBy(x => x.Name).ToList();
             isSubModelLoading = false;
             StateHasChanged();
             return;
        }

        Console.WriteLine($"❌ Cache MISS for model '{model}' - fetching from backend");
        
        // Cache miss or empty - clear and fetch fresh
        modalSubModels.Clear();

        if (!string.IsNullOrEmpty(modalSelectedManufacturer) && !string.IsNullOrEmpty(model))
        {
             try
            {
                var filter = new SearchFilterReguestDto 
                { 
                    ManufacturerNames = new List<string> { modalSelectedManufacturer },
                    BaseModelNames = new List<string> { model },
                    OnlyInStock = isModalOnlyInStock,
                    Page = 1, 
                    PageSize = 500 
                };
                var productResult = await ProductService.GetByFilterPagingAsync(filter);
                
                Console.WriteLine($"📦 Got {productResult.Result?.Data?.Count ?? 0} products for model '{model}'");
                
                 if (productResult.Ok && productResult.Result != null && productResult.Result.Data.Any())
                {
                     modalSubModels = productResult.Result.Data
                        .Where(p => p.SubModelsJson != null && p.SubModelsJson.Any())
                        .SelectMany(p => p.SubModelsJson!)
                        .Where(sm => sm != null && !string.IsNullOrWhiteSpace(sm.Key) && !string.IsNullOrWhiteSpace(sm.Name))
                        .DistinctBy(sm => sm.Key)
                        .OrderBy(x => x.Name)
                        .ToList();
                        
                     Console.WriteLine($"📊 Extracted {modalSubModels.Count} sub-models");
                }
            }
             catch (Exception ex)
            {
                 NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
            }
        }

        isSubModelLoading = false;
        StateHasChanged();
    }

    protected async Task OnModalSubModelChanged(string? subModelKey, string? subModelName)
    {
        modalSelectedSubModelKey = subModelKey;
        modalSelectedSubModelName = subModelName;
        modalSelectedDotPart = null;
        modalDotParts.Clear();
        modalDotPartSearch = "";

        isDotPartLoading = true;

        if (!string.IsNullOrEmpty(subModelKey))
        {
             try
            {
                 var filter = new SearchFilterReguestDto 
                 { 
                     ManufacturerNames = !string.IsNullOrEmpty(modalSelectedManufacturer) ? new List<string> { modalSelectedManufacturer } : null,
                     BaseModelNames = !string.IsNullOrEmpty(modalSelectedModel) ? new List<string> { modalSelectedModel } : null,
                     SubModelKeys = new List<string> { subModelKey },
                     OnlyInStock = isModalOnlyInStock, 
                     Page = 1, 
                     PageSize = 500 
                 };
                  var productResult = await ProductService.GetByFilterPagingAsync(filter);
                   if (productResult.Ok && productResult.Result != null && productResult.Result.Data.Any())
                    {
                         modalDotParts = productResult.Result.Data
                            .Where(p => !string.IsNullOrEmpty(p.DotPartName) && p.DatProcessNumber?.Any() == true)
                            .Select(p => (Name: p.DotPartName!, ProcessNumber: p.DatProcessNumber!))
                            .DistinctBy(x => x.Name)
                            .OrderBy(x => x.Name)
                            .ToList();
                    }
            }
             catch (Exception ex)
            {
                 NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
            }
        }
        
        isDotPartLoading = false;
        StateHasChanged();
    }

    protected void OnModalDotPartChanged(string dotPartName, List<string> datProcessNumbers)
    {
        modalSelectedDotPart = dotPartName;
        modalSelectedDatProcessNumber = datProcessNumbers;
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
         var parameters = new List<string>();

         if (!string.IsNullOrEmpty(modalSelectedManufacturer))
         {
             // CRITICAL: Send ORIGINAL name, not friendly-titled (preserves case: BMW not bmw)
             parameters.Add($"manufacturername={Uri.EscapeDataString(modalSelectedManufacturer)}");
         }
         
         if (!string.IsNullOrEmpty(modalSelectedModel))
         {
             // CRITICAL: Send ORIGINAL name, not friendly-titled
             parameters.Add($"modelname={Uri.EscapeDataString(modalSelectedModel)}");
         }
         
         if (!string.IsNullOrEmpty(modalSelectedSubModelKey))
         {
             parameters.Add($"submodelkey={Uri.EscapeDataString(modalSelectedSubModelKey)}");
              if (!string.IsNullOrEmpty(modalSelectedSubModelName))
               {
                   parameters.Add($"submodelname={Uri.EscapeDataString(modalSelectedSubModelName)}");
               }
         }
         
         // Logic for Part Group: Pass DatProcessNumber parameter (NOT dotpartname)
         if (modalSelectedDatProcessNumber?.Any() == true)
         {
             parameters.Add($"datprocessnumber={Uri.EscapeDataString(string.Join(",", modalSelectedDatProcessNumber))}");
         }

         if (isModalOnlyInStock)
         {
             parameters.Add("onlyinstock=true");
         }

        var url = "/product-search";
        if (parameters.Any())
        {
            url += "?" + string.Join("&", parameters);
        }

        NavigationManager.NavigateTo(url, forceLoad: false);
        await CancelAsync();
    }

    private async Task CancelAsync()
    {
        if (ModalInstance != null)
        {
            await ModalInstance.CloseAsync();
        }
    }
    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
