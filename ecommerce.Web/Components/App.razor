    <script>
        window.swalConfirm = function (title, text, type) {
            return new Promise(resolve => {
                Swal.fire({
                    title: title,
                    text: text,
                    icon: type || 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#0e947a',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Evet',
                    cancelButtonText: 'İptal'
                }).then((result) => {
                    resolve(result.isConfirmed);
                });
            });
        };

        window.addProductJsonLd = function(p){
            if(!p || !p.name) return;
            var s = document.getElementById('jsonld-product');
            if(s) s.remove();
            var data = {
                "@@context":"https://schema.org",
                "@@type":"Product",
                "name": p.name,
                "image": p.image ? [p.image] : [],
                "description": p.description || "",
                "brand": {"@@type":"Brand","name": p.brand || ""},
                "sku": p.sku || "",
                "offers": {
                    "@@type":"Offer",
                    "url": p.url || window.location.href,
                    "priceCurrency": p.currency || "TRY",
                    "price": p.price || "",
                    "availability": p.availability === 'InStock' ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
                    "itemCondition":"https://schema.org/NewCondition"
                }
            };
            var tag = document.createElement('script');
            tag.type = 'application/ld+json';
            tag.id = 'jsonld-product';
            tag.text = JSON.stringify(data);
            document.head.appendChild(tag);
        }
    </script>
