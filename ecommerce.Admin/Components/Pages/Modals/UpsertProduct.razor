@page "/upsert-product"
@using Blazored.FluentValidation

@using ecommerce.Admin.Domain.Dtos.ProductActiveArcticleDto;
@using ecommerce.Admin.Domain.Dtos.ProductCategory;
@using ecommerce.Admin.Domain.Dtos.ProductDto;
@using ecommerce.Admin.Domain.Dtos.ProductImageDto;
@using ecommerce.Admin.Domain.Dtos.ProductStockDto
@using ecommerce.Admin.Domain.Dtos.ProductTierDto;
@using ecommerce.Admin.Domain.Dtos.ProductUnitDto;
@using ecommerce.Admin.Domain.Dtos.UnitDto;
@using ecommerce.Core.Utils;
@attribute [Authorize]

<PageTitle>Ürün Ekle/Düzenle</PageTitle>

<div class="col-md-12">

<RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Ürün Kayıt Edilemedi!</RadzenAlert>


<RadzenTemplateForm TItem="ProductUpsertDto" Data="@product" Visible="@(product != null)" Submit="@FormSubmit" OnInvalidSubmit="ShowErrors">

<RadzenProgressBar ProgressBarStyle="ProgressBarStyle.Info" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="height:5px;" Visible="IsShowLoadingBar"/>

<br/>

<FluentValidationValidator @ref="_fluentValidationValidator"/>

<RadzenTabs TabPosition="TabPosition.Top" class="w-100" Change="TabChange" Visible="!IsShowLoadingBar">
<Tabs>
<RadzenTabsItem Text="Ürün Bilgileri">
    <RadzenFieldset Text="Ürün Bilgileri">


        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Marka (*)" Component="Brand" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenDropDownDataGrid Data="@brands" TextProperty="Name" ValueProperty="Id" Placeholder="Seçiniz" style="display: block; width: 100%" @bind-Value="@product.BrandId" Name="BrandId" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowFiltering="true" />
            </div>
        </div>




        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Ürün Tipi" Component="ProductType" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenDropDownDataGrid Data="@productTypes" AllowClear="true" TextProperty="Name" ValueProperty="Id" Placeholder="Seçiniz" style="display: block; width: 100%" @bind-Value="@product.ProductTypeId" Name="ProductTypeId" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowFiltering="true" />
            </div>
        </div>

        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Ürün Adı (*)" Component="Name" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenTextBox style="display: block; width: 100%" @bind-Value="@product.Name" Name="Name"/>
            </div>
        </div>

        @*<div style="margin-bottom: 1rem" class="row">
                        <div class="col-md-3">
                        <RadzenLabel Text="Kısa Ürün Adı (*)" Component="Name" style="width: 100%" />
                        </div>
                        <div class="col-md-9">
                        <RadzenTextBox style="display: block; width: 100%" @bind-Value="@product.ShortName" Name="ShortName" MaxLength="10" />
                        </div>
                        </div>*@


        @if (false)
        {
            <div style="margin-bottom: 1rem" class="row">
                <div class="col-md-3">
                    <RadzenLabel Text="Barkod No." Component="Name" style="width: 100%"/>
                </div>
                <div class="col-md-9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@product.Barcode" Name="Barcode" ShowUpDown="false" Change="@BarcodeControlSync"/>
                </div>
            </div>
        }



        <div style="margin-bottom: 1rem" class="row">
                    <div class="col-md-3">
                        <RadzenLabel Text="Arama Motoru Keywords" Component="WebKeyword" style="width: 100%"/>
                    </div>
                    <div class="col-md-9">
                        <RadzenTextBox Placeholder="Arama motorunda bulun mayan ürünler için keyword ekleyebilirsiniz." style="display: block; width: 100%" @bind-Value="@product.WebKeyword" Name="WebKeyword" ShowUpDown="false" />
                       
                    </div>
                </div>
    
        @*      <div style="margin-bottom: 1rem" class="row">
                        <div class="col-md-3">
                        <RadzenLabel Text="Gtin" Component="Gtin" style="width: 100%" />
                        </div>
                        <div class="col-md-9">
                        <RadzenNumeric style="display: block; width: 100%" @bind-Value="@product.Gtin" Name="Gtin" ShowUpDown="false" />

                        </div>
                        </div>*@

        @*<div style="margin-bottom: 1rem" class="row">
                        <div class="col-md-3">
                        <RadzenLabel Text="Aşama (*)" Component="Tier" style="width: 100%" />
                        </div>
                        <div class="col-md-9">
                        <RadzenDropDownDataGrid Data="@tiers" TextProperty="Name" ValueProperty="Id" Placeholder="Seçiniz" style="display: block; width: 100%" @bind-Value="@product.TierId" Name="TierId" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />
                        </div>
                        </div>*@

        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Açıklama" Component="Description" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenTextArea style="display: block; width: 100%" @bind-Value="@product.Description" Name="Description"/>

            </div>
        </div>

        <div class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Durum" Component="Length" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenCheckBox TValue="bool" @bind-Value="@Status" Name="Status"/>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Yenilikçi Ürünler" Component="Length" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenCheckBox TValue="bool" @bind-Value="@product.IsNewsProduct" Name="Status"/>
                <span style="color: red;font-size: 10px;">Yenilikçi ürünler işaretli ise ürün web te yenilikçi ürünler arasında çıkacaktır.</span>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Hediye Ürün mü?" Component="Length" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenCheckBox TValue="bool" @bind-Value="@product.IsGift" Name="Status"/>
                <span style="color: red;font-size: 10px;">İndirim ve Kampanyada Modülünde Kullanılmak İçin</span>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Stok Takibi Yapılsın mı?" Component="IsStockFollow" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenCheckBox TValue="bool" @bind-Value="@product.IsStockFollow" Name="IsStockFollow"/>
                <span style="color: red;font-size: 10px;">Ürünün stok takibi yapılmasını istiyorsanız işaretleyiniz.</span>
            </div>
        </div>
        @* Admin ürün tanımı sadeleştirme: Ebat/Ağırlık/Sunum alanları ana sekmeye taşındı, sadece Ağırlık gösteriliyor. *@
        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Ağırlık (gr)" Component="Weight" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenNumeric style="display: block; width: 100%" @bind-Value="@product.Weight" Name="Weight" Min="0" ShowUpDown="false"/>
            </div>
        </div>
    </RadzenFieldset>
</RadzenTabsItem>

