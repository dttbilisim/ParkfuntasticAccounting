            <div class="col-md-9">
                @if (SellerCompany != null)
                {
                    <RadzenDropDownDataGrid Data="@Sellertowns" TextProperty="Name" ValueProperty="Id" Placeholder="Seçiniz" class="rz-full-width" @bind-Value="@SellerCompany.TownId" Disabled Name="TownId" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowFiltering="true"/>
                }
