<RadzenTabsItem Text="Fiyat/Maliyet">
    <RadzenFieldset Text="Ürün Vergi Bilgileri">


        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Vergi Oranı (*)" Component="Tax" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenDropDownDataGrid TValue="int?" Data="@taxes" TextProperty="Name" ValueProperty="Id" Placeholder="Seçiniz" style="display: block; width: 100%" @bind-Value="@product.TaxId" Name="TaxId" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowFiltering="true" />
            </div>
        </div>

        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Maliyet Fiyatı" Component="Length" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenNumeric Format="c" style="display: block; width: 100%" @bind-Value="@product.CostPrice" Name="CostPrice" Min="0" ShowUpDown="false"/>
            </div>
        </div>

        @if (false)
        {
            <div style="margin-bottom: 1rem" class="row">
                <div class="col-md-3">
                    <RadzenLabel Text="Perakende Satış Fiyatı" Component="Length" style="width: 100%"/>
                </div>
                <div class="col-md-9">
                    <RadzenNumeric Format="c" style="display: block; width: 100%" @bind-Value="@product.RetailPrice" Name="RetailPrice" Min="0" ShowUpDown="false"/>
                    @* <RadzenButton ButtonStyle="ButtonStyle.Light"  Text="@psfButtonStatus" Variant="Variant.Flat" Click="@GetPsf"/> *@
                </div>
            </div>
        }
        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Min Satış Fiyatı" Component="MinPrice" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenNumeric ReadOnly="true" Format="c" style="display: block; width: 100%" @bind-Value="@product.MinPrice" Name="MinPrice" Min="0" ShowUpDown="false"/>
            </div>
        </div>
        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Max Satış Fiyatı" Component="MaxPrice" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenNumeric ReadOnly="true" Format="c" style="display: block; width: 100%" @bind-Value="@product.MaxPrice" Name="MaxPrice" Min="0" ShowUpDown="false"/>
            </div>
        </div>
        <div style="margin-bottom: 1rem" class="row">
            <div class="col-md-3">
                <RadzenLabel Text="Ortalama Satış Fiyatı" Component="AvgPrice" style="width: 100%"/>
            </div>
            <div class="col-md-9">
                <RadzenNumeric ReadOnly="true" Format="c" style="display: block; width: 100%" @bind-Value="@product.AvgPrice" Name="AvgPrice" Min="0" ShowUpDown="false"/>
            </div>
        </div>
        @if (false)
        {
            <div style="margin-bottom: 1rem" class="row">
                <div class="col-md-3">
                    <RadzenLabel Text="İlan Sayısı" Component="AdvertCount" style="width: 100%"/>
                </div>
                <div class="col-md-9">
                    <RadzenNumeric ReadOnly="true"  style="display: block; width: 100%" @bind-Value="@product.AdvertCount" Name="AdvertCount" Min="0" ShowUpDown="false"/>
                </div>
            </div>
        }
    </RadzenFieldset>
</RadzenTabsItem>

@if (false)
{
    <RadzenTabsItem Text="Grup Bilgileri">
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Medium" AlertStyle="AlertStyle.Warning" Visible="@IsProductSaved">Önce ürün kaydetmelisiniz!</RadzenAlert>


        <RadzenFieldset Text="Grub Bilgileri">


            <div style="width: 100%; overflow: hidden;" class="mb-2">
                <div style="float:right">
                    <RadzenButton Icon="add_circle_outline" Text="Ürün Grubu Ekle" Variant="Variant.Flat" Click="AddProductTierButtonClick" class="mt-2" Visible="@isShowSaveThenProductPanels"/>
                </div>
            </div>

            <RadzenDataGrid AllowFiltering="false"
                            AllowColumnResize="true"
                            AllowAlternatingRows="false"
                            FilterMode="FilterMode.Advanced"
                            AllowSorting="false"
                            AllowPaging="true"
                            PagerHorizontalAlign="HorizontalAlign.Left"
                            ShowPagingSummary="false"
                            Data="@productTiers"
                            TItem="ProductTierListDto"
                            ColumnWidth="300px"
                            LogicalFilterOperator="LogicalFilterOperator.Or"
                            PageSize="10">
                <Columns>
                    <RadzenDataGridColumn TItem="ProductTierListDto" Title="Id" Property="Id" Width="50px"/>
                    <RadzenDataGridColumn TItem="ProductTierListDto" Title="Ürün Grubu" Width="70px">
                        <Template Context="productTier">
                            <RadzenText Text="@productTier.Tier.Name" Style="width: 2rem;"/>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ProductTierListDto" Width="70px">
                        <Template Context="productCategory">
                            <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall"
                                          Shade="Shade.Dark" Variant="Variant.Flat"
                                          Click=@(args => GridDeleteProductTierButtonClick(args, productCategory)) @onclick:stopPropagation="true"/>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

        </RadzenFieldset>


    </RadzenTabsItem>
}

<RadzenTabsItem Text="Kategori Bilgileri">

    <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Medium" AlertStyle="AlertStyle.Warning" Visible="@IsProductSaved">Önce ürün kaydetmelisiniz!</RadzenAlert>

    <RadzenFieldset Text="Kategori Bilgileri">


        <div style="width: 100%; overflow: hidden;" class="mb-2">
            <div style="float:right">
                <RadzenButton Icon="add_circle_outline" Text="Kategori Ekle" Variant="Variant.Flat" Click="AddProductCategoryButtonClick" class="mt-2" Visible="@isShowSaveThenProductPanels"/>
            </div>
        </div>

        <RadzenDataGrid AllowFiltering="false"
                        AllowColumnResize="true"
                        AllowAlternatingRows="false"
                        FilterMode="FilterMode.Advanced"
                        AllowSorting="false"
                        AllowPaging="true"
                        PagerHorizontalAlign="HorizontalAlign.Left"
                        ShowPagingSummary="false"
                        Data="@productCategories"
                        TItem="ProductCategoryListDto"
                        ColumnWidth="300px"
                        LogicalFilterOperator="LogicalFilterOperator.Or"
                        PageSize="10">
            <Columns>
                <RadzenDataGridColumn TItem="ProductCategoryListDto" Title="Id" Property="Id" Width="50px"/>
                <RadzenDataGridColumn TItem="ProductCategoryListDto" Title="Kategori">
                    <Template Context="productCategory">
                        <p style="white-space:pre-wrap">@productCategory.Category.Name</p>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ProductCategoryListDto" Width="70px">
                    <Template Context="productCategory">
                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.ExtraSmall"
                                      Shade="Shade.Dark" Variant="Variant.Flat"
                                      Click=@(args => GridDeleteProductCategoryButtonClick(args, productCategory)) @onclick:stopPropagation="true"/>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>

    </RadzenFieldset>


</RadzenTabsItem>

