@page "/test-global-loading"
@using ecommerce.Web.Utility
@using I18NPortable
@inject AppStateManager AppStateManager
@inject IJSRuntime JSRuntime
@inject II18N lang

<div class="container-fluid-lg py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Global Loading System Test</h3>
                    <p class="text-muted">Bu sayfa global loading sistemini test etmek için oluşturulmuştur.</p>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <button class="btn btn-primary w-100" @onclick="TestShortLoading">
                                <i class="fas fa-clock me-2"></i>
                                Kısa Loading (2 saniye)
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-success w-100" @onclick="TestLongLoading">
                                <i class="fas fa-hourglass-half me-2"></i>
                                Uzun Loading (5 saniye)
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-warning w-100" @onclick="TestDatabaseSimulation">
                                <i class="fas fa-database me-2"></i>
                                DB İşlemi Simülasyonu
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-info w-100" @onclick="TestMultipleOperations">
                                <i class="fas fa-sync-alt me-2"></i>
                                Çoklu İşlem Test
                            </button>
                        </div>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="alert alert-info">
                        <h5><i class="fas fa-info-circle me-2"></i>Global Loading Durumu:</h5>
                        <p class="mb-0">
                            <strong>Durum:</strong> 
                            @if (AppStateManager.IsGlobalLoading)
                            {
                                <span class="badge bg-warning">Yükleniyor...</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@lang["Common.Ready"]</span>
                            }
                        </p>
                    </div>

                    <div class="mt-3">
                        <h5>Test Sonuçları:</h5>
                        <div class="list-group">
                            @foreach (var result in testResults)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@result.Title</h6>
                                        <small>@result.Timestamp.ToString("HH:mm:ss")</small>
                                    </div>
                                    <p class="mb-1">@result.Message</p>
                                    <small class="@(result.Success ? "text-success" : "text-danger")">
                                        @(result.Success ? "Başarılı" : "Başarısız")
                                    </small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TestResult> testResults = new();
    
    private class TestResult
    {
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public DateTime Timestamp { get; set; } = DateTime.Now;
        public bool Success { get; set; }
    }
    
    private async Task TestShortLoading()
    {
        await AppStateManager.ExecuteWithLoading(async () => {
            await Task.Delay(2000); // 2 saniye bekle
            AddTestResult("Kısa Loading", "2 saniyelik loading tamamlandı", true);
        }, "Kısa işlem");
    }
    
    private async Task TestLongLoading()
    {
        await AppStateManager.ExecuteWithLoading(async () => {
            await Task.Delay(5000); // 5 saniye bekle
            AddTestResult("Uzun Loading", "5 saniyelik loading tamamlandı", true);
        }, "Uzun işlem");
    }
    
    private async Task TestDatabaseSimulation()
    {
        await AppStateManager.ExecuteWithLoading(async () => {
            try
            {
                // DB işlemi simülasyonu
                await Task.Delay(3000);
                
                // Rastgele başarı/başarısızlık simülasyonu
                var random = new Random();
                var success = random.Next(0, 10) > 2; // %80 başarı oranı
                
                if (success)
                {
                    AddTestResult("DB İşlemi", "Veritabanı işlemi başarıyla tamamlandı", true);
                }
                else
                {
                    AddTestResult("DB İşlemi", "Veritabanı bağlantı hatası", false);
                    throw new Exception("Simulated database error");
                }
            }
            catch (Exception ex)
            {
                AddTestResult("DB İşlemi", $"Hata: {ex.Message}", false);
            }
        }, "Veritabanı işlemi");
    }
    
    private async Task TestMultipleOperations()
    {
        await AppStateManager.ExecuteWithLoading(async () => {
            try
            {
                AddTestResult("Çoklu İşlem", "İşlem 1 başladı...", true);
                await Task.Delay(1000);
                
                AddTestResult("Çoklu İşlem", "İşlem 2 başladı...", true);
                await Task.Delay(1000);
                
                AddTestResult("Çoklu İşlem", "İşlem 3 başladı...", true);
                await Task.Delay(1000);
                
                AddTestResult("Çoklu İşlem", "Tüm işlemler tamamlandı", true);
            }
            catch (Exception ex)
            {
                AddTestResult("Çoklu İşlem", $"Hata: {ex.Message}", false);
            }
        }, "Çoklu işlem");
    }
    
    private void AddTestResult(string title, string message, bool success)
    {
        testResults.Insert(0, new TestResult
        {
            Title = title,
            Message = message,
            Timestamp = DateTime.Now,
            Success = success
        });
        
        // Maksimum 10 sonuç tut
        if (testResults.Count > 10)
        {
            testResults = testResults.Take(10).ToList();
        }
        
        StateHasChanged();
    }
}
