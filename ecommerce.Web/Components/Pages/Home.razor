@page "/"

@using ecommerce.Web.Utility
@using ecommerce.Web.Components.Pages.Components
<section class="home-section-2 home-section-bg pt-0 overflow-hidden">
    <div class="container-fluid p-0">
        <div class="row">
            <div class="col-12">


                <SlickSlider SliderName="slider-animate" SliderId="slider-animate" Config="@SliderConfigs.SliderHomeBanner">
                    @if (BannerItemList != null)
                    {
                        for (var i = 0; i < BannerItemList.Count; i++)
                        {
                            var item = BannerItemList[i];
                            var isFirst = i == 0;
                            <div class="home-contain rounded-0 p-0" style="overflow:hidden;">
                                @if (!string.IsNullOrEmpty(item.FileName))
                                {
                                    <img style="@(item.FullSlider ? "width:100%; height:auto; object-fit:cover;" : null)"
                                         src="@($"{CdnConfig.BaseUrl}/BannerImages/{item.FileName}")"
                                         srcset="@($"{CdnConfig.BaseUrl}/BannerImages/{item.FileName}") 1920w, @($"{CdnConfig.BaseUrl}/BannerImages/1280/{item.FileName}") 1280w, @($"{CdnConfig.BaseUrl}/BannerImages/768/{item.FileName}") 768w, @($"{CdnConfig.BaseUrl}/BannerImages/480/{item.FileName}") 480w"
                                         sizes="(max-width: 576px) 100vw, (max-width: 992px) 100vw, 100vw"
                                         class="img-fluid bg-img"
                                         width="1920" height="700"
                                         loading="@(isFirst ? null : "lazy")"
                                         decoding="async"
                                         fetchpriority="@(isFirst ? "high" : "low")"
                                         alt="@item.Title">
                                }
                                else
                                {
                                    <img style="@(item.FullSlider ? "width:100%; height:auto; object-fit:cover;" : null)"
                                         src="assets/images/banner/no-image.jpg"
                                         class="img-fluid bg-img"
                                         width="1920" height="700"
                                         loading="@(isFirst ? null : "lazy")"
                                         decoding="async"
                                         fetchpriority="@(isFirst ? "high" : "low")"
                                         alt="Banner image">
                                }
                                <div class="home-detail position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center z-2">
                                    <div class="container-fluid-lg">
                                        <div>
                                            <h6 class="ls-expanded theme-color text-uppercase">@item.Title</h6>
                                            <h1 class="heding-2">@lang["Home.BannerSubtitle1"]</h1>
                                            <h2 class="content-2">@lang["Home.BannerSubtitle2"]</h2>
                                            <h5 class="text-content">@item.Description</h5>
                                            @if (item.IsButton)
                                            {
                                                <button class="btn theme-bg-color btn-md text-white fw-bold mt-md-4 mt-2 mend-auto"
                                                        onclick="@(item.IsNewTab ? $"window.open('{item.Url}', '_blank')" : $"location.href = '{item.Url}'")">
                                                    @item.ButtonName <i class="fa-solid fa-arrow-right icon"></i>
                                                </button>
                                            }

                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }


                </SlickSlider>
            </div>
        </div>
    </div>
</section>

