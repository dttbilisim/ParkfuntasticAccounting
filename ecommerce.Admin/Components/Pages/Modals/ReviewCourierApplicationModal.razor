@using ecommerce.Admin.Domain.Dtos.CourierApplicationDto
@using Radzen
@using Radzen.Blazor

<div class="modal-wrapper">
    <div class="modal-header-modern">
        <h5 class="modal-title-modern">Başvuruyu Reddet</h5>
        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Click="@(() => DialogService.Close(null))" Size="ButtonSize.Small" />
    </div>
    <div class="modal-content-body p-3">
        <p class="text-muted small mb-3">@UserName — bu başvuruyu reddetmek için isteğe bağlı bir gerekçe girin.</p>
        <RadzenTemplateForm TItem="CourierApplicationReviewDto" Data="@Model" Submit="@OnSubmit">
            <RadzenFieldset Text="Red gerekçesi (isteğe bağlı)" class="mb-3">
                <RadzenTextArea @bind-Value="Model.RejectReason" Rows="3" MaxLength="500" Placeholder="Örn: Eksik belge" Style="width: 100%;" />
            </RadzenFieldset>
            <div class="d-flex justify-content-end gap-2">
                <RadzenButton ButtonType="ButtonType.Button" Text="İptal" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(null))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Reddet" ButtonStyle="ButtonStyle.Danger" Icon="cancel" />
            </div>
        </RadzenTemplateForm>
    </div>
</div>
