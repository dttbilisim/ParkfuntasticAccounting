@page "/reset-password"
@using ecommerce.Web.Domain.Services.Abstract
@using Microsoft.AspNetCore.Components
@using Radzen

<PageTitle>@lang["ResetPassword"]</PageTitle>

@if (IsProcessing)
{
    <div class="d-flex justify-content-center my-5">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width: 100%; max-width: 400px;" />
    </div>
}
else
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-sm-12">
                <div class="card shadow-sm border-0 rounded-3 p-4">
                    <h4 class="mb-4 text-center fw-semibold">@lang["SetNewPassword"]</h4>

                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold">@lang["NewPassword"]</label>
                        <input type="password" class="form-control form-control-lg" @bind="NewPassword" placeholder="••••••••" />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-semibold">@lang["ConfirmPassword"]</label>
                        <input type="password" class="form-control form-control-lg" @bind="ConfirmPassword" placeholder="••••••••" />
                    </div>

                    <RadzenButton Text="@lang["UpdatePassword"]"
                                  Click="OnResetPassword"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Style="width: 100%; font-weight: 600; font-size: 16px;" />
                </div>
            </div>
        </div>
    </div>
}