<!-- Category  -->
<section class="category-section-3 py-5">
    <div class="container-fluid-lg">
        <div class="corporate-section-title mb-4">
            <h2 class="fw-bold">@lang["ShopByCategories"]</h2>
            <p>Aracınız için ihtiyacınız olan tüm parçaları kategorilerde keşfedin</p>
        </div>
        <div class="row">
            <div class="col-12">
                @if (CategoryList?.Any() == true)
                {
                    <div class="category-slider-1">
                        <SlickSlider SliderName="category-slider-1" SliderId="category" Config="@SliderConfigs.Category1" InitializeImmediately="true">
                            @foreach (var category in CategoryList.OrderBy(x => x.Name))
                            {
                                <div class="px-2">
                                    <a href="/product-search?catid=@category.Id&catname=@FriendlyUrlHelper.GetFriendlyTitle(category.Name!)" class="category-card-premium">
                                        <div class="category-logo-wrapper">
                                            <img class="img-fluid"
                                                 src="@(string.IsNullOrEmpty(category.ImageUrl) ? "assets/images/category/rice.jpg" : $"{CdnConfig.CategoryImagesUrl}{category.ImageUrl}")"
                                                 alt="@category.Name"
                                                 loading="lazy" 
                                                 decoding="async">
                                        </div>
                                        <span class="category-name-premium">@category.Name</span>
                                    </a>
                                </div>
                            }
                        </SlickSlider>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!--- BRAND(MARKA)-->
            <section class="brand-slider-section section-b-space section-light-bg">
                <div class="container-fluid-lg">
                    <div class="row">
                        <div class="col-12">
                            <div class="corporate-section-title mb-4">
                                <h2 class="fw-bold">@lang["ShopByBrands"]</h2>
                                <p>En seçkin markaların yedek parçalarını keşfedin</p>
                            </div>

                            @if (BrandList?.Any() == true)
                            {
                                <div class="category-slider-1">
                                    <SlickSlider SliderName="brand-slider-1" SliderId="brand" Config="@SliderConfigs.Category1" InitializeImmediately="true">
                                        @foreach (var brand in BrandList)
                                        {
                                            <div class="px-2">
                                                <a href="/product-search?brandid=@brand.Id&brandname=@FriendlyUrlHelper.GetFriendlyTitle(brand.Name!)" class="brand-card-premium">
                                                    <div class="brand-logo-wrapper">
                                                        <img class="img-fluid"
                                                             src="@(string.IsNullOrEmpty(brand.ImageUrl) ? "assets/images/category/rice.jpg" : $"{CdnConfig.BrandImagesUrl}{brand.ImageUrl}")"
                                                             alt="@brand.Name" 
                                                             loading="lazy" 
                                                             decoding="async">
                                                    </div>
                                                    <span class="brand-name-premium">@brand.Name</span>
                                                </a>
                                            </div>
                                        }
                                    </SlickSlider>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </section>
<!--- ÜRÜN --->
<section class="product-section-3">
    <div class="container-fluid-lg">
        <div class="corporate-section-title mb-4">
            <h2>@lang["Home.Product"]</h2>
            <p>Sizler için seçtiğimiz öne çıkan yedek parçalar</p>
        </div>
        <div class="row">
            <div class="col-12">
                @if (ProductList?.Any() == true)
                {
                    <SlickSlider SliderName="slider-7_1" SliderId="slider-7_1" Config="@SliderConfigs.Slider_7_1" InitializeImmediately="true">
                        <ProductComponent Product="@ProductList" CartResult="@CartResult" />
                    </SlickSlider>
                }
                else
                {
                    <div class="text-muted py-3">@lang["NoProducts"]</div>
                }
            </div>
        </div>
    </div>

</section>



