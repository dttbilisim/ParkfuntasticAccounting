@using ecommerce.Admin.Services.Interfaces
@using ecommerce.Web.Domain.Dtos.Cart
@using Microsoft.AspNetCore.Components.Authorization
@using ecommerce.Core.Helpers

@inject ICartStateService CartStateService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ecommerce.Core.Identity.CurrentUser CurrentUser
@inject ecommerce.Web.Domain.Services.Abstract.ICartService CartService
@inject Radzen.NotificationService NotificationService
@inject Radzen.DialogService DialogService
@inject Radzen.TooltipService TooltipService
@inject ecommerce.Admin.Services.AuthenticationService Security

@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<div class="header-cart-dropdown @(IsOpen ? "show" : "")">
    <!-- Backdrop for closing -->
    <div class="cart-backdrop" style="z-index: 2000;" @onclick="Close"></div>

    <div class="cart-panel" style="z-index: 2001;" @onclick="@(() => {})" @onclick:stopPropagation="true">
        <div class="cart-head">
            <h5>
                Sepetim (@(GetTotalItemCount()))
                @if (isRefreshing)
                {
                    <span class="spinner-border spinner-border-sm ms-2 text-muted" role="status"></span>
                }
            </h5>
            <div class="cart-head-actions">
                @if (CartStateService.CurrentCart != null && CartStateService.CurrentCart.TotalItems > 0)
                {
                    <button type="button" 
                            class="btn-clear-cart" 
                            @onclick="ClearAllCart"
                            @onclick:stopPropagation="true"
                            disabled="@isUpdating"
                            title="Sepeti Temizle"
                            aria-label="Sepeti Temizle">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                }
                <button type="button" class="btn-close" @onclick="Close" aria-label="Close">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        </div>
        
        <ul class="cart-list">
            @if (Security.User?.SalesPersonId.HasValue == true && !Security.SelectedCustomerId.HasValue)
            {
                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-75">
                    <div style="background: #e2e8f0; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                        <i class="fa-solid fa-user-check fs-2 text-secondary"></i>
                    </div>
                    <h6 class="text-dark fw-bold">Lütfen Cari Seçin</h6>
                    <p class="small">Sepet işlemleri için bir cari seçmelisiniz.</p>
                </div>
            }
            else if (CartStateService.CurrentCart?.Sellers != null && CartStateService.CurrentCart.Sellers.Any())
            {
                @foreach (var seller in CartStateService.CurrentCart.Sellers)
                {
                    // Initialize expanded state if not present (default closed)
                    if (!_sellerExpandedState.ContainsKey(seller.SellerId))
                    {
                        _sellerExpandedState[seller.SellerId] = false;
                    }
                    var isExpanded = _sellerExpandedState[seller.SellerId];

                    <li class="cart-seller-header" @onclick="() => ToggleSeller(seller.SellerId)" 
                        style="cursor: pointer; display: flex; justify-content: space-between; align-items: center; padding: 12px 15px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; border-left: 4px solid #0e947a; margin-bottom: 2px;">
                        <div class="seller-info" style="display: flex; align-items: center; gap: 10px;">
                            <i class="fa-solid fa-store" style="color: #0e947a; font-size: 1.1rem;"></i>
                            <span class="seller-name" style="font-weight: 700; font-size: 1rem; color: #2d3748;">@seller.SellerName</span>
                        </div>
                        
                        <!-- Center: Total Price -->
                        <div class="seller-total-center" style="font-weight: 800; color: #0e947a; background-color: #e6fffa; padding: 4px 12px; border-radius: 6px; font-size: 0.95rem; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                             @CurrencyHelper.FormatPrice(seller.OrderTotal, seller.Currency)
                        </div>

                        <div class="d-flex align-items-center gap-2">
                             <!-- Removed price from right side -->
                             <i class="fa-solid @(isExpanded ? "fa-angle-up" : "fa-angle-down")" style="font-size: 1rem; color: #718096;"></i>
                        </div>
                    </li>
                    
                    @if (isExpanded)
                    {
                        @foreach (var item in seller.Items)
                        {
                            var isItemUpdating = updatingItems.Contains(item.ProductSellerItemId);
                            <li class="drop-cart" @key="@($"{item.Id}-{item.ProductSellerItemId}")">
                                <div class="img">
                                    @if(!string.IsNullOrEmpty(item.PictureUrl))
                                    {
                                         var cdnBase = Configuration["Cdn:BaseUrl"] ?? "";
                                         var imageUrl = item.PictureUrl.StartsWith("http") ? item.PictureUrl : $"{cdnBase}/ProductImages/{item.PictureUrl}";
                                         <img src="@imageUrl" 
                                              alt="@item.ProductName"
                                              onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                         <div class="cart-image-placeholder" style="display: none;">
                                             <i class="fa-solid fa-image"></i>
                                         </div>
                                    }
                                    else
                                    {
                                         <div class="cart-image-placeholder">
                                             <i class="fa-solid fa-image"></i>
                                         </div>
                                    }
                                </div>
                                <div class="drop-contain">
                                    @{
                                        var cartProductNameId = $"cart-product-name-{item.Id}-{item.ProductSellerItemId}";
                                    }
                                    <h6 @ref="@(_elementReferences[cartProductNameId])"
                                        @onmouseenter="@(() => ShowTooltip(cartProductNameId, item.ProductName))"
                                        @onmouseleave="@(() => HideTooltip())"
                                        style="cursor: pointer;">@item.ProductName</h6>
                                    <div class="meta">
                                        @if (!item.IsPackageProduct)
                                        {
                                            <!-- Normal ürün: miktar düzenlenebilir -->
                                            <div class="quantity-controls" style="position: relative; z-index: 10;">
                                                <button type="button" class="qty-btn minus" 
                                                        disabled="@isItemUpdating"
                                                        @onclick="@(async () => await UpdateQtyDifference(item, -1))"
                                                        @onclick:stopPropagation="true"
                                                        style="pointer-events: auto; cursor: pointer;">
                                                    <i class="fa-solid fa-minus" style="pointer-events: none;"></i>
                                                </button>
                                                <input type="number" 
                                                       value="@item.Quantity" 
                                                       disabled="@isItemUpdating"
                                                       @onchange="@((ChangeEventArgs e) => UpdateQuantity(item, e))"
                                                       min="1" 
                                                       style="pointer-events: auto;" />
                                                <button type="button" class="qty-btn plus" 
                                                        disabled="@isItemUpdating"
                                                        @onclick="@(async () => await UpdateQtyDifference(item, 1))"
                                                        @onclick:stopPropagation="true"
                                                        style="pointer-events: auto; cursor: pointer;">
                                                    <i class="fa-solid fa-plus" style="pointer-events: none;"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Paket ürün: miktar değiştirilemez -->
                                            <span class="text-muted small">Adet: @item.Quantity</span>
                                        }
                                    </div>
                                    @if (item.IsPerfectCompatibility)
                                    {
                                        <div class="cart-compatibility-badge text-success small mt-1">
                                            <i class="fa-solid fa-check-circle"></i> Tam Uyum
                                        </div>
                                    }
                                    @if (item.IsPackageProduct && (item.VisitDate.HasValue || !string.IsNullOrEmpty(item.Voucher) || !string.IsNullOrEmpty(item.GuideName)))
                                    {
                                        <div class="cart-package-info small text-muted mt-1">
                                            @if (item.VisitDate.HasValue)
                                            {
                                                <span class="d-block"><i class="fa-solid fa-calendar-day me-1"></i>Tarih: @item.VisitDate.Value.ToString("dd.MM.yyyy")</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Voucher))
                                            {
                                                <span class="d-block"><i class="fa-solid fa-ticket me-1"></i>Voucher: @item.Voucher</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.GuideName))
                                            {
                                                <span class="d-block"><i class="fa-solid fa-user-tie me-1"></i>Rehber: @item.GuideName</span>
                                            }
                                        </div>
                                    }
                                    @if (item.IsPackageProduct && item.PackageProductItems != null && item.PackageProductItems.Any())
                                    {
                                        <div class="cart-package-details small mt-1">
                                            <div class="text-muted mb-1"><i class="fa-solid fa-boxes-stacked me-1"></i>Paket içeriği (miktarlar düzenlenebilir):</div>
                                            <ul class="list-unstyled mb-0 ps-2" style="font-size: 0.8rem;">
                                                @foreach (var pkg in item.PackageProductItems)
                                                {
                                                    var pkgUpdating = updatingPackageItems.Contains($"{item.ProductSellerItemId}-{pkg.ProductId}");
                                                    <li class="d-flex align-items-center gap-1 mb-1">
                                                        <span class="flex-grow-1">@pkg.ProductName — @CurrencyHelper.FormatPrice(pkg.Price, item.Currency)</span>
                                                        <div class="d-flex align-items-center" style="gap: 2px;">
                                                            <button type="button" class="btn btn-sm p-0" style="width: 24px; height: 24px; font-size: 0.7rem;"
                                                                    disabled="@(pkgUpdating || pkg.Quantity <= 0)"
                                                                    @onclick="@(() => UpdatePackageItemQty(item, pkg, -1))"
                                                                    @onclick:stopPropagation="true">−</button>
                                                            <input type="number" class="form-control form-control-sm text-center" style="width: 40px; font-size: 0.75rem; padding: 0 2px;"
                                                                   value="@pkg.Quantity" min="0"
                                                                   disabled="@pkgUpdating"
                                                                   @onchange="@((ChangeEventArgs ev) => UpdatePackageItemQtyFromInput(item, pkg, ev))"
                                                                   @onclick:stopPropagation="true"
                                                                   @onkeydown:stopPropagation="true" />
                                                            <button type="button" class="btn btn-sm p-0" style="width: 24px; height: 24px; font-size: 0.7rem;"
                                                                    disabled="@pkgUpdating"
                                                                    @onclick="@(() => UpdatePackageItemQty(item, pkg, 1))"
                                                                    @onclick:stopPropagation="true">+</button>
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </div>
                                <div class="drop-price">@CurrencyHelper.FormatPrice(item.Total, item.Currency)</div>
                                
                                <button type="button" class="item-remove-btn" 
                                        disabled="@isItemUpdating"
                                        @onclick="@(async () => await RemoveItem(item.Id, item.ProductSellerItemId))"
                                        @onclick:stopPropagation="true">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </li>
                        }
                        
                        <!-- Seller Footer -->
                        <li class="cart-seller-footer">
                            <div class="seller-footer-content">
                                <span class="seller-footer-label">Toplam</span>
                                <span class="seller-footer-total">@CurrencyHelper.FormatPrice(seller.OrderTotal, seller.Currency)</span>
                            </div>
                        </li>
                    }
                }
            }
            else
            {
                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-75">
                    <div style="background: #e2e8f0; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                        <i class="fa-solid fa-cart-shopping fs-2 text-secondary"></i>
                    </div>
                    <h6 class="text-dark fw-bold">Sepetiniz Boş</h6>
                    <p class="small">Ürün eklemek için ürünleri inceleyebilirsiniz.</p>
                </div>
            }
        </ul>

        @if (CartStateService.CurrentCart != null && CartStateService.CurrentCart.TotalItems > 0)
        {
            <div class="cart-foot" style="position: relative;">
                @if (isUpdating)
                {
                    <div class="cart-loading-overlay">
                        <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                        <span class="ms-2 small">Güncelleniyor...</span>
                    </div>
                }
                
                <div class="cart-total-row">
                    <span class="label">Ara Toplam</span>
                    <span class="value @(isUpdating ? "text-muted" : "")">@CurrencyHelper.FormatPrice(CartStateService.CurrentCart.SubTotal, CartStateService.CurrentCart.Currency)</span>
                </div>

                @if(CartStateService.CurrentCart.OrderTotalDiscount > 0)
                {
                    <div class="cart-total-row">
                        <span class="label">İndirim</span>
                        <span class="value text-danger @(isUpdating ? "opacity-50" : "")">-@CurrencyHelper.FormatPrice(CartStateService.CurrentCart.OrderTotalDiscount, CartStateService.CurrentCart.Currency)</span>
                    </div>
                }
                
                <div class="cart-total-row grand-total">
                    <span class="label">Genel Toplam</span>
                    <span class="value @(isUpdating ? "text-muted" : "")">@CurrencyHelper.FormatPrice(CartStateService.CurrentCart.OrderTotal, CartStateService.CurrentCart.Currency)</span>
                </div>

                <div class="cart-actions">
                    <a href="/admin-checkout" class="btn-b2b btn-b2b-primary w-100 @(isUpdating ? "disabled" : "")" @onclick="Close">
                        <i class="fa-solid fa-check-circle me-2"></i>Siparişi Tamamla
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    
    private bool isRefreshing = false;
    private bool isUpdating = false;
    private HashSet<int> updatingItems = new();
    private HashSet<string> updatingPackageItems = new();
    
    // Dictionary to store Expanded state for each seller
    private Dictionary<int, bool> _sellerExpandedState = new();

    // Dictionary to store ElementReferences by ID for tooltips
    private Dictionary<string, ElementReference> _elementReferences = new();

    protected override void OnInitialized()
    {
        CartStateService.OnChange += OnCartStateChanged;
    }
    
    private void OnCartStateChanged()
    {
        isRefreshing = false;
        isUpdating = false;
        updatingItems.Clear();
        updatingPackageItems.Clear();
        // Optionally keep state or clear it. If clear, all accordions close on update.
        // _sellerExpandedState.Clear(); // Uncomment to close on update
        InvokeAsync(StateHasChanged);
    }
    
    private void ToggleSeller(int sellerId)
    {
        if (!_sellerExpandedState.ContainsKey(sellerId))
        {
            _sellerExpandedState[sellerId] = false;
        }
        
        _sellerExpandedState[sellerId] = !_sellerExpandedState[sellerId];
        StateHasChanged();
    }

    public void Dispose()
    {
        CartStateService.OnChange -= OnCartStateChanged;
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task UpdatePackageItemQty(ecommerce.Web.Domain.Dtos.Cart.CartItemDto item, ecommerce.Web.Domain.Dtos.Cart.CartPackageItemDto pkg, int delta)
    {
        var newQty = Math.Max(0, pkg.Quantity + delta);
        await UpdatePackageItemQuantities(item, pkg.ProductId, newQty);
    }

    private async Task UpdatePackageItemQtyFromInput(ecommerce.Web.Domain.Dtos.Cart.CartItemDto item, ecommerce.Web.Domain.Dtos.Cart.CartPackageItemDto pkg, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val >= 0)
            await UpdatePackageItemQuantities(item, pkg.ProductId, val);
    }

    private async Task UpdatePackageItemQuantities(ecommerce.Web.Domain.Dtos.Cart.CartItemDto item, int productId, int newQuantity)
    {
        var key = $"{item.ProductSellerItemId}-{productId}";
        updatingPackageItems.Add(key);
        isUpdating = true;
        StateHasChanged();

        try
        {
            var quantities = item.PackageProductItems?.ToDictionary(x => x.ProductId, x => x.Quantity) ?? new Dictionary<int, int>();
            quantities[productId] = newQuantity;

            var req = new ecommerce.Web.Domain.Dtos.Cart.CartItemUpsertDto
            {
                ProductSellerItemId = item.ProductSellerItemId,
                Quantity = 0,
                CustomerId = Security?.SelectedCustomerId,
                Voucher = item.Voucher,
                GuideName = item.GuideName,
                VisitDate = item.VisitDate,
                PackageItemQuantities = quantities
            };

            var result = await CartService.CreateCartItem(req);
            if (result.Ok && result.Result != null)
            {
                CartStateService.SetCart(result.Result);
                StateHasChanged();
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Güncellendi", Detail = "Paket içeriği güncellendi.", Duration = 2000 });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Hata", Detail = result.Metadata?.Message ?? "Güncellenemedi.", Duration = 4000 });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Hata", Detail = ex.Message, Duration = 4000 });
        }
        finally
        {
            updatingPackageItems.Remove(key);
            isUpdating = false;
            StateHasChanged();
        }
    }

    private async Task UpdateQtyDifference(ecommerce.Web.Domain.Dtos.Cart.CartItemDto item, int diff)
    {
        var newQty = item.Quantity + diff;
        
        if (newQty <= 0)
        {
            await RemoveItem(item.Id, item.ProductSellerItemId);
            return;
        }
        
        var e = new ChangeEventArgs { Value = newQty };
        await UpdateQuantity(item, e);
    }

    private async Task UpdateQuantity(ecommerce.Web.Domain.Dtos.Cart.CartItemDto item, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newQty) && newQty > 0)
        {
            if (newQty == item.Quantity) return;
            
            var delta = newQty - item.Quantity;
            if (delta == 0) return;

            // Mark as updating
            updatingItems.Add(item.ProductSellerItemId);
            isUpdating = true;
            StateHasChanged();

            try
            {
                var req = new ecommerce.Web.Domain.Dtos.Cart.CartItemUpsertDto 
                { 
                    ProductSellerItemId = item.ProductSellerItemId, 
                    Quantity = delta,
                    CustomerId = Security?.SelectedCustomerId
                };
                
                var result = await CartService.CreateCartItem(req);
                
                if (result.Ok && result.Result != null)
                {
                    // Use returned cart directly instead of RefreshCart (avoids cache issues)
                    CartStateService.SetCart(result.Result);
                    StateHasChanged();
                    
                    NotificationService.Notify(new NotificationMessage
                    {
                        Severity = NotificationSeverity.Success,
                        Summary = "Güncellendi",
                        Detail = "Sepet güncellendi.",
                        Duration = 2000
                    });
                }
                else
                {
                    NotificationService.Notify(new NotificationMessage
                    {
                        Severity = NotificationSeverity.Error,
                        Summary = "Hata",
                        Detail = result.Metadata?.Message ?? "Miktar güncellenemedi.",
                        Duration = 4000
                    });
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Hata",
                    Detail = ex.Message,
                    Duration = 4000
                });
            }
            finally
            {
                updatingItems.Remove(item.ProductSellerItemId);
                isUpdating = false;
                StateHasChanged();
            }
        }
    }

    private async Task RemoveItem(int itemId, int? productSellerItemId = null)
    {
        if (productSellerItemId.HasValue)
        {
            updatingItems.Add(productSellerItemId.Value);
        }
        isUpdating = true;
        StateHasChanged();
        
        try
        {
            var res = await CartService.CartItemRemove(itemId);
            if(res.Ok && res.Result != null)
            {
                // Use returned cart directly instead of RefreshCart (avoids cache issues)
                CartStateService.SetCart(res.Result);
                StateHasChanged();
                
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Info,
                    Summary = "Silindi",
                    Detail = "Ürün sepetten kaldırıldı.",
                    Duration = 2000
                });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Hata",
                    Detail = res.Metadata?.Message ?? "Ürün silinemedi.",
                    Duration = 4000
                });
            }
        }
        catch(Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Hata",
                Detail = ex.Message,
                Duration = 4000
            });
        }
        finally
        {
            if (productSellerItemId.HasValue)
            {
                updatingItems.Remove(productSellerItemId.Value);
            }
            isUpdating = false;
            StateHasChanged();
        }
    }

    private int GetTotalItemCount()
    {
        // Plasiyer with no customer selected -> Show 0
        if (Security.User?.SalesPersonId.HasValue == true && !Security.SelectedCustomerId.HasValue)
        {
            return 0;
        }

        if (CartStateService?.CurrentCart == null)
            return 0;
        
        // Use CartCount (unique product count) like CartPage.razor does
        return CartStateService.CurrentCart.CartCount > 0 
            ? CartStateService.CurrentCart.CartCount 
            : 0;

    }

    protected void ShowTooltip(string elementId, string text)
    {
        if (!string.IsNullOrEmpty(text) && !string.IsNullOrEmpty(elementId) && _elementReferences.TryGetValue(elementId, out var elementRef))
        {
            TooltipService.Open(elementRef, text, new Radzen.TooltipOptions 
            { 
                Duration = 0,
                Style = "background-color: #0e947a !important; background: #0e947a !important; color: white !important; border: none !important; padding: 8px 12px !important; border-radius: 4px !important; font-size: 0.875rem !important;"
            });
        }
    }

    protected void HideTooltip()
    {
        TooltipService.Close();
    }

    private async Task ClearAllCart()
    {
        if (CartStateService?.CurrentCart == null || CartStateService.CurrentCart.TotalItems == 0)
            return;

        var confirmed = await DialogService.Confirm(
            "Sepeti Temizle",
            "Sepetinizdeki tüm ürünler silinecektir. Emin misiniz?",
            new Radzen.ConfirmOptions
            {
                OkButtonText = "Evet, Temizle",
                CancelButtonText = "İptal"
            }
        );

        if (!confirmed.HasValue || !confirmed.Value)
            return;

        isUpdating = true;
        isRefreshing = true;
        StateHasChanged();

        try
        {
            var result = await CartService.ClearCart();
            
            if (result.Ok && result.Result != null)
            {
                CartStateService.SetCart(result.Result);
                StateHasChanged();
                
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Sepet Temizlendi",
                    Detail = "Sepetinizdeki tüm ürünler kaldırıldı.",
                    Duration = 3000
                });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Hata",
                    Detail = result.Metadata?.Message ?? "Sepet temizlenemedi.",
                    Duration = 4000
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Hata",
                Detail = ex.Message,
                Duration = 4000
            });
        }
        finally
        {
            isUpdating = false;
            isRefreshing = false;
            StateHasChanged();
        }
    }
}
