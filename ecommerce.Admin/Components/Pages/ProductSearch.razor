            @<div class="image-zoom-content position-relative d-flex justify-content-center align-items-center" style="width:100%; height:100%;" @onclick="() => ds.Close()">
                <button class="close-zoom-btn position-absolute top-0 end-0 m-3" style="z-index: 1050; background: rgba(0,0,0,0.5); color: white; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer;" @onclick="() => ds.Close()" @onclick:stopPropagation="true">
                    <i class="fa-solid fa-xmark"></i>
                </button>
                <img src="@url" alt="Zoomed Image" style="max-width: 90vw; max-height: 90vh; object-fit: contain; box-shadow: 0 10px 40px rgba(0,0,0,0.5); border-radius: 8px; cursor: pointer;" @onclick:stopPropagation="true" />
            </div>, 
            new DialogOptions { 
                Width = "100%", 
                Height = "100%", 
                ShowTitle = false, 
                ShowClose = false,
                CloseDialogOnEsc = true,
                CssClass = "transparent-dialog",
                Style = "background: rgba(0,0,0,0.7); box-shadow: none; border: none; padding: 0;"
            });
    }

    protected async Task OpenVehicleModal(SellerProductViewModel product)
    {
        // [VIN-COMP-FIX] Prepare a unified list of compatible vehicles
        // emphasizing the current search context if it exists.
        var compatibilities = new List<ecommerce.Domain.Shared.Dtos.Product.SellerProductCompatibilityDto>();

        // Add vehicles from Parts (Rich data with Manufacturer/Model)
        if (product.Parts != null && product.Parts.Any())
        {
            foreach (var part in product.Parts)
            {
                if (part.SubModelsJson != null && part.SubModelsJson.Any())
                {
                    foreach (var sm in part.SubModelsJson)
                    {
                        compatibilities.Add(new ecommerce.Domain.Shared.Dtos.Product.SellerProductCompatibilityDto
                        {
                            ManufacturerName = part.ManufacturerName,
                            BaseModelName = part.BaseModelName,
                            SubModelName = sm.Name,
                            ManufacturerKey = part.ManufacturerKey?.ToString(),
                            BaseModelKey = part.BaseModelKey?.ToString()
                        });
                    }
                }
                else if (!string.IsNullOrEmpty(part.ManufacturerName))
                {
                    compatibilities.Add(new ecommerce.Domain.Shared.Dtos.Product.SellerProductCompatibilityDto
                    {
                        ManufacturerName = part.ManufacturerName,
                        BaseModelName = part.BaseModelName,
                        SubModelName = "Tüm Modeller",
                        ManufacturerKey = part.ManufacturerKey?.ToString(),
                        BaseModelKey = part.BaseModelKey?.ToString()
                    });
                }
            }
        }
        // 3. Fallback to SubModelsJson (Statik katalog verisi - Fix labels here too)
        else if (product.SubModelsJson != null && product.SubModelsJson.Any())
        {
            foreach (var sm in product.SubModelsJson)
            {
                compatibilities.Add(new ecommerce.Domain.Shared.Dtos.Product.SellerProductCompatibilityDto
                {
                    ManufacturerName = product.ManufacturerName,
                    BaseModelName = product.BaseModelName,
                    SubModelName = sm.Name,
                    ManufacturerKey = product.ManufacturerKey,
                    BaseModelKey = product.BaseModelKey
                });
            }
        }

        await DialogService.OpenAsync("", ds =>
            @<div class="vehicle-modal-content-wrapper">
                <div class="vehicle-modal-header p-4 border-bottom shadow-sm" style="background: linear-gradient(135deg, var(--ps-primary) 0%, var(--ps-primary-dark) 100%);">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <div>
                            <h5 class="mb-1 fw-bold fs-4 text-white"><i class="fa-solid fa-car-side me-2"></i>Uyumlu Araçlar</h5>
                            <small class="text-white-50">@product.ProductName</small>
                        </div>
                        <button class="btn btn-sm btn-light rounded-circle shadow-sm" style="width: 32px; height: 32px;" @onclick="() => ds.Close()">
                            <i class="fa-solid fa-xmark text-success"></i>
                        </button>
                    </div>
                </div>
                <div class="vehicle-modal-body p-3" style="max-height: 550px; overflow-y: auto; background: #f8fafc;">
                    @if (compatibilities.Any())
                    {
                        <div class="row g-2">
                            @foreach (var v in compatibilities)
                            {
                                bool isContext = v.SubModelName == "ARAMA BAĞLAMI";
                                <div class="col-md-6">
                                    <div class="p-3 border rounded shadow-sm @(isContext ? "bg-success text-white border-success" : "bg-white")" style="transition: transform 0.2s;">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fa-solid fa-car @(isContext ? "text-white" : "text-success") opacity-75"></i>
                                            <div class="flex-grow-1">
                                                <div class="fw-bold small" style="line-height: 1.2;">@v.ManufacturerName @v.BaseModelName</div>
                                                <div class="@(isContext ? "text-white-50" : "text-muted")" style="font-size: 0.75rem;">@v.SubModelName</div>
                                            </div>
                                            @if(isContext) {
                                                <span class="badge bg-white text-success small" style="font-size:0.6rem">SEÇİLİ</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="fa-solid fa-triangle-exclamation d-block mb-3 fs-2 opacity-25"></i>
                            Uyumlu araç bilgisi bulunamadı.
                        </div>
                    }
                </div>
            </div>,
            new DialogOptions {
                Width = "700px",
                ShowTitle = false,
                ShowClose = false,
                Style = "border-radius: 12px; overflow: hidden; padding: 0;"
            });
    }



    protected async Task OpenProductDetailModal(SellerProductViewModel product)
    {
         // ML Instrumentation: Log Click with Field Tracking
         if (!string.IsNullOrWhiteSpace(searchText))
         {
             var rank = searchResult.Data.IndexOf(product) + 1;
             
             // Use service to detect matched fields (DRY principle)
             var fieldMatch = FieldMatcherService.DetectMatchedFields(searchText, product);
             
             _ = SearchAnalyticsService.LogInteractionAsync(new ecommerce.Domain.Shared.Dtos.Search.SearchInteractionDto
             {
                 SearchTerm = searchText,
                 ProductId = product.SellerItemId,
                 InteractionType = "Click",
                 Rank = rank,
                 UserId = Security?.User?.Id,
                 MatchedFields = fieldMatch.MatchedFields,
                 FieldScores = fieldMatch.FieldScores,
                 PrimaryMatchField = fieldMatch.PrimaryMatchField
             });
         }

         // Fetch similar products before opening the modal
         var similarProducts = new List<SellerProductViewModel>();
         if (product.OemCode != null && product.OemCode.Any())
         {
             // Array'den tüm OemCode'ları kullan
             var result = await ProductSearchService.GetSimilarProductsAsync(product.OemCode);
             if (result.Ok && result.Result != null)
             {
                 similarProducts = result.Result.Where(p => p.SalePrice > 0 && p.SellerItemId != product.SellerItemId).ToList();
             }
         }

         if (product.IsPackageProduct)
         {
             await DialogService.OpenAsync<Modals.PackageDetailModal>($"Paket Ürün: {product.ProductName}",
                 new Dictionary<string, object>
                 {
                     { "PackageName", product.ProductName ?? "" },
                     { "RefProductId", product.ProductId },
                     { "SellerId", product.SellerId },
                     { "SellerItemId", product.SellerItemId },
                     { "Currency", product.Currency ?? "TL" }
                 },
                 new DialogOptions
                 {
                     Width = "480px",
                     ShowTitle = false,
                     ShowClose = false,
                     Style = "border-radius: 16px; overflow: hidden; padding: 0; border: none; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); max-height: 85vh;"
                 });
         }
         else
         {
             await DialogService.OpenAsync<Modals.ProductDetailModal>($"Ürün Detayı: {product.PartNumber}",
                 new Dictionary<string, object>
                 {
                     { "Product", product },
                     { "SimilarProducts", similarProducts }
                 },
                 new DialogOptions
                 {
                     Width = "900px",
                     ShowTitle = false,
                     ShowClose = false,
                     Style = "border-radius: 16px; overflow: hidden; padding: 0; border: none; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); max-height: 85vh;"
                 });
         }
    }
}

