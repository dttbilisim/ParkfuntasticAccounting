@page "/address-test"
@using ecommerce.Web.Domain.Services
@using ecommerce.Web.Domain.Dtos.Address



<PageTitle>@lang["AddressTest.PageTitle"]</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">@lang["AddressTest.Header"]</h2>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>@lang["AddressTest.CitySelection.Title"]</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">@lang["AddressTest.CitySelection.Label"]</label>
                                <select class="form-select" @onchange="OnCityChanged" disabled="@isLoading">
                                    <option value="">@lang["AddressTest.CitySelection.Placeholder"]</option>
                                    @if (cities != null)
                                    {
                                        @foreach (var city in cities)
                                        {
                                            <option value="@city.Code" selected="@(selectedCityCode == city.Code)">@city.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>@lang["AddressTest.TownSelection.Title"]</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">@lang["AddressTest.TownSelection.Label"]</label>
                                <select class="form-select" @onchange="OnTownChanged" disabled="@(isLoading || towns == null)">
                                    <option value="">@lang["AddressTest.TownSelection.Placeholder"]</option>
                                    @if (towns != null)
                                    {
                                        @foreach (var town in towns)
                                        {
                                            <option value="@town.Code" selected="@(selectedTownCode == town.Code)">@town.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>@lang["AddressTest.NeighborhoodSelection.Title"]</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">@lang["AddressTest.NeighborhoodSelection.Label"]</label>
                                <select class="form-select" @onchange="OnNeighboorChanged" disabled="@(isLoading || neighboors == null)">
                                    <option value="">@lang["AddressTest.NeighborhoodSelection.Placeholder"]</option>
                                    @if (neighboors != null)
                                    {
                                        @foreach (var neighboor in neighboors)
                                        {
                                            <option value="@neighboor.Code" selected="@(selectedNeighboorCode == neighboor.Code)">@neighboor.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>@lang["AddressTest.StreetSelection.Title"]</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">@lang["AddressTest.StreetSelection.Label"]</label>
                                <select class="form-select" @onchange="OnStreetChanged" disabled="@(isLoading || streets == null)">
                                    <option value="">@lang["AddressTest.StreetSelection.Placeholder"]</option>
                                    @if (streets != null)
                                    {
                                        @foreach (var street in streets)
                                        {
                                            <option value="@street.Code" selected="@(selectedStreetCode == street.Code)">@street.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>@lang["AddressTest.BuildingSelection.Title"]</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">@lang["AddressTest.BuildingSelection.Label"]</label>
                                <select class="form-select" @onchange="OnBuildingChanged" disabled="@(isLoading || buildings == null)">
                                    <option value="">@lang["AddressTest.BuildingSelection.Placeholder"]</option>
                                    @if (buildings != null)
                                    {
                                        @foreach (var building in buildings)
                                        {
                                            <option value="@building.Code" selected="@(selectedBuildingCode == building.Code)">@building.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5>@lang["AddressTest.HomeSelection.Title"]</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">@lang["AddressTest.HomeSelection.Label"]</label>
                                <select class="form-select" @onchange="OnHomeChanged" disabled="@(isLoading || homes == null)">
                                    <option value="">@lang["AddressTest.HomeSelection.Placeholder"]</option>
                                    @if (homes != null)
                                    {
                                        @foreach (var home in homes)
                                        {
                                            <option value="@home.Code" selected="@(selectedHomeCode == home.Code)">@home.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="text-center mt-4 text-muted">
                    <p class="mt-2">@lang["AddressTest.LoadingMessage"]</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-4" role="alert">
                    <strong>@lang["AddressTest.ErrorPrefix"]</strong> @errorMessage
                </div>
            }

            @if (selectedAddress != null)
            {
                <div class="card mt-4">
                    <div class="card-header">
                        <h5>@lang["AddressTest.SelectedAddress.Title"]</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>@lang["AddressTest.SelectedAddress.City"]</strong> @selectedAddress.CityName</p>
                        <p><strong>@lang["AddressTest.SelectedAddress.Town"]</strong> @selectedAddress.TownName</p>
                        <p><strong>@lang["AddressTest.SelectedAddress.Neighborhood"]</strong> @selectedAddress.NeighboorName</p>
                        <p><strong>@lang["AddressTest.SelectedAddress.Street"]</strong> @selectedAddress.StreetName</p>
                        <p><strong>@lang["AddressTest.SelectedAddress.Building"]</strong> @selectedAddress.BuildingName</p>
                        <p><strong>@lang["AddressTest.SelectedAddress.Home"]</strong> @selectedAddress.HomeName</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
